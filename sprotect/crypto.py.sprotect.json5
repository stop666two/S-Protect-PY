{
  // ==========================================
  // 密码学引擎 — 加密算法实现
  // ==========================================
  // 此模块包含 AES-256-GCM、ChaCha20-Poly1305、XOR 流混淆、
  // HKDF-SHA256 密钥派生、RSA-4096/ECC 密钥对生成、
  // master_key 拆分与分片恢复、三层指纹验证等。
  //
  // 安全等级：最高。此模块是保护链的核心。
  // 任何针对此模块的逆向成功都意味着整个保护系统失效。
  // ==========================================

  obfuscate: {
    level: 5,
    rename_variables: true,
    rename_functions: true,
    rename_classes: true,
    encrypt_strings: true,
    encrypt_numbers: true,
    control_flow_flattening: true,
    dead_code_injection: true,
    string_split: true,
    obfuscate_imports: true,
    obfuscate_calls: true,
    obfuscate_arithmetic: true,
    obfuscate_booleans: true,
  },

  anti_debug: {
    enabled: true,
    action: "exit",
    checks: ["pdb", "debugger", "vm", "sandbox", "ida"],
  },

  virtualization: {
    enabled: true,
    mode: "full",
  },
}
