{
  // ===================================================================
  // 密码学引擎 — 加密算法实现
  // ===================================================================
  // 此模块包含以下核心功能：
  //   • AES-256-GCM 加密/解密
  //   • ChaCha20-Poly1305 加密/解密
  //   • XOR 流混淆（轻量级第一层）
  //   • HKDF-SHA256 密钥派生（域分离派生各子密钥）
  //   • RSA-4096 密钥对生成 + OAEP+SHA256 加密
  //   • ECC P-256/P-384/P-521 密钥对生成 + ECIES
  //   • master_key 拆分与分片恢复（Shamir Secret Sharing）
  //   • 三层指纹验证（f1=f(xor), f2=blake3, f3=HMAC-SHA256）
  //   • 密钥伪装（1 个真实分片 + 4 个诱饵分片）
  //   • 多态填充（0-512 字节随机填充）
  //
  // ⚠️ 安全等级：最高 ⚠️
  //   此模块是整个保护链的最核心环节。
  //   任何针对此模块的逆向成功都意味着整个保护系统完全失效。
  //   攻击者一旦理解 AES-GCM 密钥如何派生、指纹如何验证，
  //   即可绕过全部保护逻辑直接提取原始数据。
  //
  //   因此，此模块的所有混淆选项必须开到最大强度。
  //   不允许任何折中方案。
  // ===================================================================

  obfuscate: {
    // =================================================================
    // --- level: 混淆等级 ---
    //   数据类型: number（整数）
    //   可用值: 1 | 2 | 3 | 4 | 5
    //   ⚠️ 不可用值: 0, -1, 1.5, "5", null（非正整数或非标准范围均无效）
    //   推荐值: 5
    //   ❌ 禁止值: 1 | 2 | 3（等级太低，加密算法的核心逻辑容易被逆向工程）
    //   原因: 密码学模块包含 AES-GCM 加密循环、HKDF 迭代派生、
    //     Shamir 分片恢复等敏感逻辑。混淆等级 1-3 不足以隐藏
    //     密钥调度、S-box 查表、GF(2^128) 乘法等可识别特征。
    //     Chaos 代理在等级 5 下会注入大量不透明谓词和控制流分支，
    //     使反编译工具的 F5 输出完全不可读。
    // =================================================================
    level: 5,

    // =================================================================
    // --- rename_variables: 变量重命名 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   ⚠️ 不可用值: "true", 1, 0, "yes", null
    //   推荐值: true
    //   ❌ 禁止值: false（核心模块不得保持原变量名）
    //   原因: 密码学代码中变量名往往暗示用途，如
    //     `master_key`、`nonce`、`aad`、`ciphertext`、
    //     `derived_key`、`fingerprint` 等。
    //     保留原名 = 直接告诉攻击者每个变量的作用。
    //     重命名为 hex 编码后攻击者必须通过数据流分析
    //     才能推断变量用途，大幅提高逆向成本。
    // =================================================================
    rename_variables: true,

    rename_functions: true,
    rename_classes: true,

    // =================================================================
    // --- encrypt_strings: 字符串加密 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   ⚠️ 不可用值: "true", "false", 1, 0
    //   推荐值: true
    //   ❌ 禁止值: false
    //   原因: 密码学模块包含大量敏感字符串：
    //     • 算法名称: "AES-256-GCM"、"ChaCha20"、"HKDF-SHA256"
    //     • 错误消息: "Decryption failed: MAC mismatch"、"Invalid key length"
    //     • 常量: "SProtect_v1_fingerprint"、"master_key_domain"
    //     这些字符串是攻击者的"路标"——通过搜索这些字符串
    //     可以快速定位关键函数。加密后所有字符串在二进制中
    //     呈现为 base64 乱码，运行时才解密。
    //     注意: 运行时解密的性能开销可以忽略（每个字符串解密耗时 < 1µs）。
    // =================================================================
    encrypt_strings: true,

    encrypt_numbers: true,
    control_flow_flattening: true,
    dead_code_injection: true,
    string_split: true,
    obfuscate_imports: true,
    obfuscate_calls: true,
    obfuscate_arithmetic: true,
    obfuscate_booleans: true,
  },

  anti_debug: {
    // =================================================================
    // --- enabled: 反调试总开关 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   ⚠️ 不可用值: "true", 1, "yes"
    //   推荐值: true
    //   ❌ 禁止值: false
    //   原因: 密码学代码是攻击者的首要目标。他们会在调试器中
    //     单步跟踪加密/解密过程，观察寄存器中的密钥值。
    //     启用反调试可以：
    //     • 检测 pdb.set_trace() 断点注入
    //     • 检测 PyCharm/VSCode 远程调试器附加
    //     • 检测 VirtualBox/VMware 等虚拟机环境
    //     • 检测 IDA Pro/Ghidra 调试器
    //     一个能在调试器中单步跟踪 AES-GCM 的攻击者，
    //     可以在几步之内提取出 master_key。
    // =================================================================
    enabled: true,

    // =================================================================
    // --- action: 反调试触发后的行为 ---
    //   数据类型: string
    //   可用值: "exit" | "warn" | "crash" | "corrupt"
    //   ⚠️ 不可用值: "print", "log", "ignore", 123, null
    //   推荐值: "exit"
    //   ❌ 禁止值: "warn"（警告后攻击者可继续调试）
    //   原因: 对于密码学模块，检测到调试器后必须立即终止进程。
    //     如果只是 warn，攻击者可以 patch 掉警告逻辑继续分析。
     //     "exit" 会调用 os._exit(0) 或 sys.exit() 立即终止，
    //     不给攻击者任何反应时间。
    //     备选:
    //       "crash" — 触发段错误或除零异常，模拟程序崩溃
    //       "corrupt" — 返回错误解密结果（但可能导致后续崩溃暴露）
    // =================================================================
    action: "exit",

    // =================================================================
    // --- checks: 检测项目列表 ---
    //   数据类型: string[]
    //   可用值: "pdb" | "debugger" | "vm" | "sandbox" | "ida" |
    //           "hiderecon" | "container" | "remote_debug" | "all"
    //   ⚠️ 不可用值: ["pdb"], null, [123]
    //   推荐值: ["pdb", "debugger", "vm", "sandbox", "ida"]
    //   ❌ 禁止值: ["pdb"]（仅检测 pdb 太弱，高级攻击者不用 pdb）
    //   原因:
    //     • "pdb" — 检测 Python 标准库调试器 pdb.set_trace()
    //     • "debugger" — 检测 sys.gettrace() != None（含 PyCharm/VSCode）
    //     • "vm" — 检测 VirtualBox/VMware/Parallels 特征
    //       （密码学模块中 CPU 指令可能因 VM 差异导致加密结果错误，
    //        所以就算不是攻击场景也应该退出）
    //     • "sandbox" — 检测 API 沙箱（Cuckoo/CAPE 等）
    //     • "ida" — 检测 IDA Pro 调试器附加
    //     检测项越多，攻击者绕过成本越高。
    //     但注意: VM 检测可能存在误报（合法用户在虚拟机中运行）。
    //     考虑到密码学模块在真实硬件上运行才能保证加密正确性，
    //     这个误报是可接受的。
    // =================================================================
    checks: ["pdb", "debugger", "vm", "sandbox", "ida"],
  },

  virtualization: {
    // =================================================================
    // --- enabled: 虚拟化总开关 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   ❌ 禁止值: false
    //   原因: 启用字节码虚拟化后，核心加密逻辑被编译为自定义
    //     虚拟指令集，反编译工具（uncompyle6、pycdc、decompyle3）
    //     无法将其还原为 Python 字节码。攻击者面对的是自定义 VM
    //     的解释器，必须逆向 VM 指令集本身才能理解逻辑。
    //     这是目前最强的保护手段之一。
    // =================================================================
    enabled: true,

    // =================================================================
    // --- mode: 虚拟化模式 ---
    //   数据类型: string
    //   可用值: "full" | "partial" | "smart"
    //   ⚠️ 不可用值: "light", "none", true, 1
    //   推荐值: "full"
    //   ❌ 禁止值: "partial"（部分虚拟化会暴露部分逻辑）
    //   原因:
    //     • "full" — 整个模块被虚拟化，无任何 Python 字节码残留
    //     • "partial" — 仅关键函数被虚拟化，非关键部分保持原样
    //       （可被攻击者利用作为入口点）
    //     • "smart" — 自动选择虚拟化范围，但可能存在边界漏洞
    //     密码学模块必须选择 "full"，确保没有任何函数
    //     以原始 Python 字节码形式存在。
    // =================================================================
    mode: "full",
  },
}
