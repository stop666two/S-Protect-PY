{
  // ===================================================================
  // 类型定义模块 — 所有 Enum 和 Dataclass
  // ===================================================================
  // 此模块包含：
  //   • 7 个 Enum（ObfuscateLevel, InterdependencyMode, NamingStyle,
  //        AntiDebugAction, VirtualizationMode, WatermarkLevel,
  //        EncryptAlgorithm）
  //   • 15 个 @dataclass（从 RenameRules 到 Config 顶层聚合）
  //   • HybridEncryptConfig、PackConfig 等
  //
  // ⚠️ 关键约束（违反将导致运行时崩溃）：
  //   1. Enum 名称不能混淆——enum 的 name/value 被反射访问
  //   2. Dataclass 字段名不能混淆——config.py 通过 d.get("field") 访问
  //   3. 类名不能混淆——被 isinstance() 和类型注解引用
  //   4. encrypt_strings 不能 true——枚举值字符串用于配置匹配
  //
  // → 此模块只能做最低限度混淆（level 2，仅变量重命名）
  // ===================================================================

  obfuscate: {
    // --- level: 混淆等级 ---
    // 可用值: 1 | 2
    // ❌ 禁止: 3-5（控制流平坦化和死代码注入会破坏类结构）
    // 推荐值: 2（level 1 只修改变量名，安全）
    level: 2,

    // --- rename_variables: 变量重命名 ---
    // 可用值: true | false
    // 推荐值: true（安全，只影响局部变量）
    rename_variables: true,

    // --- rename_functions: 函数重命名 ---
    // ❌ 必须 false
    // 原因: Enum 的 __init__ 等魔术方法被 Python 运行时调用，
    //   dataclass 的 __init__、__repr__ 自动生成方法，
    //   改名后出现 TypeError
    rename_functions: false,

    // --- rename_classes: 类重命名 ---
    // ❌ 必须 false
    // 原因: Config 类被所有模块引用，EncryptConfig 等
    //   被 config.py 的 _enc() 显式构造，
    //   类名改变导致 NameError
    rename_classes: false,

    rename_rules: {
      style: "hex",
      // 保留所有公开 API 类型名
      reserved: [],
    },

    // --- encrypt_strings: 字符串加密 ---
    // ❌ 必须 false
    // 原因: Enum 的 value 属性（如 "chain"、"exit"、"hex"）
    //   以字符串形式被 config.py 的 d.get() 匹配，
    //   加密后编码为 base64 → 匹配失败 → 配置加载异常
    encrypt_strings: false,

    // --- encrypt_numbers: 数字加密 ---
    // ❌ 必须 false
    // 原因: Enum 的整数值（如 ObfuscateLevel.L5 = 5）
    //   被 config.py 的 d.get("level", 3) 比较，
    //   加密后变为 struct.unpack 表达式 → 值不匹配
    encrypt_numbers: false,

    // --- control_flow_flattening: 控制流平坦化 ---
    // ❌ 必须 false
    // 原因: dataclass 的 __init__ 由装饰器自动生成，
    //   平坦化不影响装饰器生成的代码但仍有风险
    control_flow_flattening: false,

    // --- dead_code_injection: 死代码注入 ---
    // ❌ 必须 false
    // 原因: 无函数体可注入，设置无效但保留一致性
    dead_code_injection: false,

    string_split: true,
    obfuscate_imports: true,
    obfuscate_calls: true,
    obfuscate_arithmetic: true,
    obfuscate_booleans: true,
  },

  anti_debug: {
    // --- enabled: 总开关 ---
    // 为什么 false: 类型定义在 build 机器上运行，不需要反调试
    enabled: false,
    action: "warn",
    checks: [],
  },
}
