{
  // ===================================================================
  // 项目扫描模块 — 文件发现
  // ===================================================================
  // 此模块负责：
  //   • scan_project(): 通过 glob 递归匹配项目目录中的 .py 文件
  //   • 返回文件路径列表供后续加密流程使用
  //
  // 逻辑约 40 行，仅涉及文件系统遍历和模式匹配。
  // 不包含加密算法、密钥处理、反调试等敏感逻辑。
  // 安全等级：低 — 即使完全公开也无安全损失。
  //
  // ⚠️ 注意:
  //   此模块的保护目标是维持整体构建工具链的混淆一致性，
  //   而非阻止逆向分析。攻击者即使读懂此模块代码也无法
  //   获得任何实质性攻击面。
  // ===================================================================

  obfuscate: {
    // --- level: 混淆强度 ---
    // 可用值: 0 | 1 | 2 | 3 | 4 | 5
    //         0 = 不混淆
    //         1 = 最低
    //         2 = 低
    //         3 = 中等（适合有一定内部逻辑的模块）
    //         4 = 高
    //         5 = 最高
    // 推荐值: 3
    // 禁止值: 0（完全不混淆会使此模块在构建产物中突出，
    //   间接暴露其他模块的混淆特征）
    // ⚠️ 模块特殊原因: 此模块虽无敏感逻辑，但设为 level 3
    //   可以使其与其他中等保护模块保持一致的混淆外观，
    //   防止攻击者通过"这个模块完全没混淆"来推测其功能不重要。
  level: 5,

    // --- rename_variables: 局部变量重命名 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: scan_project() 中的局部变量
    //   (file_list、excluded、matched 等）重命名后不影响
    //   外部调用。变量名虽无明显安全价值，但混淆无害。
    rename_variables: true,

    // --- rename_functions: 函数重命名 ---
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: 无
    // ⚠️ 模块特殊原因: scan_project() 是模块的唯一公开函数，
    //   被 encrypt.py 等核心模块直接调用：
    //     from project import scan_project
    //     files = scan_project(project_dir)
    //   重命名会导致调用方 ImportError。
    //   如果未来改为通过配置对象或字典分发，可改为 true。
    rename_functions: false,

    // --- rename_classes: 类重命名 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 此模块无自定义类（仅使用标准库
    //   glob、os.path 等）。设为 false 无影响。
    rename_classes: false,

    // --- encrypt_strings: 字符串加密 ---
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 此模块的字符串主要是：
    //   • glob 模式（"**/*.py"）
    //   • 排除目录（"__pycache__", ".git"）
    //   • 错误消息（"Directory not found"）
    //   这些字符串不包含密钥、算法名或任何敏感信息。
    //   加密徒增构建时间而不提升安全性。

    // --- encrypt_numbers: 数字常量加密 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 无敏感数字常量。最多只有
    //   os.path 的常量值，加密无收益。
    encrypt_numbers: false,

    // --- control_flow_flattening: 控制流平坦化 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 文件扫描流程是标准的"遍历 → 过滤 → 返回"
    //   三步线性流程，平坦化后反而使代码更难阅读和维护，
    //   而此模块又不需要高强度保护，得不偿失。

    // --- dead_code_injection: 死代码注入 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 此模块在构建时执行，死代码注入
    //   会增加执行时间（虽然不多）。且此模块的安全价值
    //   不值得增加代码复杂度。

    // --- string_split: 字符串拆分 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 路径模式字符串（如 "**/*.py"）拆分后
    //   不影响 glob 匹配结果，无任何副作用。
    string_split: true,

    // --- obfuscate_imports: 导入混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 导入 glob、os、re 等标准库，
    //   混淆后与其他模块保持一致的构建产物风格。
    obfuscate_imports: true,

    // --- obfuscate_calls: 调用混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: os.walk()、glob.glob() 等标准库调用
    //   混淆后不影响功能。可以开启。
    obfuscate_calls: true,

    // --- obfuscate_arithmetic: 算术表达式混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 路径拼接（os.path.join）中的隐式
    //   字符串操作不受算术混淆影响。可以安全开启。
    obfuscate_arithmetic: true,

    // --- obfuscate_booleans: 布尔表达式混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 排除目录的条件判断（如
    //   if dir_name in EXCLUDED_DIRS: continue）
    //   混淆后不影响功能。
    obfuscate_booleans: true,
  },

  anti_debug: {
    // --- enabled: 反调试开关 ---
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: true
    // ⚠️ 模块特殊原因:
    //   ① 仅在构建时执行，构建环境需要可调试
    //   ② 不包含任何敏感逻辑，反调试无意义
    //   ③ 开启反调试可能导致构建流水线中的
    //      自动化测试框架（如 pytest-xdist）异常
    enabled: false,
  },
}
