{
  // ===================================================================
  // AST 混淆引擎 — Python 抽象语法树变换
  // ===================================================================
  // 此模块是整个保护系统的"大脑"——它包含 Obfuscator 类
  // （继承 ast.NodeTransformer），负责对所有其他模块
  // 执行混淆变换。
  //
  // 包含功能：
  //   • Obfuscator —— 主混淆器，遍历 AST 并应用变换
  //   • _LiteralEncryptor —— 字符串/数字字面量加密
  //   • 不透明谓词生成（Opaque Predicate）
  //   • 死代码注入（Dead Code Injection）
  //   • 控制流平坦化（Control Flow Flattening）
  //   • 导入混淆（Import Obfuscation）
  //   • 函数调用混淆（Call Obfuscation）
  //
  // ⚠️ 最高安全警告 ⚠️
  //   此模块本身是混淆器——它的源码描述了"如何混淆"。
  //   如果攻击者逆向此模块，就能：
  //   1. 理解所有混淆规则和变换模式
  //   2. 编写去混淆器（deobfuscator）还原所有混淆
  //   3. 针对每个变换编写逆变换
  //   4. 一键还原所有受保护模块
  //
  //   因此，此模块的保护等级必须与 crypto.py 同等甚至更高。
  //   混淆器一旦失守，整个保护系统就失去了意义。
  // ===================================================================

  obfuscate: {
    // --- 混淆等级 (1-5) ---
    // 等级说明: L1=仅变量重命名, L2=+字符串加密, L3=+控制流平坦化+不透明谓词,
    //           L4=+数字加密+死代码注入, L5=全部启用
    level: 5,

    // --- 重命名变量 ---
    // true: 局部变量名改为随机十六进制 (如 _0xa1b2)
    // false: 保留原名，降低混淆效果
    rename_variables: true,

    // --- 重命名函数 ---
    // true: 函数名改为随机标识符
    // false: 保留原名（当函数被其他模块按名导入时必须 false）
    rename_functions: true,

    // --- 重命名类 ---
    // true: 类名改为随机标识符
    // false: 保留原名（当类被 isinstance/类型注解引用时必须 false）
    rename_classes: true,

    rename_rules: {
      // --- 命名风格 ---
      // hex=十六进制, chinese=中文, invisible=零宽字符, math-symbols=数学符号, custom=自定义
      style: "hex",
      // --- 保留名称（这些标识符不会被混淆） ---
      reserved: [],
      // --- 混淆名前缀 ---
      prefix: "_0x",
      // --- 混淆名后缀 ---
      suffix: "",
      // --- 混淆名最小长度 ---
      min_length: 6,
      // --- 黑名单（强制不改名的标识符） ---
      blacklist: [],
    },

    // --- 字符串加密 ---
    // true: 字符串常量转为 base64/XOR 编码，运行时解码
    // false: 保持明文（当字符串用于配置匹配/F-字符串模板时必须 false）
    encrypt_strings: true,

    // --- 数字加密 ---
    // true: 数字常量转为 struct.pack 运行时计算
    // false: 保持原值（当数字用于配置默认值/Enum值/模板时必须 false）
    encrypt_numbers: true,

    // --- 字符串最小加密长度 ---
    // 小于此长度的字符串不加密（避免 "a","b" 等单字符也加密）
    string_min_length: 3,

    // --- 字符串加密比例 (0.0 ~ 1.0) ---
    // 1.0 = 全部加密, 0.5 = 50% 随机加密
    string_encrypt_ratio: 1.0,

    // --- 控制流平坦化 ---
    // true: 顺序代码转为 while-switch 状态机
    // false: 保持原控制流（当代码含 yield/async/异常处理时必须 false）
    control_flow_flattening: true,

    // --- 死代码注入 ---
    // true: 注入永远不会执行的代码块（含不透明谓词）
    // false: 不注入（当函数体为空或含 yield 时必须 false）
    dead_code_injection: true,

    // --- 死代码密度 (0.0 ~ 1.0) ---
    // 0.3 = 每10行注入3行死代码, 大于0.8会严重膨胀体积
    dead_code_density: 0.3,

    // --- 不透明谓词数量 ---
    // 每个函数中插入的永远为真的条件判断数
    opaque_predicate_count: 2,

    // --- 删除文档字符串 ---
    remove_docstrings: true,

    // --- 删除注释 ---
    remove_comments: true,

    // --- 删除空行 ---
    strip_blank_lines: true,

    // --- 最大行长 (0=不限制) ---
    max_line_length: 0,

    // --- 字符串分割为碎片 ---
    // true: 将字符串拆为多个碎片 + 拼接
    string_split: true,

    // --- 字符串加密方式 ---
    // base64: 标准 base64 编码, xor: 单字节 XOR, mixed: 随机选择
    string_cipher: "mixed",

    // --- 导入混淆 ---
    // true: import os → os = __import__("os")
    obfuscate_imports: true,

    // --- 函数调用混淆 ---
    // true: func(a) → (lambda _a0: func(_a0))(a)
    obfuscate_calls: true,

    // --- 算术表达式混淆 ---
    // true: a+b → a-(-b), a*2^n → a<<n
    obfuscate_arithmetic: true,

    // --- 布尔值混淆 ---
    // true: True → 1==1, False → 1!=0
    obfuscate_booleans: true,
  },

  anti_debug: {
    // --- 反调试总开关 ---
    // true: 运行时执行反调试检测
    // false: 跳过所有检测（仅构建时/测试模块）
    enabled: true,

    // --- 检测到异常时的动作 ---
    // exit: 立即退出, warn: 打印警告继续, corrupt: 破坏内存后退出
    action: "exit",

    // --- 启用的检测项列表 ---
    // pdb/debugger: Python调试器, ptrace: 系统级跟踪,
    // vm: 虚拟机检测, sandbox: 沙箱检测,
    // timing: 时序检测, cuckoo: Cuckoo沙箱,
    // ida: IDA/Ghidra远程调试, procmon: 进程监控工具,
    // gpu: GPU调试环境
    checks: ["pdb", "debugger", "vm"],

    // --- 逐检测项动作覆盖 ---
    per_check_actions: [],

    // --- 进程白名单 ---
    process_whitelist: [],

    // --- 阻断 sys.settrace/sys.setprofile ---
    block_tracing: true,

    // --- 时序检测阈值（秒） ---
    timing_threshold: 2.0,

    // --- 退出码 ---
    exit_code: 1,

    // --- 退出时清空内存 ---
    wipe_memory: true,

    // --- 退出时破坏内存 ---
    corrupt_on_exit: false,
  },

  virtualization: {
    // =================================================================
    // --- enabled: 虚拟化总开关 ---
    //   可用值: true | false
    //   推荐值: true
    //   原因: 将 Obfuscator 类的核心变换方法（visit_*）
    //     编译为自定义 VM 指令集。即使攻击者能拿到字节码，
    //     也无法直接读懂变换逻辑。这是保护"混淆器"本身
    //     的最后一道防线。
    // =================================================================
    enabled: true,

    // =================================================================
    // --- mode: 虚拟化模式 ---
    //   可用值: "full" | "partial" | "smart"
    //   推荐值: "full"
    //   原因: 和 crypto.py 同理。混淆器的每个方法都必须
    //     被虚拟化，不能有任何"partial"的例外。
    //     如果 visit_FunctionDef 被虚拟化但
    //     visit_Call 没有被虚拟化，攻击者可以通过
    //     未被虚拟化的方法推断混淆模式。
    // =================================================================
    mode: "full",
  },
}
