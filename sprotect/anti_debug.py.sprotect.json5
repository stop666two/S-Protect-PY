{
  // ===================================================================
  // 反调试/反VM/反沙箱模块 — 运行时检测引擎
  // ===================================================================
  // 此模块是第一道防线。loader 启动后最先执行的检查就在此模块。
  // 如果此模块被绕过（例如被 patch 或替换），后续所有保护——
  // 反篡改、解密、水印验证——全部形同虚设。
  //
  // 此模块包含 9 种独立检测实现：
  //   • pdb:      sys.gettrace() != None  检测 Python 调试器
  //   • ptrace:   Linux ptrace(PTRACE_TRACEME) 系统调用检测
  //   • debugger: pydevd/PYTHONDEBUG/chromedebug 环境变量检测
  //   • vm:       VirtualBox/VMware/QEMU/Hyper-V/KVM/Xen 特征检测
  //               （通过 /proc/cpuinfo、dmesg、注册表、进程名）
  //   • sandbox:  沙箱目录特征（C:\sandbox、/tmp/sandbox 等）
  //   • timing:   时序分析——执行固定次数循环，超过阈值=调试器
  //   • cuckoo:   Cuckoo 沙箱特定产物（cuckoo*.dll、分析报告路径）
  //   • ida:      IDA Pro/Ghidra 远程调试端口（23946/TCP 等）
  //   • procmon:  检测 Process Monitor/Process Hacker/Wireshark
  //
  // ===================================================================

  // ===================================================================
  // obfuscate — 混淆设置（AST 级别）
  // ===================================================================
  obfuscate: {
    // --- level: 混淆等级 ---
    // 可用值: 1 | 2 | 3 | 4 | 5
    // 不可用: "5" / 0 / 6 / -1 / 3.5 / null / true
    // 合法示例:
    //   3 — 字符串加密 + 控制流平坦化（标准保护）
    //   4 — 加入数字加密（反调试模块有大量敏感数字常量）
    //   5 — 全部开启（此模块用此值）
    // 注意事项:
    //   • 反调试模块是攻击者首要 patch 目标，混淆等级不足
    //     等价于没有保护
    //   • 此模块不含配置键名，字符串/数字加密不会引起冲突
    // 为什么用 5（此模块）:
    //   反调试模块是所有保护中的第一道门。
    //   如果这个门的锁不够牢固——攻击者轻易拆掉它——
    //   后面的 VM、反篡改、水印全部暴露。
    //   必须最高等级。没有商量余地。
    level: 5,

    // --- rename_variables: 变量重命名 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 注意事项:
    //   • 反调试模块内部有大量检测逻辑的中间结果变量
    //     （如 is_debugger_attached、vm_detected 等）
    //   • 这些变量名本身泄露了检测逻辑——必须改名
    // 为什么用 true（此模块）:
    //   变量名如 is_vm、sandbox_found 等直接告诉攻击者
    //   检测手段。rename_variables=true 后攻击者看到的
    //   是 _0xdeadbe、_0xcafe01 等无意义名称，
    //   无法判断哪个变量对应哪种检测。
    rename_variables: true,

    // --- rename_functions: 函数重命名 ---
    // 可用值: true | false
    // 注意事项:
    //   • 如果函数被外部通过模块属性间接调用，改名后仍可调用
    //   • 但如果函数名在某个地方被硬编码为字符串（如
    //     getattr(module, "check_vm")），改名后找不到
    // 为什么用 true（此模块）:
    //   反调试模块的函数全部通过 check_all() 统一入口调度，
    //   内部函数（_check_pdb、_check_vm 等）不会被外部直接引用。
    //   rename_functions=true 是安全的。
    rename_functions: true,

    // --- rename_classes: 类重命名 ---
    // 可用值: true | false
    // 注意事项:
    //   • 反调试模块通常没有对外暴露的类（都是函数式实现）
    //   • 如果有内部 Helper 类，改名不影响外部
    // 为什么用 true（此模块）:
    //   同 rename_functions——反调试模块的类（如果有）
    //   是纯内部实现，外部无引用。改后无影响。
    rename_classes: true,

    // --- encrypt_strings: 字符串加密 ---
    // 可用值: true | false
    // 注意事项:
    //   • 反调试模块包含大量检测特征字符串
    //     （如 "VBOX"、"VMware"、"python.exe" 等）
    //   • 加密后攻击者无法通过搜索字符串了解检测哪些特征
    // 为什么用 true（此模块）:
    //   反调试模块的字符串是最敏感的数据——它们列出了所有
    //   被检测的 VM 名称、调试器名称、沙箱特征。
    //   如果这些字符串不加密，攻击者用 strings 命令
    //   就能了解完整检测清单，然后逐一绕过。
    encrypt_strings: true,

    // --- encrypt_numbers: 数字加密 ---
    // 可用值: true | false
    // 注意事项:
    //   • 反调试模块有时钟阈值、循环次数、端口号等敏感数字
    //   • 加密后攻击者难以通过数字确定检测参数
    // 为什么用 true（此模块）:
    //   timing 检测的循环次数（如 100000 次）、端口检测的
    //   端口号（23946、9229 等）加密后攻击者无法快速定位
    //   并修改检测参数。
    encrypt_numbers: true,

    // --- control_flow_flattening: 控制流平坦化 ---
    // 可用值: true | false
    // 注意事项:
    //   • 反调试检测大多是无状态的检测函数，适合平坦化
    //   • 平坦化后攻击者无法追踪哪个检测先执行、哪个后执行
    // 为什么用 true（此模块）:
    //   反调试的 9 项检测是独立的——顺序执行，没有复杂依赖。
    //   控制流平坦化可以安全应用，攻击者无法区分
    //   哪个条件分支对应哪项检测。
    control_flow_flattening: true,

    // --- dead_code_injection: 死代码注入 ---
    // 可用值: true | false
    // 注意事项:
    //   • 死代码中可放置虚假的检测逻辑，迷惑攻击者
    //   • 注入太多会增加启动时间（反调试在 loader 启动时运行）
    // 为什么用 true（此模块）:
    //   反调试模块中注入死代码后，攻击者需要花时间
    //   区分哪些是真检测、哪些是假检测。
    //   相比启动时增加的几百毫秒，安全性收益更大。
    dead_code_injection: true,
  },

  // ===================================================================
  // anti_debug — 反调试/反VM/反沙箱（自引用配置）
  // ===================================================================
  anti_debug: {
    // --- enabled: 总开关 ---
    // 可用值: true | false
    // 为什么用 true（此模块）:
    //   反调试模块自身的代码当然要启用反调试保护。
    //   如果攻击者想 patch 此模块的检测函数，必须先过反调试。
    //   这是反调试模块的"自我守卫"——反调试保护反调试。
    enabled: true,

    // --- action: 检测到异常时的动作 ---
    // 可用值: "exit" | "warn" | "corrupt"
    // 合法示例:
    //   "exit" — 立即退出（生产环境标准配置）
    //   "warn" — 仅打印警告（调试用）
    //   "corrupt" — 破坏内存后退出（最激进）
    // 注意事项:
    //   • 反调试模块自身被调试 = 最严重的攻击信号
    //   • 此时必须用最激进的 action——甚至可以考虑 corrupt
    // 为什么用 "exit"（此模块）:
    //   反调试模块被调试意味着检测逻辑正在被逆向。
    //   没有任何理由让程序继续运行——必须立即退出。
    action: "exit",

    // --- checks: 启用的检测项列表 ---
    // 可用值:
    //   "pdb"       Python 调试器检测
    //   "ptrace"    Linux ptrace 检测
    //   "debugger"  IDE 调试器检测
    //   "vm"        虚拟机检测
    //   "sandbox"   沙箱检测
    //   "timing"    时序分析
    //   "cuckoo"    Cuckoo 沙箱检测
    //   "ida"       IDA/Ghidra 端口检测
    //   "procmon"   进程监控工具检测
    // 不可用: "gdb" / "windbg" / "x64dbg"
    // 合法示例:
    //   ["pdb", "vm"] — 最小检测集
    //   ["pdb", "debugger", "vm", "sandbox", "procmon"] — 常见检测集
    //   ["pdb", "ptrace", "debugger", "vm", "sandbox", "timing",
    //    "cuckoo", "ida", "procmon"] — 全部开启（此模块用）
    // 注意事项:
    //   • 全部 9 项开启会带来约 0.5-1 秒的启动延迟
    //   • 某些检测在特定平台可能误报（如 ptrace 在 WSL 中）
    //   • 在 CI/CD 环境中 vm 检测可能误报（CI runner 有时是容器）
    // 为什么用全部 9 项（此模块）:
    //   反调试模块自身不应有任何盲区。
    //   攻击者可能用任何手段分析此模块——从简单的 pdb
    //   到高级的 IDA Pro + GDB 联合调试。
    //   9 项全开确保无论攻击者用什么工具，至少有一项能命中。
    checks: ["pdb", "ptrace", "debugger", "vm", "sandbox", "timing", "cuckoo", "ida", "procmon"],
  },

  // ===================================================================
  // virtualization — 代码虚拟化
  // ===================================================================
  virtualization: {
    // --- enabled: 启用虚拟化 ---
    // 可用值: true | false
    // 注意事项:
    //   • 虚拟化将函数代码替换为自定义字节码 + 解释器
    //   • 性能影响巨大（10-50x）
    // 为什么用 true（此模块）:
    //   反调试检测函数被虚拟化后，攻击者无法用传统调试器
    //   单步跟踪检测逻辑。即使绕过了 AST 混淆层，
    //   还需要逆向虚拟化解释器才能理解检测代码。
    //   这是反调试模块的最终兜底保护。
    enabled: true,

    // --- mode: 虚拟化模式 ---
    // 可用值: "partial"（部分） | "full"（全部）
    // 不可用: "auto" / "smart"
    // 合法示例:
    //   "partial" — 只虚拟化 functions 列表指定的函数，
    //               性能影响可控（推荐生产使用）
    //   "full" — 所有函数全部虚拟化，性能极差
    // 为什么用 "full"（此模块）:
    //   反调试模块代码量不大（~300 行），函数数量也少（~10 个）。
    //   "full" 模式下所有函数虚拟化后，即使攻击者理解了
    //   一个检测函数，其他检测函数的逆向成本仍然不变。
    mode: "full",
  },
}
