{
  // ==========================================
  // CLI 入口模块 — 命令行解析与分发
  // ==========================================
  // main() 被 __main__.py 引用，rename_functions 必须为 false。
  // argparse 内部使用类名做反射，rename_classes 必须为 false。
  // ==========================================

  obfuscate: {
    level: 3,
    rename_variables: true,
    rename_functions: false,
    rename_classes: false,
    rename_rules: { style: "hex", reserved: ["main", "build_parser"] },
    encrypt_strings: true,
    encrypt_numbers: false,
    control_flow_flattening: false,
    dead_code_injection: false,
    string_split: true,
    obfuscate_imports: true,
    obfuscate_calls: true,
    obfuscate_arithmetic: true,
    obfuscate_booleans: true,
  },

  anti_debug: {
    enabled: false,
    action: "warn",
    checks: ["pdb", "debugger"],
  },
}
