{
  // ===================================================================
  // 代码虚拟化引擎 — 将 Python 函数编译为自定义 VM 指令执行
  // ===================================================================
  // 将源码中的指定函数编译为自定义栈式虚拟机 bytecode，
  // 替代原始 Python 字节码执行，使反汇编结果完全不可读。
  //
  // ⚠️ 注意：此模块的混淆配置已使用 L5 全开，
  //    但某些功能（encrypt_strings、dead_code_injection 等）
  //    已在代码中强制关闭以防止破坏 VM 编译器逻辑。
  // ===================================================================

  obfuscate: {
    level: 5,
  },
}
