{
  // ===================================================================
  // 反篡改模块 — 运行时文件完整性校验
  // ===================================================================
  // 此模块在 loader 启动后运行，确保 .pye 加密文件未被篡改。
  // 配合 chain_hash 链式依赖校验，构成双层完整性保护：
  //   第一层（链式依赖）：encrypt 阶段嵌入，校验文件间依赖关系
  //   第二层（反篡改）：运行时主动验证每个文件哈希
  //
  // 此模块包含：
  //   • verify_files():          对每个 .pye 文件做 SHA256 哈希校验
  //   • check_memory():          检测文件 mtime 与加载时间是否一致
  //   • detect_hooks():          检测模块是否被 hook/patch
  //                               （检查 sys.modules 中模块的 __code__）
  //   • detect_dump():           检测内存 dump 工具
  //   • start_periodic_check():  后台线程周期完整性检查
  //
  // 场景解释：为什么反篡改重要？
  //   假设攻击者替换了你的 main.pye 文件，植入自己的代码。
  //   没有反篡改校验 → 替换后的文件也能正常解密执行。
  //   有反篡改校验 → 启动时发现哈希不匹配 → 立即退出。
  // ===================================================================

  // ===================================================================
  // obfuscate — 混淆设置（AST 级别）
  // ===================================================================
  obfuscate: {
    // --- level: 混淆等级 ---
    // 可用值: 1 | 2 | 3 | 4 | 5
    // 不可用: "5" / 0 / 6 / -1 / 3.5
    // 合法示例:
    //   4 — 数字加密 + 死代码注入，但不加密字符串（若有键名）
    //   5 — 全部开启（此模块用此值）
    // 注意事项:
    //   • 反篡改模块不含配置键名，encrypt_strings 安全
    //   • 反篡改是运行时保护的最后一道防线，必须最强保护
    // 为什么用 5（此模块）:
    //   如果攻击者绕过了反调试，下一步就是尝试篡改文件
    //   或 hook 反篡改模块。L5 确保反篡改代码本身难以分析
    //   和修改——攻击者要先搞清楚代码逻辑才能绕过它。
    level: 5,

    // --- rename_variables: 变量重命名 ---
    // 可用值: true | false
    // 注意事项:
    //   • 反篡改内部变量名如 file_hashes、expected_hash
    //     直接泄露了校验逻辑——必须改名
    // 为什么用 true（此模块）:
    //   变量名 file_hash、checksum、is_valid 等直接告诉
    //   攻击者这个函数在做什么。改名后 _0xdeadbe 等
    //   无意义名称不泄露任何语义。
    rename_variables: true,

    // --- rename_functions: 函数重命名 ---
    // 可用值: true | false
    // 注意事项:
    //   • 反篡改函数通过 loader 的统一入口调用，外部无直接 import
    //   • start_periodic_check 可能在 threading.Thread 中被
    //     引用为 target，但那是通过函数对象引用，不是名字
    // 为什么用 true（此模块）:
    //   反篡改模块的所有函数都是内部调用。verify_files() 被
    //   start_periodic_check() 调用，函数名不对外暴露。
    //   改名后所有内部引用通过函数对象（而非字符串名）访问，
    //   不受影响。
    rename_functions: true,

    // --- rename_classes: 类重命名 ---
    // 可用值: true | false
    // 注意事项:
    //   • 如果模块内有 IntegrityChecker 等类，改名安全
    // 为什么用 true（此模块）:
    //   反篡改模块的类（如果有）纯内部使用，无外部引用。
    rename_classes: true,

    // --- encrypt_strings: 字符串加密 ---
    // 可用值: true | false
    // 注意事项:
    //   • 反篡改模块的字符串包括哈希算法名（"sha256"）、
    //     文件路径等——加密后攻击者无法阅读
    // 为什么用 true（此模块）:
    //   字符串 "sha256"、"hexdigest"、错误信息等被加密后，
    //   攻击者无法通过 strings 命令确认使用了什么哈希算法。
    //   也无法阅读错误信息中暴露的文件路径结构。
    encrypt_strings: true,

    // --- encrypt_numbers: 数字加密 ---
    // 可用值: true | false
    // 注意事项:
    //   • 校验间隔（秒）、MAX_FILE_SIZE、缓冲区大小等数字
    //     加密后难以被定位修改
    // 为什么用 true（此模块）:
    //   periodic_check_interval 5.0、hash_block_size 65536
    //   等数字加密后，攻击者无法通过查找这些特定数值
    //   快速定位到控制逻辑。
    encrypt_numbers: true,

    // --- control_flow_flattening: 控制流平坦化 ---
    // 可用值: true | false
    // 注意事项:
    //   • 文件校验逻辑是顺序执行（打开→读取→哈希→比较）
    //   • 平坦化后攻击者无法追踪校验流程
    // 为什么用 true（此模块）:
    //   反篡改的 verify_files() 是典型的顺序流水线操作。
    //   平坦化后每个步骤的转换关系被隐藏，攻击者
    //   无法识别哪个 switch-case 是真正的哈希计算，
    //   哪个是文件读取。
    control_flow_flattening: true,

    // --- dead_code_injection: 死代码注入 ---
    // 可用值: true | false
    // 注意事项:
    //   • 注入虚假的校验逻辑可以迷惑攻击者
    // 为什么用 true（此模块）:
    //   死代码中可包含看起来像哈希校验的虚假逻辑，
    //   攻击者 patch 了"真正的"校验函数后，
    //   却发现还有第二层虚假校验——需要更多时间分析。
    dead_code_injection: true,
  },

  // ===================================================================
  // anti_debug — 反调试/反VM/反沙箱
  // ===================================================================
  anti_debug: {
    // --- enabled: 总开关 ---
    // 可用值: true | false
    // 为什么用 true（此模块）:
    //   反篡改阶段必须防止调试器附加。如果攻击者用调试器
    //   运行被保护的程序，可以：
    //   1. 在 verify_files() 处下断点
    //   2. 观察哈希校验逻辑
    //   3. 修改校验结果（让 false 变 true）
    //   4. 让程序认为自己没被篡改
    //   启用反调试可阻止这种攻击方式。
    enabled: true,

    // --- action: 检测到异常时的动作 ---
    // 可用值: "exit" | "warn" | "corrupt"
    // 为什么用 "exit"（此模块）:
    //   在反篡改阶段被调试 = 最危险的攻击信号。
    //   攻击者正在尝试观察/绕过文件完整性校验。
    //   必须立即退出，不留给攻击者观察校验逻辑的时间。
    action: "exit",

    // --- checks: 启用的检测项列表 ---
    // 可用值: "pdb" / "ptrace" / "debugger" / "vm" / "sandbox" /
    //         "timing" / "cuckoo" / "ida" / "procmon"
    // 合法示例:
    //   ["pdb", "debugger", "vm"] — 仅调试器和 VM（此模块用）
    //   ["pdb", "ptrace", "debugger", "vm", "sandbox"] — 更多项
    // 注意事项:
    //   • 反篡改阶段不需要启用全部 9 项检测
    //   • 主要威胁来自调试器（绕过校验）+ VM（分析行为）
    //   • 沙箱、Cuckoo、IDA 等在此阶段不是主要攻击面
    // 为什么用 ["pdb", "debugger", "vm"]（此模块）:
    //   反篡改执行在校验文件完整性，主要保护目标是被调试器
    //   附加和 VM 分析。pdb 覆盖本地调试器，debugger 覆盖
    //   IDE 调试器，vm 覆盖虚拟化分析环境。
    //   procmon 等检测项在此阶段不是必须的——反篡改模块
    //   运行时间短（几毫秒到几秒），不需要检测进程监控工具。
    checks: ["pdb", "debugger", "vm"],
  },

  // ===================================================================
  // virtualization — 代码虚拟化
  // ===================================================================
  virtualization: {
    // --- enabled: 启用虚拟化 ---
    // 可用值: true | false
    // 为什么用 true（此模块）:
    //   反篡改模块的 verify_files() 是攻击者的首要绕过目标。
    //   虚拟化后，即使攻击者通过某种方式绕过了反调试
    //   和 AST 混淆，还需要逆向虚拟化解释器才能理解
    //   哈希校验逻辑。
    enabled: true,

    // --- mode: 虚拟化模式 ---
    // 可用值: "partial" | "full"
    // 合法示例:
    //   "partial" — 只虚拟化关键函数（verify_files、detect_hooks）
    //   "full" — 所有函数虚拟化（此模块用此值）
    // 注意事项:
    //   • 反篡改模块函数数量少（5 个主函数 + 几个辅助），
    //     全量虚拟化性能影响在可接受范围
    //   • 周期后台线程的虚拟化可能影响定时精度
    //     （虚拟化解释器增加执行延迟）
    // 为什么用 "full"（此模块）:
    //   反篡改模块全量虚拟后，攻击者无法找到"未虚拟化"
    //   的薄弱环节。每一个函数——从 verify_files 到
    //   detect_hooks——都需要逆向解读。
    mode: "full",
  },
}
