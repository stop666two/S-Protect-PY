{
  // ==========================================
  // 反调试/反VM/反沙箱模块 - 12种检测手段（pdb/ptrace/调试器/VM/沙箱/时序/Cuckoo/IDA/进程监控）
  // ==========================================

  obfuscate: {
    level: 5,
    rename_variables: true,
    rename_functions: true,
    rename_classes: true,
    rename_rules: { style: "hex", reserved: [""] },
    encrypt_strings: true,
    encrypt_numbers: true,
    control_flow_flattening: true,
    dead_code_injection: true,
    remove_docstrings: true,
    remove_comments: true,
    strip_blank_lines: true,
  },
  anti_debug: {
    enabled: true,
    action: "exit",
    checks: ["pdb", "ptrace", "debugger", "vm", "sandbox", "timing", "cuckoo", "ida", "procmon"],
    block_tracing: true,
    wipe_memory: true,
    corrupt_on_exit: true,
  },
  virtualization: {
    enabled: true,
    mode: "full",
  },
}
