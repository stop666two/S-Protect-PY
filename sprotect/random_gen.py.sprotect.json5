{
  // ========================================================================
  // 随机名生成器 - 混淆标识符
  // ========================================================================
  // 所属层级: 代码变换层 (Transformation Layer)
  // 文件位置: sprotect/random_gen.py
  //
  // ┌─ 功能概述 ──────────────────────────────────────────────────────────┐
  // │ 为混淆过程提供多样化的标识符命名方案:                                 │
  // │   ① NameGen 类 — 名字生成器工厂                                     │
  // │   ② 5 种命名风格:                                                   │
  // │      - hex:          _0x + 随机十六进制数字 (如 _0x1a3f)           │
  // │      - chinese:      Unicode 中文字符 (如 _用户数据)                │
  // │      - invisible:    零宽字符 (如 _​​)  — 注意此方案可能导致       │
  // │                      编辑器显示异常，慎用                           │
  // │      - math-symbols: Unicode 数学符号 (如 _∑)                       │
  // │      - custom:       用户自定义前缀 + 随机后缀                      │
  // │   ③ 20 种前缀样式:                                                  │
  // │      经典: _0x, _a, _b, _c, ... _z                                  │
  // │      数字: _0, _1, _2, ... _9                                       │
  // │      特殊: __, _A, _B, ... _Z                                       │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 代码特征 ──────────────────────────────────────────────────────────┐
  // │ 行数: ~20 行（极简）                                                │
  // │ 依赖: 仅标准库（random, string）                                     │
  // │ 复杂度: 简单的工厂模式 + 随机数生成                                  │
  // │ 敏感度: 低 — 不包含密钥、算法参数等                                  │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 为什么保护等级较低 ──────────────────────────────────────────────┐
  // │ ① 此模块功能单一: 给定长度 → 返回随机字符串                         │
  // │ ② 即使攻击者完全看懂此模块，他只能知道:                             │
  // │    "哦，_0x1a 是随机生成的"                                         │
  // │    但他仍然不知道哪个变量对应什么功能                                │
  // │ ③ 真正需要保护的是 obfuscate.py（混淆引擎核心逻辑）                 │
  // │ ④ 此模块在设计上就不包含安全敏感信息                                │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ invisible 命名风格的特殊说明 ────────────────────────────────────┐
  // │ 零宽字符包括:                                                       │
  // │   U+200B Zero Width Space                                          │
  // │   U+200C Zero Width Non-Joiner                                     │
  // │   U+200D Zero Width Joiner                                         │
  // │ 优势: 代码看起来完全空白，逆向者难以分辨变量                        │
  // │ 风险:                                                               │
  // │   • 某些编辑器会显示不可见字符为特殊符号（如 VS Code 的点）          │
  // │   • 某些终端/控制台输出会异常                                      │
  // │   • 复制粘贴时可能丢失或改变字符                                   │
  // │   • Python 3.12+ 对 Unicode 标识符有更严格的检查                    │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 变更历史 ──────────────────────────────────────────────────────────┐
  // │ v1.0 初始版本，支持 hex / chinese / math-symbols                    │
  // │ v1.1 添加 invisible 零宽字符命名风格                                │
  // │ v1.2 添加 custom 自定义前缀风格 + 20 种前缀样式                    │
  // └─────────────────────────────────────────────────────────────────────┘
  // ========================================================================

  obfuscate: {
    // ------------------------------------------------------------------
    // 混淆等级: 2
    // ------------------------------------------------------------------
    // 选型理由:
    //   这是整个项目中最不需要保护的模块
    //   它只负责"生成随机字符串"，没有任何业务逻辑
    //
    // 可能的误解:
    //   "random_gen 被 obfuscate.py 调用，保护它防止链式攻击"
    //   → 错。攻击者不需要看懂 random_gen，他可以直接看 obfuscate.py
    //     的混淆结果。保护 random_gen 对提升整体安全性几乎没有帮助。
    //
    // 如果为了保护调用链而提高等级:
    //   → 过度设计。纵深防御应该放在关键路径上。
    // ------------------------------------------------------------------
    level: 2,

    // --- 变量重命名 ---
    // true: 将 chars, prefixes, style 等局部变量重命名
    //       虽然此模块保护价值低，但变量重命名无任何副作用
    //       开启也无妨
    rename_variables: true,

    // --- 函数重命名 ---
    // false: NameGen.generate() 被 obfuscate.py 调用
    //        如果使用 from sprotect.random_gen import NameGen
    //        则 NameGen 类名不可变（取决于 rename_classes 的设置）
    //        但函数名 generate() 被重命名后:
    //          ng = NameGen(style="hex")
    //          name = ng.generate(8)    # generate 被改名为 _0x3a
    //          → AttributeError: 'NameGen' object has no attribute '_0x3a'
    //        所以 rename_functions 必须为 false
    //
    // 注意:
    //   NameGen.generate() 是实例方法，通过 self.generate() 调用
    //   如果重命名，self._0x3a() 可以工作... 前提是 obfuscate.py 也同步修改
    //   但 obfuscate.py 的代码写的是 name_gen.generate(len)
    //   除非 obfuscate.py 也被混淆并正确处理了重命名映射——但这是
    //   两个独立的混淆单元，不会共享重命名映射表
    //   所以: 函数重命名必然导致 AttributeError
    rename_functions: false,

    // --- 类重命名 ---
    // false: 同上，NameGen 类被外部队落引用
    //        类名被重命名后，from ... import NameGen 失败
    rename_classes: false,

    // --- 字符串加密 ---
    // true: 加密以下内容:
    //   • 命名风格名称 ("hex", "chinese", "invisible" 等)
    //   • 前缀字符集
    //   • Unicode 字符范围
    // 没有副作用:
    //   这些字符串只在初始化时使用一次，加密后不影响运行时性能
    //   唯一影响: 代码阅读者无法通过字符串搜索找到命名风格列表
    encrypt_strings: true,

    // --- 数字加密 ---
    // false: 没有敏感数字
    encrypt_numbers: false,

    // --- 控制流平坦化 ---
    // false: 单函数随机生成逻辑，平坦化没有防护效果
    control_flow_flattening: false,

    // --- 死代码注入 ---
    // false: 不需要
    dead_code_injection: false,
  },

  anti_debug: {
    // --- 总开关: false ---
    // 随机名生成器在构建流程中调用，不需要反调试
    enabled: false,
  },
}
