{
  // ===================================================================
  // 备份模块 — 构建前自动备份
  // ===================================================================
  // 此模块负责：
  //   • backup_project(): 在构建前将项目目录打包为 .zip
  //
  // 逻辑极简单（约 20 行），仅调用 zipfile 打包 project_dir。
  // 不包含任何加密/混淆逻辑，不需要强保护。
  // 安全等级：最低 — 纯工具函数，无敏感逻辑。
  //
  // ⚠️ 注意:
  //   此模块的保护优先级低于反篡改、加密、解密等核心模块。
  //   混淆的目的是保持构建工具链的代码风格统一，
  //   而非阻止逆向分析（即使完全公开此模块源码也无安全损失）。
  // ===================================================================

  obfuscate: {
    // --- level: 混淆强度 ---
    // 可用值: 0 | 1 | 2 | 3 | 4 | 5
    //         0 = 不混淆
    //         1 = 最低
    //         2 = 低（适合纯工具类模块）
    //         3 = 中等
    //         4 = 高
    //         5 = 最高
    // 推荐值: 2
    // 禁止值: 0（即使工具模块也保持最低度混淆以统一构建产物风格）
    // ⚠️ 模块特殊原因: 备份模块仅约 20 行逻辑，使用标准库
    //   zipfile。不需要高强度混淆，level 2 足以让此模块在
    //   构建产物中不被一眼识别为"简单的 zip 打包工具"。
    //   更高的级别（4-5）会导致无谓的构建时间增加。
  level: 5,

    // --- rename_variables: 局部变量重命名 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: backup_project() 中的局部变量
    //   （zip_path、backup_name、exclude_dirs 等）虽然
    //   信息价值低，但重命名无成本无副作用，开启即可。
    rename_variables: true,

    // --- rename_functions: 函数重命名 ---
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: 无
    // ⚠️ 模块特殊原因: backup_project() 函数名可能被外部
    //   构建脚本通过名称引用，且此函数仅有一个公开入口。
    //   保持原名有助于构建出错时快速定位问题。
    rename_functions: false,

    // --- rename_classes: 类重命名 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 此模块无自定义类（仅使用内置 zipfile
    //   类）。设为 false 无任何影响。
    rename_classes: false,

    // --- encrypt_strings: 字符串加密 ---
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 此模块字符串主要是：
    //   • 文件路径（project_dir, zip_output）
    //   • 错误消息（"Backup failed: {e}"）
    //   既不包含密钥，也不包含算法标识。加密徒增构建时间。

    // --- encrypt_numbers: 数字常量加密 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 无敏感数字常量。唯一数字可能是
    //   zipfile.ZIP_DEFLATED（枚举值），加密无收益。
    encrypt_numbers: false,

    // --- control_flow_flattening: 控制流平坦化 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 此模块逻辑是：创建 ZipFile → 遍历文件
    //   → 逐个写入 → 关闭。平坦化对如此简单的线性逻辑
    //   几乎无混淆效果，反而增加构建开销。

    // --- dead_code_injection: 死代码注入 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 仅 20 行代码的模块，注入死代码后
    //   代码量可能膨胀 2-3 倍，而安全收益极低。
    //   此模块不值得牺牲可读性来换取微不足道的混淆增益。

    // --- string_split: 字符串拆分 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 字符串拆分不影响逻辑，无副作用。
    //   路径字符串（如 os.path.join(project_dir, "build")）
    //   拆分后略微增加阅读难度，无成本。
    string_split: true,

    // --- obfuscate_imports: 导入混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 导入 zipfile、os、logging 等标准库
    //   没有安全风险，但混淆 import 可以统一构建产物风格。
    obfuscate_imports: true,

    // --- obfuscate_calls: 调用混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 函数调用（如 zipfile.ZipFile()、
    //   os.walk()）混淆后不影响功能，可以开启。
    obfuscate_calls: true,

    // --- obfuscate_arithmetic: 算术表达式混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 即使只有简单的路径拼接
    //   （os.path.join 等），混淆也无负面影响。
    obfuscate_arithmetic: true,

    // --- obfuscate_booleans: 布尔表达式混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 文件排除判断（if name.endswith('.pyc'):）
    //   等简单条件，混淆无害。
    obfuscate_booleans: true,
  },

  anti_debug: {
    // --- enabled: 反调试开关 ---
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: true（工具模块开启反调试 = 干扰开发者正常工作）
    // ⚠️ 模块特殊原因:
    //   ① 备份模块仅在构建时运行，构建环境是开发者机器
    //   ② 开发者可能需要在构建时调试备份逻辑
    //      （如检查备份文件是否包含了正确的内容）
    //   ③ 此模块无任何需要保护的敏感逻辑
    //   结论：反调试完全不需要，且会带来负面效果。
    enabled: false,
  },
}
