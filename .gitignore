# ============================================================================
# S-Protect-PY .gitignore — 排除规则
# ============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
*.spec

# ---- Virtual environments ----
venv/
.venv/
env/
.env/

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- OS ----
Thumbs.db
.DS_Store
Desktop.ini

# ---- Build output ----
output/
project/output/
_runtime/
_backup/
_meta/
_workspace/
_test_temp/
_test_output/

# ---- Generated files ----
*.pye
*.log
*.tmp
*.bak
_ks*/
_ks*.json
_key_store.json
_decoy_meta.json

# ---- Debug / temp ----
_debug_*.py
__debug_*.py
1/
_scratch/

# ---- Config / secrets ----
license_*
*.key
*.pem
*.cert
.env

# ---- Test coverage ----
coverage/
.coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
__pypackages__/

# ---- AI rules - DO NOT COMMIT ----
AGENTS.md
AGENTS.txt
AGENT.md
AGENT.txt
agent-readme.md
RULES.md
AGENTS_*.md
RULES_*.md

# ---- Misc ----
node_modules/
.[!g]*/
!/.github/
output/report.html
output/report.md
