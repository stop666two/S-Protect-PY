{
  // ==========================================
  // 类型定义模块 - 精细化配置
  // 包含所有 Enum、Dataclass 类型定义
  // 注意：类型本身不能被混淆（否则运行时反射会出问题）
  // ==========================================

  obfuscate: {
    level: 2,
    rename_variables: true,
    rename_functions: false,   // Enum/dataclass 方法不改名
    rename_classes: false,     // 类名被广泛引用，不能改名
    rename_rules: {
      style: "hex",
      reserved: [],            // 不保留任何名字（但 rename_classes=false 所以不影响）
    },
    encrypt_strings: false,    // 枚举值字符串不改，影响序列化
    encrypt_numbers: false,    // 枚举数字不改
    control_flow_flattening: false,
    dead_code_injection: false,
  },

  anti_debug: {
    enabled: false,
    action: "warn",
    checks: [],
  },
}
