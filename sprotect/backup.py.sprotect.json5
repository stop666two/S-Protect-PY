{
  // ========================================================================
  // 备份模块 - 构建前自动备份
  // ========================================================================
  // 所属层级: 工具层 (Utility Layer)
  // 文件位置: sprotect/backup.py
  //
  // ┌─ 功能概述 ──────────────────────────────────────────────────────────┐
  // │ 提供构建前的项目源代码自动备份功能:                                   │
  // │   ① backup(project_dir, backup_max_count)                          │
  // │      - 将 project_dir 整个目录打包为 zip                            │
  // │      - 备份文件名格式: backup_YYYYMMDD_HHMMSS.zip                  │
  // │      - 保留最多 backup_max_count 个备份（超出则删除最旧的）          │
  // │   ② 使用标准库 zipfile + os 模块实现                                │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 代码特征 ──────────────────────────────────────────────────────────┐
  // │ 行数: ~20 行（极简）                                                │
  // │ 依赖: 仅标准库（zipfile, os, datetime）                              │
  // │ 复杂度: 线性逻辑，无分支嵌套，无循环（除文件遍历）                      │
  // │ 敏感度: 低 — 不含密码、密钥、算法参数等敏感信息                      │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 为什么不需要强保护 ──────────────────────────────────────────────┐
  // │ ① 这是纯工具函数，被 encrypt.py 在构建流程中调用                    │
  // │ ② 它只读项目文件→打包→写 zip，不参与运行时保护                      │
  // │ ③ 攻击者即使看懂了 backup() 也无法绕过加密保护                      │
  // │ ④ 唯一副作用是消耗磁盘空间，攻击者修改此模块最大损失是备份失败       │
  // │ ⑤ 项目备份也通过 git 管理，备份 zip 只是额外保障                    │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 变更历史 ──────────────────────────────────────────────────────────┐
  // │ v1.0 初始版本，基础 zip 打包功能                                    │
  // │ v1.1 添加 backup_max_count 自动清理                                 │
  // └─────────────────────────────────────────────────────────────────────┘
  // ========================================================================

  obfuscate: {
    // ------------------------------------------------------------------
    // 混淆等级: 2
    // ------------------------------------------------------------------
    // 选型理由:
    //   对于 ~20 行的纯工具函数，level 5 的保护是过度设计
    //   level 2 提供基本的变量重命名，使攻击者不能一眼看出变量用途
    //   例如: project_dir 被重命名为 _0x1a, backup_max_count 被重命名为 _0x2b
    //   这就够了——因为看懂这些变量名也无法获取任何有价值信息
    //
    // 不开到 3 以上的原因:
    //   ① 字符串加密会使 os.path.join 的路径拼接字符串变为乱码
    //      虽然运行时解码后仍正确，但增加调试难度
    //   ② 不必要的混淆会增加构建时间（虽然小模块差异不明显）
    //   ③ 控制流平坦化对单函数线性逻辑没有实际防护效果
    // ------------------------------------------------------------------
    level: 2,

    // --- 变量重命名 ---
    // true: 将局部变量（如 zip_name, backup_dir, counter 等）改为无意义名
    //       让静态分析无法通过变量名推断变量用途
    rename_variables: true,

    // --- 函数重命名 ---
    // false: backup() 被 encrypt.py 通过 from sprotect.backup import backup 导入
    //        虽然 Python 模块导入后通过模块对象的 __dict__ 查找函数
    //        如果 backup 被重命名，import 语句会抛出 ImportError
    // 例外场景:
    //   如果将来改用 import sprotect.backup 然后 sprotect.backup.backup()
    //   则重命名同样会导致失败——因为模块属性名也变了
    rename_functions: false,

    // --- 类重命名 ---
    // false: 此模块没有自定义类，设置 true 没有实际效果
    //        但保持 false 避免未来添加类时忘记改回导致异常
    rename_classes: false,

    // --- 字符串加密 ---
    // false: 备份模块中的字符串主要是:
    //   • 文件路径（os.path.join 的参数字符串）
    //   • zip 文件名模板（f"backup_{timestamp}.zip"）
    //   • 错误信息字符串（如 "Backup failed: {e}"）
    //   加密文件路径字符串后，os.path.join 仍然能正常工作（因为
    //   解码在执行时发生），但代码可读性会降低。没有必要。
    encrypt_strings: false,

    // --- 数字加密 ---
    // false: 没有需要保护的敏感数字
    encrypt_numbers: false,

    // --- 控制流平坦化 ---
    // false: 线性逻辑的函数被平坦化后只是增加了无意义的 switch 分支
    //        实际保护效果为零，反而增加构建后的代码体积
    control_flow_flattening: false,

    // --- 死代码注入 ---
    // false: 不需要也不建议在工具函数中注入死代码
    dead_code_injection: false,
  },

  anti_debug: {
    // --- 总开关: false ---
    // backup() 在构建流程中同步调用，不需要反调试
    enabled: false,
  },
}
