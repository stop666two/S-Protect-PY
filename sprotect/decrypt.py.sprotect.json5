{
  // ====================================================================
  // 解密模块 — .pye 文件解析与测试验证（全量中文注释）
  // ====================================================================
  // 【模块职责】
  //   此模块提供 .pye 加密文件的加密（用于测试）和解密（用于验证）功能：
  //
  //   • encrypt_to_pye() — 将数据加密为 v2 格式 .pye 字节串
  //     （与 encrypt.py 中的 build 流程不同，这是纯数据加密）
  //   • decrypt_from_pye() — 自动检测 v1/v2 格式并正确解密
  //     v2 格式：读取 header 中 extra_layers → decrypt_payload_v2
  //     v1 格式：手动 AES-GCM → XOR → ChaCha20 → zlib 解压
  //   • _find_real_key() — 尝试 5 个密钥分片中匹配三层指纹
  //
  // 【用途定位】
  //   此模块主要用于 **测试和验证**，而非 build 流程的核心部分。
  //   在开发阶段用于验证加密/解密管道是否正确：
  //   • 加密一个测试数据 → 生成 .pye 字节串
  //   • 解密该字节串 → 验证输出是否与输入一致
  //   • 测试 extra_layers 是否正常工作
  //   • 验证三层指纹机制
  //
  // 【与被保护程序的关系】
  // ⚠️ 此模块不会在最终用户的设备上运行！
  //    解密只发生在 build 机器上（开发者环境）。
  //    真正在用户设备上运行的是 loader.py 生成的运行时加载器。
  //    所以此模块的安全等级可以设得较低。
  //
  // 【被调用关系】
  //   测试代码 → 通过 sprotect.decrypt.xxx 导入并调用
  //   开发者  → 命令行/测试脚本中直接调用
  //   build   → 不在 build 流程中使用（仅用于验证）
  //
  // 【函数列表】
  //   encrypt_to_pye(source_data, real_key, extra_layers) → bytes
  //     加密数据为 .pye 格式（v2），含三层指纹密钥伪装
  //
  //   decrypt_from_pye(pye_data: bytes) → bytes
  //     自动检测 v1/v2 格式并解密返回原始数据
  //     v2: 解析 header → decrypt_payload_v2
  //     v1: 手动各层解密 + zlib 解压
  //
  //   _find_real_key(p: dict) → bytes | None
  //     遍历 k1-k5，对每个密钥调用 verify_fingerprint
  //     返回第一个通过三层指纹验证的密钥
  //
  // 【安全等级】
  //   低-中等。此模块仅在开发环境中使用，不在生产环境部署。
  //   但即使如此，适度混淆可以防止内部实现被无意泄露。
  // ====================================================================

  obfuscate: {
    // --- 混淆等级 ---
    // 可用值: 1 | 2 | 3 | 4 | 5
    // 不可用值: "5"（字符串）/ 0 / -1 / 6 / 3.5
    // 各等级含义:
    //   L1: 仅变量名+函数名重命名
    //   L2: + 字符串加密
    //   L3: + 控制流平坦化 + 不透明谓词
    //   L4: + 数字加密
    //   L5: + 死代码注入
    // 注意事项:
    //   • 等级越低，代码可读性越高，调试越方便
    //   • 此模块只用于开发/测试环境，不需要高强度保护
    // 为什么此模块选择 2:
    //   1. 此模块不在最终用户设备上运行
    //      — 只在 build 机器上用于测试和验证
    //   2. 需要保留一定的可读性以便排查加密管道问题
    //   3. 等级 2 提供了基本的变量+函数重命名，
    //      防止内部实现被意外泄露（如错误报告中的 stack trace）
    //   4. 但不需要控制流平坦化/死代码注入等高级特性
    //      — 这些特性会干扰调试
    //   5. 不选 level 1 而选 level 2 的原因是：
    //      level 2 额外提供了字符串加密，可以隐藏
    //      错误消息中的实现细节
    level: 2,

    // --- 重命名变量 ---
    // 可用值: true | false
    // 注意事项:
    //   • 本模块变量名不多（payload, ct, mk, pye_data, source_data）
    //   • 重命名影响不大但可提高 stack trace 阅读难度
    // 为什么此模块选择 true:
    //   基本的变量保护，防止内部变量名泄露。
    rename_variables: true,

    // --- 重命名函数 ---
    // 可用值: true | false
    // ❗ 必须为 false
    // 注意事项:
    //   ⚠️⚠️⚠️ 此模块必须为 false ⚠️⚠️⚠️
    //   原因：
    //   decrypt_from_pye 和 encrypt_to_pye 被测试代码直接调用。
    //   虽然 Python 模块导入后通过函数对象引用不受函数名影响，
    //   但此模块涉及以下几种名称访问模式：
    //
    //   1. 测试代码可能通过名称字符串引用函数
    //      （例如 unittest 的测试发现机制或 pytest fixtures）
    //   2. 开发者在交互式环境中通过 sprotect.decrypt.decrypt_from_pye
    //      访问，函数名混淆后无法通过名称定位
    //   3. 文档/注释中引用的函数名与实际不匹配会带来困惑
    //
    //   更重要的是，此模块不是 build 流程的核心组件，
    //   函数名混淆带来的保护价值远低于它造成的调试困难。
    // 为什么此模块选择 false:
    //   保留函数名以便测试代码和开发者的交互式使用。
    //   此模块的安全不依赖函数名隐藏。
    rename_functions: false,

    // --- 重命名类 ---
    // 可用值: true | false
    // 注意事项: 当前 decrypt.py 没有类定义，此设置无效果
    // 为什么此模块选择 false:
    //   保持统一，且无实际影响。
    rename_classes: false,

    // --- 加密字符串 ---
    // 可用值: true | false
    // 注意事项:
    //   • 本模块字符串主要是错误消息：
    //     "No valid key found in .pye"
    //     "Invalid .pye data: {e}"
    // 为什么此模块选择 false:
    //   此模块只有两条错误消息，没有敏感字符串。
    //   加密这些字符串的价值为零，反而增加调试时的难度
    //   （错误消息在反编译工具中不可读）。
    encrypt_strings: false,

    // --- 加密数字 ---
    // 可用值: true | false
    // 注意事项:
    //   • 本模块数字主要是 5（密钥数量）、12（nonce 长度）、
    //     28（nonce+tag 偏移）、32（密钥长度）
    //   • 这些数字在加密管道中常见，不构成敏感信息
    // 为什么此模块选择 false:
    //   没有敏感数字需要保护，关闭以保持代码可读性。
    encrypt_numbers: false,

    // --- 控制流平坦化 ---
    // 可用值: true | false
    // 注意事项:
    //   • 本模块的 _find_real_key 函数有一个简洁的 for 循环，
    //     平坦化后反而难以阅读和调试
    // 为什么此模块选择 false:
    //   此模块保留可读性用于调试，不进行控制流平坦化。
    control_flow_flattening: false,

    // --- 死代码注入 ---
    // 可用值: true | false
    // 为什么此模块选择 false:
    //   不在开发/测试模块中注入死代码，以免干扰排查。
    dead_code_injection: false,
  },

  // --- 反调试 ---
  // 可用值: { enabled: true } | { enabled: false }
  // 完全禁用反调试。
  // 原因：
  //   1. 此模块只在 build 机器上运行（开发者环境）
  //   2. 开发者需要能够用调试器追踪解密过程以排查问题
  //   3. 不存在"用户设备上被调试"的安全风险
  // 注意事项:
  //   • 即使设为 enabled: false，模块被导入时仍然不会报错
  //   • 如果将来将此模块部署到生产环境，需要重新评估
  // 为什么此模块选择禁用:
  //   开发/测试模块不需要反调试保护。如果攻击者能够访问
  //   开发者的 build 机器，那整个开发环境已经失陷，
  //   反调试也不能挽救什么。
  anti_debug: { enabled: false },
}
