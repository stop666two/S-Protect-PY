{
  // ===================================================================
  // 随机名生成器 — 混淆标识符
  // ===================================================================
  // 此模块负责：
  //   • generate_name(): 生成随机标识符
  //   • 支持 5 种命名风格：hex / chinese / invisible / math-symbols / custom
  //   • 20 种前缀样式可选
  //
  // 此模块为整个混淆流程提供标识符命名服务。
  // 逻辑约 20 行，不包含敏感逻辑。
  // 安全等级：低 — 但此模块的输出（随机名）会影响最终混淆质量。
  //
  // ⚠️ 注意:
  //   • generate_name() 函数被 obfuscate.py 直接调用
  //   → rename_functions 必须 false
  //   • 此模块包含中文对照表（几百个中文字符的列表）
  //   → encrypt_strings 必须 false（中文表加密会严重拖慢构建速度
  //     且解密后的字符映射关系无安全收益）
  // ===================================================================

  obfuscate: {
    // --- level: 混淆强度 ---
    // 可用值: 0 | 1 | 2 | 3 | 4 | 5
    //         0 = 不混淆
    //         1 = 最低
    //         2 = 低（适合纯工具/服务类模块）
    //         3 = 中等
    //         4 = 高
    //         5 = 最高
    // 推荐值: 2
    // 禁止值: 0
    // ⚠️ 模块特殊原因: 此模块是工具服务类模块，被 obfuscate.py
    //   调用。它自身不需要高强度保护（暴露了"这是一个随机名
    //   生成器"也无害），但保持 level 2 的轻度混淆可以维持
    //   构建产物中各模块混淆程度的一致性。
    level: 5,

    // --- rename_variables: 局部变量重命名 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 变量名（如 name_pool、prefix_list、
    //   char_table）暴露了命名池的实现细节。虽然此模块不是
    //   核心安全模块，但变量名本身揭示了命名算法，混淆后
    //   可以增加攻击者理解命名规律的难度。
    rename_variables: true,

    // --- rename_functions: 函数重命名 ---
    // ❌ 必须 false
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: true
    // ⚠️ 模块特殊原因:
    //   generate_name(style: str, length: int) -> str 是此模块
    //   的唯一公开 API，被 obfuscate.py 直接引用：
    //     from random_gen import generate_name
    //     new_name = generate_name("hex", 16)
    //   重命名后 obfuscate.py 无法调用此函数。
    //   obfuscate.py 是整个混淆流程的调度核心，改名会导致
    //   整个构建链断裂。
    rename_functions: false,

    // --- rename_classes: 类重命名 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 此模块仅包含函数，无自定义类。
    rename_classes: false,

    // --- rename_rules: 重命名规则 ---
    // 可用值: { style: string, reserved: string[], prefix: string, suffix: string, min_length: number, blacklist: string[] }
    //   - style: 命名风格 — "hex" | "random" | "chinese" | "invisible"
    //   - reserved: 保留名称列表（不会被重命名的标识符）
    //   - prefix: 重命名后标识符的前缀，如 "_"
    //   - suffix: 重命名后标识符的后缀，如 "_"
    //   - min_length: 重命名后标识符的最小长度
    //   - blacklist: 禁止使用的标识符列表
    // 推荐值: { style: "hex", reserved: ["NameGen", "gen"], prefix: "", suffix: "", min_length: 6, blacklist: [] }
    // ⚠️ 模块特殊原因: NameGen 类和 gen 函数虽未在模块外直接
    //   使用（generate_name 是唯一入口），但保留它们便于
    //   未来扩展和调试。rename_functions/classes=false 时此字段
    //   虽不生效，但保留以确保配置完整性。
    rename_rules: {
      style: "hex",
      reserved: ["NameGen", "gen"],
      prefix: "",
      suffix: "",
      min_length: 6,
      blacklist: [],
    },

    // --- encrypt_strings: 字符串加密 ---
    // 可用值: true | false
    // ❌ 必须 false
    // 推荐值: false
    // 禁止值: true
    // ⚠️ 模块特殊原因: 此模块包含中文对照表（几百个中文字符），
    //   加密这组字符串会：
    //   ① 在构建时对 500+ 个中文字符逐一加密 → 构建时间显著增加
    //   ② 解密后的字符映射关系完全暴露在内存中 → 无安全收益
    //   ③ chinese 命名风格本身就不依赖字符串的隐蔽性
    //   即使 encrypt_strings=false，hex 和 math-symbols 等短字符表
    //   也不会显著暴露模块功能，因为模块用途（随机名生成器）
    //   在类/函数名已关闭重命名的情况下本身就一目了然。
    encrypt_strings: false,

    // --- encrypt_numbers: 数字常量加密 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 唯一的数字是默认长度（如 8、16、32），
    //   这些数字没有保护价值。
    encrypt_numbers: false,

    // --- string_min_length: 字符串最小加密长度 ---
    // 可用值: number（>= 0，小于此长度的字符串不加密）
    // 推荐值: 0
    // ⚠️ 模块特殊原因: encrypt_strings=false，此字段无效。
    string_min_length: 0,

    // --- string_encrypt_ratio: 字符串加密比例 ---
    // 可用值: 0.0 ~ 1.0（0.0=不加密任何字符串，1.0=加密所有字符串）
    // 推荐值: 0.0
    // ⚠️ 模块特殊原因: encrypt_strings=false，此字段无效。
    string_encrypt_ratio: 0.0,

    // --- string_cipher: 字符串加密算法 ---
    // 可用值: "base64" | "xor" | "aes"
    // 推荐值: "base64"
    // ⚠️ 模块特殊原因: encrypt_strings=false，此字段无效。
    string_cipher: "base64",

    // --- control_flow_flattening: 控制流平坦化 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: generate_name() 的核心是 random.choice()
    //   循环，控制流简单直接。平坦化对于这种"选择 → 拼接 →
    //   返回"的模式几乎没有混淆效果，只会增加构建时间。
    control_flow_flattening: false,

    // --- dead_code_injection: 死代码注入 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 此模块函数体极小（约 5-10 行有效代码），
    //   注入死代码会导致代码膨胀比例过高（200%+），
    //   而安全收益极低，性价比差。
    dead_code_injection: false,

    // --- dead_code_density: 死代码密度 ---
    // 可用值: 0.0 ~ 1.0（0.0=不注入，1.0=最大密度）
    // 推荐值: 0.0
    // ⚠️ 模块特殊原因: dead_code_injection=false，此字段无效。
    dead_code_density: 0.0,

    // --- opaque_predicate_count: 不透明谓词数量 ---
    // 可用值: number（>= 0）
    // 推荐值: 0
    // ⚠️ 模块特殊原因: 此模块控制流极简单，无需谓词混淆。
    opaque_predicate_count: 0,

    // --- remove_docstrings: 移除文档字符串 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 保留 docstring 有助于模块维护。
    remove_docstrings: false,

    // --- remove_comments: 移除注释 ---
    // 可用值: true | false
    // 推荐值: true
    // ⚠️ 模块特殊原因: 注释在构建产物中无意义，移除可减小体积。
    remove_comments: true,

    // --- strip_blank_lines: 移除空行 ---
    // 可用值: true | false
    // 推荐值: true
    // ⚠️ 模块特殊原因: 移除空行可减小构建产物体积。
    strip_blank_lines: true,

    // --- max_line_length: 最大行长度 ---
    // 可用值: number（0 = 不限制）
    // 推荐值: 0
    // ⚠️ 模块特殊原因: 此模块简单，无需控制行长度。
    max_line_length: 0,

    // --- string_split: 字符串拆分 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 字符表字符串拆分后不影响 random.choice()
    //   的索引访问。即使 encrypt_strings=false，额外拆分可以
    //   进一步增加字符串分析的难度。
    string_split: true,

    // --- obfuscate_imports: 导入混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 导入 random、string 等标准库，
    //   混淆后维持构建产物风格统一。
    obfuscate_imports: true,

    // --- obfuscate_calls: 调用混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: random.choice() 和 random.randint() 等
    //   调用混淆后不影响命名生成结果。
    obfuscate_calls: true,

    // --- obfuscate_arithmetic: 算术表达式混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 命名长度计算、索引计算等简单算术
    //   混淆后不影响执行结果。
    obfuscate_arithmetic: true,

    // --- obfuscate_booleans: 布尔表达式混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 风格选择（if style == "hex": ...）等
    //   条件判断混淆后不影响功能。
    obfuscate_booleans: true,
  },

  anti_debug: {
    // --- enabled: 反调试开关 ---
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: true
    // ⚠️ 模块特殊原因:
    //   ① 此模块仅在构建时的混淆阶段执行
    //   ② 不涉及运行时安全，无防逆向需求
    //   ③ 开发者可能需要调试命名生成逻辑
    //      （如排查某一命名风格是否正确输出）
    enabled: false,

    // --- action: 反调试触发时的全局行为 ---
    // 可用值: "warn" | "exit" | "crash" | "corrupt"
    // 推荐值: "warn"
    // ⚠️ 模块特殊原因: enabled=false，此字段不生效。
    action: "warn",

    // --- checks: 启用的反调试检查列表 ---
    // 可用值: string[]，支持: "pdb", "debugger", "ptrace",
    //   "process_name", "remote_debug", "container", "vm"
    // 推荐值: []
    // ⚠️ 模块特殊原因: 构建模块不需要任何反调试检查。
    checks: [],

    // --- per_check_actions: 每个检查的独立触发动作 ---
    // 可用值: string[]，与 checks 数组一一对应
    //   每个元素可为: "warn" | "exit" | "crash" | "corrupt"
    // 推荐值: []
    // ⚠️ 模块特殊原因: checks 为空，此字段无效。
    per_check_actions: [],

    // --- process_whitelist: 允许调试的进程白名单 ---
    // 可用值: string[]（进程名列表）
    // 推荐值: []
    // ⚠️ 模块特殊原因: enabled=false，无需白名单。
    process_whitelist: [],

    // --- block_tracing: 阻止系统级跟踪 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: enabled=false，无需阻止跟踪。
    block_tracing: false,

    // --- timing_threshold: 反调试超时阈值（秒） ---
    // 可用值: number（0 = 禁用定时检查）
    // 推荐值: 0
    // ⚠️ 模块特殊原因: enabled=false，无需定时检查。
    timing_threshold: 0,

    // --- exit_code: 反调试触发时的进程退出码 ---
    // 可用值: number（通常为 1 或负数）
    // 推荐值: 1
    // ⚠️ 模块特殊原因: enabled=false，此字段不生效。
    exit_code: 1,

    // --- wipe_memory: 退出时擦除敏感内存 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 此模块无敏感内存数据。
    wipe_memory: false,

    // --- corrupt_on_exit: 退出时损坏关键数据 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 此模块无关键数据可损坏。
    corrupt_on_exit: false,
  },
}
