{
  // ==========================================
  // 水印模块 — 三层溯源追踪
  // ==========================================
  // 水印用于追踪泄露来源（哪次 build、哪个 batch）。
  // Watermark.code() 需在源码末尾精确注入代码，
  // control_flow_flattening 可能改变代码结构导致注入位置偏移。
  // ==========================================

  obfuscate: {
    level: 3,
    rename_variables: true,
    rename_functions: true,
    rename_classes: true,
    encrypt_strings: true,
    encrypt_numbers: false,
    control_flow_flattening: false,
    dead_code_injection: false,
    string_split: true,
    obfuscate_imports: true,
    obfuscate_calls: true,
    obfuscate_arithmetic: true,
    obfuscate_booleans: true,
  },

  anti_debug: { enabled: false },
}
