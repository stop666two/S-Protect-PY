{
  // ==========================================
  // 反调试/反VM/反沙箱模块 — 运行时检测引擎
  // ==========================================
  // 此模块包含 9 种检测手段：
  //   • pdb:      sys.gettrace() != None 检测
  //   • ptrace:   Linux ptrace 系统调用检测
  //   • debugger: pydevd/PYTHONDEBUG/chromedebug 检测
  //   • vm:       VirtualBox/VMware/QEMU/Hyper-V/KVM/Xen 检测
  //   • sandbox:  沙箱目录特征检测
  //   • timing:   时序分析（超过阈值 = 调试器附加）
  //   • cuckoo:   Cuckoo 沙箱特定产物检测
  //   • ida:      IDA Pro/Ghidra 远程调试端口检测
  //   • procmon:  Process Monitor/Process Hacker/Wireshark 检测
  //
  // 此模块是运行时保护的第一道防线。
  // 启动器加载后最先执行的就是反调试检查。
  // 如果此模块被绕过，后续所有保护都形同虚设。
  // ==========================================

  obfuscate: {
    // --- level: 混淆等级 ---
    // 可用值: 1 | 2 | 3 | 4 | 5
    // 不可用: "5"（字符串） / 0 / 6 / -1 / 3.5
    // 为什么用 5: 反调试模块是运行时保护的第一道防线，
    //   必须最高强度保护。任何针对此模块的逆向成功
    //   都意味着整个保护系统可以被调试绕过。
    level: 5,

    // --- rename_variables: 变量重命名 ---
    // 可用值: true | false
    // true = 所有局部变量名改为 _0x 风格随机名
    // false = 保持原始变量名
    // 注意事项: 变量名混淆后 stack trace 更难追踪
    rename_variables: true,

    // --- rename_functions: 函数重命名 ---
    // 可用值: true | false
    // 注意事项: 此模块的函数被 loader 和 runtime 调用，
    //   但 Python 通过模块对象引用函数，改名不影响调用
    rename_functions: true,

    // --- rename_classes: 类重命名 ---
    rename_classes: true,

    // --- encrypt_strings: 字符串加密 ---
    // 可用值: true | false
    // 注意事项: 检测项名称（如 "pdb", "vm"）以字符串形式出现，
    //   加密后这些字符串在反编译工具中不可读
    encrypt_strings: true,

    // --- encrypt_numbers: 数字加密 ---
    // 可用值: true | false
    // 注意事项: 退出码、时序阈值等数字常量被加密后
    //   攻击者无法通过数字特征定位敏感代码
    encrypt_numbers: true,

    // --- control_flow_flattening: 控制流平坦化 ---
    // 可用值: true | false
    // 注意事项: 将函数体转为 while-switch 形式，
    //   破坏控制流图，让 IDA/Ghidra 的反编译结果混乱
    control_flow_flattening: true,

    // --- dead_code_injection: 死代码注入 ---
    // 可用值: true | false
    // 注意事项: 插入与真实检测代码结构相同的假检测，
    //   攻击者难以区分哪些是真检测、哪些是假检测。
    //   相比启动时增加的几百毫秒，安全性收益更大。
    dead_code_injection: true,

    // --- string_split: 字符串分割 ---
    string_split: true,

    // --- obfuscate_imports: import 混淆 ---
    obfuscate_imports: true,

    // --- obfuscate_calls: 调用混淆 ---
    obfuscate_calls: true,

    // --- obfuscate_arithmetic: 算术混淆 ---
    obfuscate_arithmetic: true,

    // --- obfuscate_booleans: 布尔值混淆 ---
    obfuscate_booleans: true,
  },

  // --- anti_debug: 反调试/反VM/反沙箱（自引用配置）---
  anti_debug: {
    // --- enabled: 总开关 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 注意事项: 此模块自身的反调试必须开启，
    //   防止攻击者在调试此模块时触发自身检测逻辑
    enabled: true,

    // --- action: 检测到异常后的动作 ---
    // 可用值: "exit" | "warn" | "corrupt"
    //    exit    = 立即退出并清空内存（最安全）
    //    warn    = 打印警告后继续运行（调试用）
    //    corrupt = 破坏内存数据后退出（最激进）
    // 不可用: "pause" / "crash" / 空字符串
    action: "exit",

    // --- checks: 启用的检测项列表 ---
    // 可用值: "pdb" | "ptrace" | "debugger" | "vm" | "sandbox"
    //        | "timing" | "cuckoo" | "ida" | "procmon"
    // 不可用: 不存在的检测项名称
    // 注意事项: 建议全部开启，每一项都有其特定防御场景。
    //   如果某些检测在特定环境下误报，可通过 per_check_actions
    //   单独覆盖其行为而非直接移除。
    checks: [
      "pdb", "ptrace", "debugger", "vm",
      "sandbox", "timing", "cuckoo", "ida", "procmon",
    ],

    // --- per_check_actions: 逐检测项覆盖动作 ---
    // 可用值: [{check:"vm", action:"warn"}] | []
    // 不可用: check 值不在 checks 列表中
    // 注意事项: 优先级高于全局 action，
    //   例: VM 中只警告不退出，其他检测直接退出
    per_check_actions: [],

    // --- process_whitelist: 进程白名单 ---
    // 可用值: ["python.exe", "myapp.exe"] | []
    // 注意事项: 白名单中的进程名不会被检测为调试器
    process_whitelist: [],

    // --- block_tracing: 阻断跟踪 ---
    // 可用值: true | false
    // 注意事项: 启动时清空 sys.settrace 和 sys.setprofile
    block_tracing: true,

    // --- timing_threshold: 时序检测阈值（秒）---
    // 可用值: 0.5 ~ 10.0
    // 推荐值: 2.0（普通机器）| 5.0（VM 环境）
    // 不可用: 0 / 负数 / > 60
    // 注意事项: VM 中因 CPU 降频可能导致误判，
    //   在 VM 环境建议设为 3-5 秒
    timing_threshold: 2.0,

    // --- exit_code: 退出码 ---
    // 可用值: 1 ~ 255
    // 不可用: 0（表示正常退出）/ 负数 / > 255
    exit_code: 1,

    // --- wipe_memory: 退出时清空内存 ---
    // 可用值: true | false
    // 注意事项: 通过 gc 模块清空敏感数据，防止 crash dump 泄露
    wipe_memory: true,

    // --- corrupt_on_exit: 退出时破坏内存 ---
    // 可用值: true | false
    // 注意事项: 比 wipe 更激进，会随机修改内存中的对象值。
    //   和 action: "corrupt" 配合使用效果翻倍。
    corrupt_on_exit: false,
  },

  // --- virtualization: 代码虚拟化（预留）---
  virtualization: {
    enabled: true,
    mode: "full",
  },
}
