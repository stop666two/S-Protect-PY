{
  // ===================================================================
  // AST 混淆引擎 — Python 抽象语法树变换
  // ===================================================================
  // 此模块包含：
  //   • collect_defs()         第一遍收集（跨文件命名映射）
  //   • Obfuscator 类          核心（ast.NodeTransformer）
  //   • _LiteralEncryptor     字符串/数字加密子类
  //   • _opaque_predicate     不透明谓词生成器
  //   • _inject_dead_code       死代码注入器
  //   • _split_string         字符串分割混淆
  //
  // 此模块本身就是混淆器——它的源码一旦被逆向，
  // 攻击者就能理解全部混淆规则和策略。
  // 必须使用最高等级保护，这是整个项目中的王牌模块。
  //
  // 注意：此模块不含任何字符串模板/配置键名，
  //       所以 encrypt_strings 可以安全全开。
  // ===================================================================

  // ===================================================================
  // obfuscate — 混淆设置（AST 级别）
  // ===================================================================
  obfuscate: {
    // --- level: 混淆等级 ---
    // 可用值: 1 | 2 | 3 | 4 | 5          （必须为整数，非字符串）
    // 不可用: "5"（字符串类型） / 0 / 6 / -1 / 3.5 / null / true
    // 合法示例:
    //   1 — 仅变量/函数重命名（最轻量、性能无损）
    //   3 — 官方默认值，含字符串加密 + 控制流平坦化
    //   5 — 终极混淆，全开所有技术（此模块用此值）
    // 注意事项:
    //   • 各级别为累加关系：L3 = L2 + 控制流平坦化 + 不透明谓词
    //   • L4 起包含数字加密，L5 全开但性能下降约 30-50%
    //   • 混淆等级不加密模块间调用关系，那是 encrypt 层的职责
    // 为什么用 5（此模块）:
    //   混淆引擎是攻击者的首要目标。一旦混淆规则暴露，
    //   攻击者可逆向出所有混淆后代码的原始逻辑。
    //   此模块必须用最高等级，不可妥协。
    level: 5,

    // --- rename_variables: 变量重命名开关 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0 / "yes" / "no"
    // 注意事项:
    //   • 设为 false 时所有变量保持原名，混淆效果大打折扣
    //   • 推荐始终为 true，除非调试需要
    // 为什么用 true（此模块）:
    //   混淆引擎内部有大量临时变量（如 transformer 状态变量），
    //   不改名 = 攻击者直接阅读有意义的变量名推理算法逻辑。
    rename_variables: true,

    // --- rename_functions: 函数重命名开关 ---
    // 可用值: true | false
    // 不可用: 同上
    // 注意事项:
    //   • 若此模块的函数被外部 import/调用，设为 false
    //   • 混淆引擎内部函数名（以 _ 开头的私有函数）不会被外部引用
    // 为什么用 true（此模块）:
    //   obfuscate.py 的 collect_defs()、Obfuscator.visit() 等
    //   虽然被 loader/encrypt 间接使用，但通过模块属性访问，
    //   函数名不直接在调用侧以字符串形式出现，改名后仍可访问。
    rename_functions: true,

    // --- rename_classes: 类重命名开关 ---
    // 可用值: true | false
    // 不可用: 同上
    // 注意事项:
    //   • 若类名被 isinstance()、类装饰器、元类引用，改后报错
    //   • 单例类、dataclass、Enum 子类建议不改名
    // 为什么用 true（此模块）:
    //   Obfuscator、_LiteralEncryptor 等类仅在此模块内部使用，
    //   对外接口通过函数调用暴露，类名改后不影响外部调用。
    rename_classes: true,

    // --- rename_rules: 重命名规则 ---
    rename_rules: {
      // --- style: 命名风格 ---
      // 可用值:
      //   "hex"           十六进制风格（默认），如 _0xa1b2c3
      //   "chinese"       中文字符，如 _变量名
      //   "invisible"     零宽字符（肉眼不可见，但编辑器可能显示异常）
      //   "math-symbols"  数学符号，如 _∑∫∂
      //   "custom"        自定义，需搭配 prefix/suffix 使用
      // 不可用: "unicode" / "base64" / "random"（未实现的风格）
      // 合法示例:
      //   "hex" — _0xff0033, _0xdeadbe, _0xcafe01
      //   "chinese" — _变量, _混淆, _计数
      //   "invisible" — 看起来 _xxxx 但中间有零宽字符
      // 注意事项:
      //   • invisible 风格在源码粘贴到网页/终端时可能失效
      //   • chinese 风格会增加字节数（UTF-8 中文占 3 字节）
      //   • hex 风格兼容性最好，推荐使用
      // 为什么用 "hex"（此模块）:
      //   混淆引擎自身代码经过混淆后，如果风格太另类
      //   （如 invisible），可能在 error traceback 中乱码，
      //   影响开发调试。hex 风格稳定、可读、标准。
      style: "hex",

      // --- reserved: 保留名称列表 ---
      // 可用值: ["__init__", "main", "visit_Node", ...] / []（空）
      // 不可用: 非字符串元素 / 含空格的标识符 / Python 关键字
      // 合法示例:
      //   [] — 全改（此模块用空数组）
      //   ["__init__", "main"] — 只保留入口和构造器
      //   ["load_config", "merge_file_config"] — 被外部引用的函数
      // 注意事项:
      //   • reserved 中的标识符不会被混淆，保留原名
      //   • 被外部 import 引用的函数名必须加入 reserved
      //   • 入口函数（如 main()、__init__()）建议保留
      //   • 过多保留 = 等于没有混淆
      // 为什么用 []（此模块）:
      //   此模块的所有函数/变量/类都是内部使用，
      //   没有需要保留名称的外部接口。
      //   即使 collect_defs() 被外部调用，也通过模块属性访问，
      //   改名后调用者仍然能通过 obfuscate.collect_defs 找到。
      reserved: [],
    },

    // --- encrypt_strings: 字符串加密开关 ---
    // 可用值: true | false
    // 不可用: 1 / 0 / "on" / "off"
    // 注意事项:
    //   • true = 所有字符串字面量被编码为 base64 + 运行时解码
    //   • 如果模块包含配置键名匹配逻辑，加密后可能键不匹配
    //   • 字符串加密后的性能开销：首次解码有开销，后续无影响
    //   • 日志/报错信息中的字符串被加密后，报错难以阅读
    // 为什么用 true（此模块）:
    //   此模块不含任何配置键名匹配逻辑。
    //   所有字符串要么是 AST 节点类型名（如 "Call"、"Name"），
    //   要么是报错信息。加密后攻击者无法直接阅读混淆规则字符串。
    encrypt_strings: true,

    // --- encrypt_numbers: 数字加密开关 ---
    // 可用值: true | false
    // 不可用: 同上
    // 注意事项:
    //   • true = 所有数字常量被替换为运行时计算表达式
    //   • 例如 42 → (lambda: (lambda: 7 * 6)())()
    //   • 性能影响大（每次运行都需要计算），热路径慎用
    //   • 对循环次数变量加密可能导致性能灾难
    // 为什么用 true（此模块）:
    //   混淆引擎中有大量魔法数字（如 AST 深度限制 1000，
    //   不透明谓词参数 7/11/13 等），加密后攻击者难以
    //   通过搜索数字常量快速定位关键逻辑。
    encrypt_numbers: true,

    // --- control_flow_flattening: 控制流平坦化开关 ---
    // 可用值: true | false
    // 不可用: 同上
    // 注意事项:
    //   • true = 将结构化代码转换为 switch-case + while 循环
    //   • 平坦化后代码逻辑极难阅读（但运行时等价）
    //   • 可能触发 Python 的 500 行深度嵌套限制
    //   • 在异常处理复杂的代码中可能引入 bug
    // 为什么用 true（此模块）:
    //   混淆引擎的 visit() 方法树递归逻辑复杂，
    //   平坦化后攻击者无法追踪 AST 节点的处理流程。
    //   即使攻击者打开了混淆引擎源码也看不懂执行顺序。
    control_flow_flattening: true,

    // --- dead_code_injection: 死代码注入开关 ---
    // 可用值: true | false
    // 不可用: 同上
    // 注意事项:
    //   • true = 注入永不执行的代码（含不透明谓词守卫）
    //   • 增加代码体积约 30-50%（取决于 density 配置）
    //   • 死代码可能被动态分析发现（如果攻击者使用覆盖工具）
    //   • 在内存受限的环境中需谨慎
    // 为什么用 true（此模块）:
    //   混淆引擎的每个方法中注入死代码后，
    //   攻击者无法判断哪些是真正的混淆逻辑，
    //   哪些是迷惑用的虚假代码，分析成本翻倍。
    dead_code_injection: true,
  },

  // ===================================================================
  // anti_debug — 反调试/反VM/反沙箱
  // ===================================================================
  anti_debug: {
    // --- enabled: 总开关 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 注意事项:
    //   • false = 跳过所有反调试检查
    //   • 在 build 机器上应设为 false，避免反调试干扰构建
    // 为什么用 true（此模块）:
    //   混淆引擎的代码是核心机密，一旦被调试器附加，
    //   攻击者可以单步跟踪所有混淆变换过程。
    //   必须在被调试时立即退出。
    enabled: true,

    // --- action: 检测到异常时的动作 ---
    // 可用值:
    //   "exit"      立即退出进程（推荐生产环境使用）
    //   "warn"      打印警告到 stderr 并继续运行（仅调试用）
    //   "corrupt"   破坏内存中数据后退出（最激进）
    // 不可用: "crash" / "halt" / "sleep" / "delete" / 任意未定义值
    // 合法示例:
    //   "exit" — sys.exit(exit_code)
    //   "warn" — print("Debugger detected!") 后继续
    //   "corrupt" — 遍历 gc 对象，随机修改部分对象值后退出
    // 注意事项:
    //   • "corrupt" 可能导致操作系统蓝屏/崩溃转储
    //   • 开发阶段应使用 "warn" 以避免影响开发流程
    //   • 生产环境始终使用 "exit"
    // 为什么用 "exit"（此模块）:
    //   混淆引擎不容许任何被调试的可能。
    //   即使警告后继续运行，也可能已暴露混淆状态。
    //   必须立即退出，不给攻击者任何机会。
    action: "exit",

    // --- checks: 启用的检测项列表 ---
    // 可用值:
    //   "pdb"          通过 sys.gettrace() != None 检测
    //   "ptrace"       Linux ptrace 系统调用检测
    //   "debugger"     pydevd/PYTHONDEBUG/chromedebug 检测
    //   "vm"           VirtualBox/VMware/QEMU/Hyper-V/KVM/Xen 检测
    //   "sandbox"      沙箱目录特征检测
    //   "timing"       时序分析（执行阈值循环检测）
    //   "cuckoo"       Cuckoo 沙箱特定产物检测
    //   "ida"          IDA Pro/Ghidra 远程调试端口检测
    //   "procmon"      Process Monitor/Process Hacker/Wireshark 检测
    // 不可用: "gdb" / "ollydbg" / "x64dbg"（未实现）
    // 合法示例:
    //   ["pdb", "vm"] — 仅检测调试器和虚拟机（快速启动）
    //   ["pdb", "ptrace", "debugger", "vm", "sandbox", "timing"] — 半开
    //   ["pdb", "debugger", "vm", "sandbox"] — 去掉了 Linux 专用项
    // 注意事项:
    //   • 检测项越多，启动越慢（约 0.1-0.5 秒/项）
    //   • "timing" 在 VM 中可能误报（CPU 降频导致循环变慢）
    //   • "ptrace" 仅 Linux 生效，Windows 中静默跳过
    //   • "procmon" 在开发机上可能误报（开发者常开这些工具）
    // 为什么用 ["pdb", "debugger", "vm"]（此模块）:
    //   混淆引擎运行在 build 机器上，build 机器通常不是 VM，
    //   也极少运行 Cuckoo 沙箱或 IDA Pro。
    //   主要威胁是调试器附加（分析混淆过程）和 VM 分析。
    //   此三项覆盖了 95% 的攻击场景。
    checks: ["pdb", "debugger", "vm"],
  },

  // ===================================================================
  // virtualization — 代码虚拟化（预留功能）
  // ===================================================================
  // 注意：当前版本此功能预留，实际未完整实现。
  //       开启后性能下降 10x-50x，仅建议对极度敏感函数使用。
  // ===================================================================
  virtualization: {
    // --- enabled: 启用虚拟化 ---
    // 可用值: true | false
    // 不可用: 同上
    // 注意事项:
    //   • true 时函数代码被替换为自定义字节码 + 解释器
    //   • 对性能影响极大（10-50 倍），热路径切勿开启
    // 为什么用 true（此模块）:
    //   混淆引擎的代码应被模拟执行，而非直接在 Python VM 上运行。
    //   即使攻击者攻破了 AST 混淆层，还有虚拟化保护兜底。
    enabled: true,

    // --- mode: 虚拟化模式 ---
    // 可用值:
    //   "partial"  部分虚拟化（仅虚拟化 functions 列表中指定的函数）
    //   "full"     全局虚拟化（全部函数——性能极差，不推荐）
    // 不可用: "auto" / "smart" / "selective"
    // 注意事项:
    //   • "full" 模式会使所有函数调用变慢 10-50 倍
    //   • 建议始终使用 "partial" 并指定最小化函数集
    // 为什么用 "full"（此模块）:
    //   此模块只有 ~500 行核心逻辑，函数数量少。
    //   "full" 虚拟化全部函数后，攻击者必须逆向虚拟化解释器
    //   才能理解任何混淆逻辑。
    mode: "full",
  },
}
