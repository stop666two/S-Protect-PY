{
  // ===================================================================
  // 诱饵代码生成模块 — 迷惑逆向分析
  // ===================================================================
  // 此模块负责：
  //   • generate_decoy_module(): 生成看起来像真实 Python 模块的假代码
  //   • 内置大量模板字符串（docstring、函数签名、类定义、import 语句等）
  //
  // 诱饵文件与真实文件的加密流程完全一致，攻击者无法区分。
  // 安全等级：中等 — 但字符串加密必须关闭。
  //
  // ⚠️ 约束：
  //   • 包含大量 Python 代码模板字符串
  //   • encrypt_strings=true → 模板被编码 → 诱饵代码含乱码 → 失去迷惑作用
  //   • rename_variables/functions/classes 虽然开启，但诱饵函数名本身
  //     就被设计为无意义，重命名不冲突。
  // ===================================================================

  obfuscate: {
    // --- level: 混淆强度 ---
    // 可用值: 0 | 1 | 2 | 3 | 4 | 5
    //         0 = 不混淆
    //         1 = 最低
    //         2 = 低
    //         3 = 中等
    //         4 = 高
    //         5 = 最高
    // 推荐值: 3
    // 禁止值: 0, 1（诱饵模块虽非核心安全模块，但仍需一定混淆
    //   以防止攻击者通过混淆程度差异区分诱饵和真实模块）
    // ⚠️ 模块特殊原因: 诱饵模块的混淆强度应与真实模块接近。
    //   若诱饵完全不混淆，攻击者会发现"有几个模块没混淆"，
    //   从而直接定位到这些是诱饵。level 3 与大多数真实模块的
    //   level 2-5 混在一起难以区分。
    level: 3,

    // --- rename_variables: 局部变量重命名 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 诱饵模块中的变量名（如 fake_data、
    //   dummy_result）暴露了"这些是假数据"，必须重命名。
    //   变量重命名不影响模板字符串的内容，安全。
    rename_variables: true,

    // --- rename_functions: 函数重命名 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 诱饵模块的公开函数（如 generate_fake_key、
    //   simulate_decrypt）虽然没有外部引用，但函数名本身
    //   揭示了此模块的"欺骗"性质，必须重命名。
    rename_functions: true,

    // --- rename_classes: 类重命名 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 诱饵模块中的类名（如 DecoyCipher、
    //   FakeValidator）直接暴露虚假身份，必须重命名。
    rename_classes: true,

    // --- encrypt_strings: 字符串加密 ---
    // ❌ 必须 false
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: true
    // ⚠️ 模块特殊原因:
    //   此模块的核心是"生成看起来像真实代码的诱饵代码"。
    //   实现方式是在 Python 代码中包含大量模板字符串：
    //
    //   template = '''
    //   def validate_license(key):
    //       """验证许可证密钥"""
    //       return check_sum(key) == MAGIC
    //   '''
    //
    //   如果 encrypt_strings=true，混淆器会在编译时将模板字符串
    //   编码为加密形式，运行时才解密。但问题是：
    //   ① 诱饵生成函数在构建时执行，它输出的诱饵代码字符串
    //      会先被 decrypt 再被 c 写入文件 → 诱饵代码中充满乱码
    //   ② 攻击者看到乱码的"假代码"会立刻意识到这是诱饵或垃圾文件
    //   ③ 正确的诱饵应该看起来是完全合法的 Python 代码
    //
    //   所以: encrypt_strings 必须 false，确保模板字符串以
    //   明文形式编译，生成的诱饵代码是干净合法的 Python 代码。
    encrypt_strings: false,

    // --- encrypt_numbers: 数字常量加密 ---
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 诱饵模块中的数字（如假密钥长度 32、
    //   假版本号 2、假魔数 0x12345678）不需要保护。
    //   真相反倒是"这些数字看起来越真实越好"。
    encrypt_numbers: false,

    // --- control_flow_flattening: 控制流平坦化 ---
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 诱饵模块逻辑简单（字符串拼接 + 条件选择），
    //   平坦化后生成的诱饵代码质量不会受影响。
    //   但考虑到性能（构建诱饵时执行），保持 false。
    control_flow_flattening: false,

    // --- dead_code_injection: 死代码注入 ---
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 死代码注入会影响诱饵生成执行的性能，
    //   并且诱饵模块本身的逻辑复杂度很低，注入死代码收益有限。
    dead_code_injection: false,

    // --- string_split: 字符串拆分 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 即使 encrypt_strings=false，字符串拆分
    //   仍然可以工作（将模板拆为多段再拼接），不影响最终
    //   诱饵代码的内容，且增加模块内部代码的阅读难度。
    string_split: true,

    // --- obfuscate_imports: 导入混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 诱饵模块可能导入 random、string、time
    //   等标准库。混淆 import 可以防止攻击者通过 import 语句
    //   快速判断模块功能。
    obfuscate_imports: true,

    // --- obfuscate_calls: 调用混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 诱饵模块内部函数之间的调用关系
    //   （如 generate_fake_key → random.choice）应该被混淆，
    //   让逆向者更难梳理调用逻辑。
    obfuscate_calls: true,

    // --- obfuscate_arithmetic: 算术表达式混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 诱饵模块中有大量"看起来像在计算"的
    //   假运算（如 xor = a ^ b ^ c），混淆后使这些假运算
    //   看起来更像真实加密逻辑。
    obfuscate_arithmetic: true,

    // --- obfuscate_booleans: 布尔表达式混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 禁止值: 无
    // ⚠️ 模块特殊原因: 诱饵模块中的条件判断（如 if key_len > 16:）
    //   混淆后可以增加"这段代码确实做了重要判断"的错觉。
    obfuscate_booleans: true,
  },

  anti_debug: {
    // --- enabled: 反调试开关 ---
    // 可用值: true | false
    // 推荐值: false
    // 禁止值: true
    // ⚠️ 模块特殊原因: 诱饵模块仅用于生成诱饵文件，在构建时
    //   执行，构建环境是开发者的机器。开发者可能需要在构建时
    //   调试诱饵生成逻辑（查看生成的诱饵代码内容是否正确）。
    //   开启反调试会导致开发者无法调试构建流程。
    //   此模块不部署到最终用户环境。
    enabled: false,
  },
}
