{
  project: { name: "myapp", version: "1.0.0", entry: "main.py", description: "", author: "" },

  files: { include: ["**/*.py"], exclude: [], exclude_dirs: ["_runtime","_backup","__pycache__",".git","_decoy","_scratch","1","node_modules","venv",".venv","env",".env","dist","build","output","project/output","_meta","_ks*"] },

  obfuscate: {
    level: 5,                          // 混淆等级 (1-5)
    rename_variables: true, rename_functions: true, rename_classes: true,
    rename_rules: { style: "hex", reserved: ["__init__", "main", "validate_chain", "cross_verify", "hash_file", "sha256_file", "sha256_data", "b64encode", "b64decode", "xor_data", "interleave", "deinterleave", "is_prime", "fibonacci", "factorial", "gcd", "lcm", "power_mod", "digit_sum", "reverse_number", "collatz_steps", "rot13", "leet_speak", "reverse_str", "is_palindrome", "count_vowels", "caesar_shift", "atbash", "run_all", "print_summary", "check_integrity", "CHAIN_REGISTRY", "FILE_REGISTRY", "CHAIN_MAP", "SEED_POOL", "_run"], prefix: "_0x", suffix: "", min_length: 12, blacklist: [] },
    encrypt_strings: true, encrypt_numbers: true, string_min_length: 1, string_encrypt_ratio: 1.0,
    control_flow_flattening: true,     // 控制流平坦化（if/elif 状态机）
    dead_code_injection: true,          // 死代码注入 + 隐式数据流
    dead_code_density: 0.5, opaque_predicate_count: 5,
    remove_docstrings: true, remove_comments: true, strip_blank_lines: true, max_line_length: 0,
    string_split: true,                // 字符串分散（切碎散落运行时重组）
    string_cipher: "mixed",
    obfuscate_imports: true, obfuscate_calls: true, obfuscate_arithmetic: true,
    obfuscate_booleans: true,
    opaque_expr: true,                 // 不透明表达式注入（a+b → (a^b)+2*(a&b)）
    match_dispatch: true,              // match/case 调度（50% 概率替代 if/elif）
  },

  encrypt: {
    algorithm: "aes-256-gcm", key_source: "auto", key_file: null, key_env_var: null,
    interdependency: "chain", backup: true, backup_max_count: 10, replace_originals: false,
    shard_count: 10, shard_min_files: 5, compress_level: 9,
    polymorphic_padding: true, polymorphic_padding_max: 2048, aad_context: "S-Protect-PY",
    extra_layers: ["serpent", "twofish", "camellia", "salsa20"],
    hybrid: { enabled: true, algorithm: "ECC", key_size: 521, key_file: "key.pem" },
    workers: 0,
    key_server: "",               // 远程密钥服务器 URL（HTTPS 直连，留空禁用）
  },

  anti_debug: {
    enabled: true, action: "exit",
    checks: ["pdb","ptrace","debugger","vm","sandbox","timing","cuckoo","ida","procmon","gpu"],
    per_check_actions: [], process_whitelist: [], block_tracing: true,
    timing_threshold: 1.0, exit_code: 1, wipe_memory: true, corrupt_on_exit: true,
  },

  virtualization: { enabled: true, mode: "full", functions: [], glob_patterns: [], exclude_functions: [], inline_threshold: 10, interpreter_obfuscate: true },

  watermark: { enabled: true, levels: ["file","code","runtime"], batch_id: "", multi_batch: [], visible: false, watermark_key: "" },

  expiration: { enabled: true, expires_at: null, grace_period_hours: 0, ntp_check: true, ntp_servers: ["pool.ntp.org","time.google.com","time.cloudflare.com","time.windows.com","time.apple.com"], ntp_timeout: 1.0, on_network_fail: "reject", check_interval_hours: 1, max_drift_seconds: 60 },

  environment: { enabled: true, bind_directory: null, bind_username: null, bind_env_vars: [], bind_file_hash: null, bind_mac_address: null, bind_hardware_id: null, strict_mode: true, fingerprint_algorithm: "sha256" },

  sandbox: { enabled: true, detect_cuckoo: true, detect_sandboxie: true, detect_docker: true, detect_ci: true },

  bootloader: { name: "main.py", include_runtime_loader: true, minimal_boot: false, hide_python_windows: true, anti_dump: true, periodic_check_interval: 1.0 },

  pack: { enabled: false, onefile: true, console: true, icon: null, extra_args: [] },

  keyvault: { enabled: true, pool_size: 2048, xor_mask_hex: "A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5A5", pid_binding: true, pid_salt: "0xDEADBEEF" },

  // ===================================================================
  // 极致压缩器 — 多算法堆叠压缩
  // 对加密后的载荷进行 Token替换→LZMA→BZ2→Zlib(9)→Base85 多轮堆叠压缩
  // 典型 Python 项目额外缩减 15%-40%
  // 独立模块: sprotect/compressor.py + compressor.json5
  // ===================================================================
  compressor: {
    enabled: true,                    // 总开关
    pass_count: 3,                    // 堆叠轮数（1-5）
    use_lzma: true,                   // 使用 LZMA
    use_bz2: true,                    // 使用 BZ2
    use_zlib: true,                   // 使用 Zlib(9)
    use_base85: true,                 // 使用 Base85 编码
    token_replace: true,              // Token 替换
    shorten_identifiers: true,        // 标识符缩短
    dictionary_size: 4096,            // Token 字典大小
  },

  // ===================================================================
  // 双进程架构（实验性功能）
  // ⚠️ 警告：此功能为实验版本，在生产环境中使用前请充分测试。
  //
  // 【原理】
  //   启用后，程序会 fork 为两个进程：
  //   - 父进程：持有全部解密密钥，通过 IPC 通道与子进程通信
  //   - 子进程：执行业务代码，不持有任何密钥
  //   攻击者即使 dump 子进程内存，也无法拿到密钥。
  //
  // 【好处】
  //   ✓ 密钥全程在父进程内存中，子进程被 dump 也拿不到密钥
  //   ✓ 调试器附着子进程只能看到已解密的数据，无法回溯密钥
  //   ✓ 父进程可监控子进程状态，检测到异常立即销毁密钥
  //
  // 【坏处/取舍】
  //   ✗ 启动时间增加约 0.5-2 秒（IPC 建立 + 子进程初始化）
  //   ✗ 内存占用翻倍（父进程+子进程各一份）
  //   ✗ os._exit() 等操作仅影响子进程，父进程需额外处理
  //   ✗ 某些受限环境（容器、云函数）不允许 spawn 子进程
  //   ✗ 单 .exe 打包后，子进程启动自身可能因路径问题失败
  //   ✗ 调试复杂度增加（需要同时跟踪两个进程）
  //
  // 【开关说明】
  //   true  = 启用双进程模式，sprotect run 自动传递 --dual 参数
  //           main.py 内会包含完整的双进程代码
  //   false = 完全禁用，编译时剔除双进程相关代码
  //           main.py 仅保留传统单进程模式
  //
  // 【推荐场景】
  //   对抗国家级 APT、防止内存 dump 提取密钥时开启。
  //   普通桌面应用或 CLI 工具建议保持 false。
  // ===================================================================
  dual_process: {
    enabled: false,                    // 总开关（实验性，默认关闭）
    child_timeout: 30,                 // 子进程超时秒数
  },

  // ===================================================================
  // 运行时保护配置
  // ===================================================================
  runtime: {
    layer_count: 6,                          // 加密层数
    min_decoy_modules: 10,                   // 最小诱饵模块数
    hex_pool_size: 15,                       // HMAC盐值交织池大小
    time_wall_minutes: 60,                   // 执行时间墙（分钟后自动退出）
    ttl_seconds: 60,                         // 内存解密TTL（秒后回收）
    integrity_check_interval: 30,            // 完整性自检间隔（秒）
    decoy_watch_interval: 45,                // 文件系统饵雷校验间隔（秒）
    memory_check_enabled: true,              // 运行时内存校验和
    time_anomaly_check: true,                // 时间戳反演检测
    stack_obfuscation: true,                 // 调用栈混淆
    file_decoy_enabled: true,                // 文件系统饵雷
    heap_scramble: false,                    // 堆内存搅乱（性能影响大）
  },

  output: { dir: "./output", keep_source_map: false, runtime_dir_name: "_runtime", preserve_non_py: true, verbose: false, clean_before_build: false, backup_before_build: true },
}
