{
  // ==========================================
  // 启动器生成模块 - 精细化配置
  // 生成 output/main.py + _runtime/loader.py
  // 模板字符串不能加密（包含生成的代码）
  // ==========================================
  obfuscate: { level: 4, rename_variables: true, rename_functions: true,
    rename_classes: true, encrypt_strings: false, encrypt_numbers: false,
    control_flow_flattening: false, dead_code_injection: false },
  anti_debug: { enabled: true, action: "exit",
    checks: ["pdb", "debugger", "vm", "sandbox", "cuckoo", "ida"] },
}
