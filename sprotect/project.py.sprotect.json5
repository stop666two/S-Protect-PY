{
  // ========================================================================
  // 项目扫描模块 - 文件发现
  // ========================================================================
  // 所属层级: 工具层 (Utility Layer)
  // 文件位置: sprotect/project.py
  //
  // ┌─ 功能概述 ──────────────────────────────────────────────────────────┐
  // │ 负责发现和保护目标项目中的 Python 文件:                               │
  // │   ① find_py_files(project_dir: str, exclude_dirs: list) → list     │
  // │      使用 glob.glob() 递归扫描 project_dir 下的所有 .py 文件        │
  // │      排除目录: __pycache__, .git, node_modules, venv, .venv, dist,  │
  // │               build, *.egg-info                                    │
  // │      返回: 绝对路径列表                                             │
  // │                                                                     │
  // │ 调用方: encrypt.py → encrypt_project()                             │
  // │ 调用时机: 构建流程开始第一个步骤                                     │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 代码特征 ──────────────────────────────────────────────────────────┐
  // │ 行数: ~40 行                                                        │
  // │ 依赖: 仅标准库（glob, os）                                           │
  // │ 复杂度: 线性逻辑，一个 for 循环 + 路径拼接                          │
  // │ 敏感度: 极低 — 纯文件系统操作                                       │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 设计说明 ──────────────────────────────────────────────────────────┐
  // │ 为什么不使用 pathlib？                                               │
  // │ pathlib 是 Python 3.4+ 的面向对象路径操作库                          │
  // │ 选择 os.path + glob 的原因是:                                       │
  // │   • 项目早期版本兼容 Python 3.6+                                    │
  // │   • 团队更熟悉 os.path 接口                                         │
  // │   • glob.glob('**/*.py', recursive=True) 一行解决递归匹配           │
  // │                                                                     │
  // │ 排除目录列表的设计:                                                  │
  // │   硬编码在函数内而不是作为配置文件参数:                               │
  // │   • 这些是几乎所有 Python 项目的通用排除项                           │
  // │   • 减少外部配置依赖，方便独立使用                                  │
  // │   • 如果用户需要自定义排除，可以通过 encrypt.py 的参数传递           │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 变更历史 ──────────────────────────────────────────────────────────┐
  // │ v1.0 初始版本，基础 glob 扫描                                       │
  // │ v1.1 添加 exclude_dirs 参数过滤                                     │
  // │ v1.2 添加 dist / build 等构建产物排除                               │
  // └─────────────────────────────────────────────────────────────────────┘
  // ========================================================================

  obfuscate: {
    // ------------------------------------------------------------------
    // 混淆等级: 3
    // ------------------------------------------------------------------
    // 选型理由:
    //   level 2 不够，因为我们需要保护排除目录列表
    //   攻击者可能修改排除目录来包含 __pycache__ 等目录中的文件
    //   虽然攻击价值不高（__pycache__ 中的 .pyc 文件通常不需要保护）
    //   但保护排除列表是好的安全习惯
    //
    //   为什么不开到 3 以上:
    //   find_py_files 只有~20 行有效代码，强混淆没有意义
    //   攻击者完全可以重写这个函数（核心安全在 loader，不在此处）
    // ------------------------------------------------------------------
    level: 3,

    // --- 变量重命名 ---
    // true: 将 py_files, file_path, dir_path, exclude_list 等变量重命名
    rename_variables: true,

    // --- 函数重命名 ---
    // ❗ 必须为 false
    // 原因:
    //   encrypt.py 中:
    //     from sprotect.project import find_py_files
    //     files = find_py_files(project_dir, exclude_dirs)
    //   find_py_files 被重命名后:
    //     from sprotect.project import find_py_files  # ImportError
    //   → 模块导入直接失败
    //
    // 替代方案:
    //   如果希望重命名函数名，对应的 import 需要改为:
    //     import sprotect.project as project_mod
    //     # 需要知道 find_py_files 被重命名成了什么...
    //     # 但这是不可能的，因为重命名是随机的
    //   → 所以 rename_functions 必须 false
    rename_functions: false,

    // --- 类重命名 ---
    // false: 此模块没有自定义类
    rename_classes: false,

    // --- 字符串加密 ---
    // false: 此模块中的字符串主要是:
    //   • 排除目录名: "__pycache__", ".git", "node_modules"...
    //   • glob 模式: "**/*.py"
    //   • 错误信息
    //   排除目录名被加密后攻击者看不到排除列表，有点用
    //   但排除列表是公开知识，任何 Python 项目都知道要排除这些目录
    //   为了便于维护和调试，不加密
    encrypt_strings: false,

    // --- 数字加密 ---
    // false: 没有数字常量
    encrypt_numbers: false,

    // --- 控制流平坦化 ---
    // false: 单循环 + 路径判断，平坦化无实际防护效果
    control_flow_flattening: false,

    // --- 死代码注入 ---
    // false: 不需要
    dead_code_injection: false,
  },

  anti_debug: {
    // --- 总开关: false ---
    // 项目扫描在构建流程中运行，不需要反调试
    enabled: false,
  },
}
