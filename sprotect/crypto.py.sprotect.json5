{
  // ==========================================
  // 密码学引擎 - AES-256-GCM加密、密钥分片、环形HMAC链校验。核心安全模块
  // ==========================================

  obfuscate: {
    level: 5,
    rename_variables: true,
    rename_functions: true,
    rename_classes: true,
    rename_rules: { style: "hex", reserved: [""] },
    encrypt_strings: true,
    encrypt_numbers: true,
    control_flow_flattening: true,
    dead_code_injection: true,
    remove_docstrings: true,
    remove_comments: true,
    strip_blank_lines: true,
  },
  anti_debug: {
    enabled: true,
    action: "exit",
    checks: ["pdb", "debugger", "vm", "sandbox"],
  },
  virtualization: {
    enabled: true,
    mode: "full",
  },
}
