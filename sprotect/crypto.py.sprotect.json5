    //   "corrupt" = 閫氳繃 gc 閬嶅巻瀵硅薄闅忔満淇敼鍐呭瓨鍚庨€€鍑猴紙鏈€婵€杩涳級
    // 涓嶅彲鐢ㄥ€? "abort" / "crash" / "ignore" / 绌哄瓧绗︿覆
    // 娉ㄦ剰浜嬮」:
    //   鈥?"exit" 閫傚悎姝ｅ紡鍙戝竷鐗堟湰锛岀畝鍗曠洿鎺?    //   鈥?"warn" 鍙湪寮€鍙戣皟璇曟椂浣跨敤锛屾寮忕増鏈笉寰楃敤
    //   鈥?"corrupt" 浼氬湪**閫€鍑哄墠**闅忔満淇敼鍐呭瓨涓殑瀵硅薄鍊硷紝
    //     瀵艰嚧 crash dump 涓殑鏁忔劅鏁版嵁琚牬鍧?    //   鈥?corrupt 鍙兘寮曡捣璇姤锛堜慨鏀逛簡涓嶅簲璇ユ敼鐨勫璞★級
    // 涓轰粈涔堟妯″潡閫夋嫨 "exit":
    //   瀵嗙爜瀛︽ā鍧楁槸淇濇姢閾炬牳蹇冿紝妫€娴嬪埌璋冭瘯鍣ㄥ簲绔嬪嵆缁堟绋嬪簭锛?    //   涓嶇粰鏀诲嚮鑰呬换浣曞垎鏋愬唴瀛樼殑鏈轰細銆備笉闇€瑕佹縺杩涚牬鍧忥紙corrupt锛夛紝
    //   鍥犱负姝ｅ父閫€鍑哄凡缁忚冻澶熶繚闅滃畨鍏ㄢ€斺€斿瘑閽ヤ笉浼氭寔涔呭寲鍦ㄥ唴瀛樹腑銆?    action: "exit",

    // --- 鍚敤鐨勬娴嬮」 ---
    // 瀹屾暣鍙敤鍊?
    //   "pdb"       - 妫€娴?sys.gettrace() != None锛堟爣鍑嗚皟璇曞櫒锛?    //   "ptrace"    - 妫€娴?ptrace 闄勫姞锛圠inux 璋冭瘯鍣ㄥ gdb锛?    //   "debugger"  - 妫€娴?pydevd / PYTHONDEBUG 绛夛紙PyCharm/VS Code锛?    //   "vm"        - 妫€娴?VirtualBox / VMware / QEMU / Hyper-V / Xen
    //   "sandbox"   - 妫€娴嬫矙绠辩洰褰曠壒寰侊紙濡?C:\sandbox锛?    //   "timing"    - 鏃跺簭妫€娴嬶細寰幆鎵ц鑰楁椂瓒呰繃 threshold 鍒ゅ畾涓鸿皟璇?    //   "cuckoo"    - 妫€娴?Cuckoo 娌欑鐗瑰畾杩涚▼/鏂囦欢
    //   "ida"       - 妫€娴?IDA Pro / Ghidra 杩滅▼璋冭瘯绔彛
    //   "procmon"   - 妫€娴?Process Monitor / Process Hacker
    // 涓嶅彲鐢ㄥ€? "gdb" / "windbg" / "ollydbg"锛堥渶閫氳繃 ptrace+debugger 瑕嗙洊锛?    // 娉ㄦ剰浜嬮」:
    //   鈥?涓嶆槸瓒婂瓒婂ソ鈥斺€旀瘡椤规娴嬮兘鏈夎繍琛屾椂寮€閿€
    //   鈥?鏍稿績妯″潡寤鸿鍖呭惈 vm/sandbox锛屽洜涓?VM 涓?CPU 鎸囦护宸紓
    //     鍙兘瀵艰嚧瀵嗙爜瀛︽搷浣滅殑鏃跺簭鐗瑰緛琚垎鏋?    //   鈥?ida 妫€娴嬩富瑕侀拡瀵硅繙绋嬭皟璇曞満鏅紙IDAPython/Ghidra 鎻掍欢锛?    // 涓轰粈涔堟妯″潡閫夋嫨杩欎簺鍊?
    //   鈥?pdb: 鏍囧噯 Python 璋冭瘯鍣ㄦ娴嬶紝鏈€鍩虹鐨勯槻绾?    //   鈥?debugger: 妫€娴?PyCharm 绛?IDE 璋冭瘯鍣?    //   鈥?vm: 瀵嗙爜瀛﹀紩鎿庡湪 VM 涓繍琛屾椂锛岀‖浠?RNG 鍙兘鐔典笉瓒?    //   鈥?sandbox: 妫€娴嬪姩鎬佸垎鏋愭矙绠辩幆澧?    //   鈥?ida: 妫€娴?IDA/Ghidra 璋冭瘯浼氳瘽锛堥€嗗悜甯哥敤宸ュ叿锛?    //   鏈€夋嫨:
    //   鈥?ptrace: 姝ゆā鍧楃煭鏆傝繍琛屽悗鍗抽€€鍑猴紝ptrace 妫€娴嬫垚鏈珮
    //   鈥?timing: 瀵嗙爜瀛﹀嚱鏁版湰韬€楁椂娉㈠姩澶э紝瀹规槗璇垽
    //   鈥?cuckoo: Cuckoo 娌欑妫€娴嬫垚鏈珮锛屾妯″潡闈炴寔涔呰繍琛?    //   鈥?procmon: 姝ゆā鍧椾笉娑夊強闀挎椂闂寸殑杩涚▼鐩戞帶
    checks: ["pdb", "debugger", "vm", "sandbox", "ida"],
  },

  virtualization: {
    // --- 鍚敤浠ｇ爜铏氭嫙鍖?---
