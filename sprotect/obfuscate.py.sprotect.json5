{
  // ===================================================================
  // AST 混淆引擎 — Python 抽象语法树变换
  // ===================================================================
  // 此模块是整个保护系统的"大脑"——它包含 Obfuscator 类
  // （继承 ast.NodeTransformer），负责对所有其他模块
  // 执行混淆变换。
  //
  // 包含功能：
  //   • Obfuscator —— 主混淆器，遍历 AST 并应用变换
  //   • _LiteralEncryptor —— 字符串/数字字面量加密
  //   • 不透明谓词生成（Opaque Predicate）
  //   • 死代码注入（Dead Code Injection）
  //   • 控制流平坦化（Control Flow Flattening）
  //   • 导入混淆（Import Obfuscation）
  //   • 函数调用混淆（Call Obfuscation）
  //
  // ⚠️ 最高安全警告 ⚠️
  //   此模块本身是混淆器——它的源码描述了"如何混淆"。
  //   如果攻击者逆向此模块，就能：
  //   1. 理解所有混淆规则和变换模式
  //   2. 编写去混淆器（deobfuscator）还原所有混淆
  //   3. 针对每个变换编写逆变换
  //   4. 一键还原所有受保护模块
  //
  //   因此，此模块的保护等级必须与 crypto.py 同等甚至更高。
  //   混淆器一旦失守，整个保护系统就失去了意义。
  // ===================================================================

  obfuscate: {
    // =================================================================
    // --- level: 混淆等级 ---
    //   数据类型: number（整数）
    //   可用值: 1 | 2 | 3 | 4 | 5
    //   ⚠️ 不可用值: 0, -1, 1.5, "5", null
    //   推荐值: 5
    //   ❌ 禁止值: 1 | 2 | 3 | 4（任何低于 5 的等级都不可接受）
    //   原因:
    //     此模块是整个系统的"密钥生成器"——混淆器本身。
    //     等级 4 以下的混淆量不足以保护 Obfuscator 类的
    //     visit_FunctionDef、visit_Call 等方法签名和变换逻辑。
    //     攻击者如果看到 `visit_Call` 方法，就能猜到
    //     "这里在混淆函数调用"，然后据此编写去混淆规则。
    //
    //     等级 5 + 所有子选项开启 + 全虚拟化 = 混淆器自身的
    //     变换逻辑在最终产物中几乎不可识别。Obfuscator 类
    //     的 visit_* 方法会被重命名为 hex 编码，函数体被
    //     控制流平坦化打乱，字符串被加密，关键逻辑被虚拟化。
    //
    //     任何一个被遗漏的方法都可能成为攻击者的突破口。
    // =================================================================
    level: 5,

    rename_variables: true,
    rename_functions: true,
    rename_classes: true,

    // =================================================================
    // --- rename_rules: 重命名规则配置 ---
    //   数据类型: object
    //   子字段:
    //     • style: string — 命名风格
    //       可用值: "hex" | "random" | "numbered" | "gibberish"
    //       ⚠️ 不可用值: "readable", "prefix", "none"
    //       推荐值: "hex"
    //       ❌ 禁止值: "numbered"（攻击者可据此还原原始命名顺序）
    //       原因: "hex" 生成类似 _0x3f8a2b 的十六进制名，
    //         不携带任何语义信息，攻击者无法通过命名猜测用途。
    //     • reserved: string[] — 保留原名列表
    //       可用值: 任意字符串数组
    //       推荐值: []（不保留任何名称）
    //       ❌ 禁止值: 包含内部方法名如 "visit_*"、"generic_visit"
    //       原因: 混淆器自身的方法名如果被保留，攻击者就能
    //         通过方法名推断混淆逻辑（如 visit_Str → 字符串加密）。
    //         所有 visit_* 方法都必须被重命名。
    // =================================================================
    rename_rules: {
      style: "hex",
      reserved: [],
    },

    encrypt_strings: true,
    encrypt_numbers: true,
    control_flow_flattening: true,
    dead_code_injection: true,
    string_split: true,
    obfuscate_imports: true,
    obfuscate_calls: true,
    obfuscate_arithmetic: true,
    obfuscate_booleans: true,
  },

  anti_debug: {
    // =================================================================
    // --- enabled: 反调试总开关 ---
    //   可用值: true | false
    //   推荐值: true
    //   ❌ 禁止值: false
    //   原因: 混淆器是攻击者的首要目标——理解混淆规则
    //     比理解加密算法更有价值（因为混淆规则保护所有模块）。
    //     如果攻击者在调试器中跟踪 visit_FunctionDef 的执行，
    //     就能完整再现混淆器的变换过程。
    // =================================================================
    enabled: true,

    // =================================================================
    // --- action: 反调试触发后的行为 ---
    //   可用值: "exit" | "warn" | "crash" | "corrupt"
    //   推荐值: "exit"
    //   原因: 检测到调试器必须立即终止，不能给攻击者任何
    //     观察混淆器执行过程的机会。混淆逻辑的泄露意味着
    //     每个被保护的模块都将被破解。
    // =================================================================
    action: "exit",

    // =================================================================
    // --- checks: 检测项目列表 ---
    //   可用值: "pdb" | "debugger" | "vm" | "sandbox" | "ida"
    //   推荐值: ["pdb", "debugger", "vm"]
    //   原因: 混淆器在构建时运行，不在运行时执行。
    //     因此 VM/沙箱检测在混淆器中的重要性略低于 crypto.py，
    //     但 pdb 和 debugger 检测必须开启。
    //     IDA 检测可选——混淆器不涉及加密，对 IDA 逆向
    //     的敏感度较低。但保留 VM 检测可以防止混淆器
    //     在受限环境中产生不一致的输出。
    // =================================================================
    checks: ["pdb", "debugger", "vm"],
  },

  virtualization: {
    // =================================================================
    // --- enabled: 虚拟化总开关 ---
    //   可用值: true | false
    //   推荐值: true
    //   原因: 将 Obfuscator 类的核心变换方法（visit_*）
    //     编译为自定义 VM 指令集。即使攻击者能拿到字节码，
    //     也无法直接读懂变换逻辑。这是保护"混淆器"本身
    //     的最后一道防线。
    // =================================================================
    enabled: true,

    // =================================================================
    // --- mode: 虚拟化模式 ---
    //   可用值: "full" | "partial" | "smart"
    //   推荐值: "full"
    //   原因: 和 crypto.py 同理。混淆器的每个方法都必须
    //     被虚拟化，不能有任何"partial"的例外。
    //     如果 visit_FunctionDef 被虚拟化但
    //     visit_Call 没有被虚拟化，攻击者可以通过
    //     未被虚拟化的方法推断混淆模式。
    // =================================================================
    mode: "full",
  },
}
