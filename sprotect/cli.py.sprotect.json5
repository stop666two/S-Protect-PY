{
  // ===================================================================
  // CLI 入口模块 — 命令行解析与分发
  // ===================================================================
  // 此模块通过 argparse 处理命令行参数和子命令分发。
  // 负责的功能：
  //   • build 子命令 — 构建受保护的可执行文件
  //   • encrypt 子命令 — 加密文件/目录
  //   • decrypt 子命令 — 解密文件/目录
  //   • keygen 子命令 — 生成密钥对
  //   • info 子命令 — 显示保护文件信息
  //   • --help / --version 参数
  //
  // ⚠️ 关键约束 ⚠️
  //   • main() 被 __main__.py 直接 import 引用
  //     → rename_functions 必须 false（否则入口点找不到函数）
  //   • argparse 内部通过 __name__ 做类名反射和参数绑定
  //     → rename_classes 必须 false（否则 argparse 报错）
  //   • build_parser() 返回 ArgumentParser 对象
  //     → 函数名被 __main__.py 引用，需加入 reserved 列表
  //
  // 安全等级：低
  //   CLI 模块不包含任何保护逻辑。它只是命令行参数的
  //   解析和路由。逆向此模块不能获取密钥或解密能力。
  //   因此混淆以"不影响功能"为优先，而非"最强保护"。
  // ===================================================================

  obfuscate: {
    // =================================================================
    // --- level: 混淆等级 ---
    //   数据类型: number（整数）
    //   可用值: 1 | 2 | 3 | 4 | 5
    //   ⚠️ 不可用值: 0, -1, 1.5, "5"
    //   推荐值: 3
    //   ❌ 禁止值: 5（没有必要且可能引入性能问题）
    //   原因: CLI 模块不包含任何保护逻辑——它只是将参数
    //     解析后路由到对应模块。混淆等级 3 已经足够：
    //     • 变量名被重命名（增加基本阅读难度）
    //     • 字符串被加密（隐藏 --help 输出中的关键字）
    //     • 导入被混淆（隐藏模块依赖关系）
    //     等级 4-5 的控制流平坦化会严重降低 argparse 的
    //     响应速度（argparse 本身就有复杂的控制流），
    //     导致 `--help` 输出延迟 2-5 秒，用户体验差。
    // =================================================================
  level: 5,

    // =================================================================
    // --- rename_variables: 变量重命名 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   ❌ 禁止值: 无（但 false 可接受，区别不大）
    //   原因: CLI 中的变量主要是 parser、args、subparsers 等，
    //     没有敏感变量。重命名主要用于增加阅读难度，
    //     让攻击者不能一眼看出 "parser" 是 ArgumentParser。
    // =================================================================
    rename_variables: true,

    // =================================================================
    // --- rename_functions: 函数重命名 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   ⚠️ 不可用值: 非布尔值
    //   推荐值: false
    //   ❌ 禁止值: true
    //   原因（关键约束）:
    //     main() 被 __main__.py 通过以下方式引用：
    //       from cli import main
    //       main()
    //     如果 main 被重命名为 _0x3f8a2b，
    //     __main__.py 会在运行时抛出 ImportError:
    //       "cannot import name 'main' from 'cli'"
    //     这是硬性约束，没有任何绕过方式。
    //     同样，build_parser 也被 __main__.py 引用。
    //     即使在 reserved 列表中声明 "main"，某些混淆代理
    //     仍然可能错误地重命名它，所以 safest 的选项是
    //     直接关闭函数重命名。
    // =================================================================
    rename_functions: false,

    // =================================================================
    // --- rename_classes: 类重命名 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: false
    //   ❌ 禁止值: true
    //   原因（关键约束）:
    //     argparse 内部使用类名做反射匹配。
    //     ArgumentParser 类名在 argparse 的 add_subparsers()
    //     和 parse_args() 中被引用。如果类名被更改，
    //     argparse 在运行时抛出 AttributeError:
    //       "'ArgumentParser' object has no attribute '_subparsers'"
    //     这是一个非常难调试的运行时错误——因为错误信息中
    //     的类名已经被混淆，你看到的是 _0x7f2a 而不是 ArgumentParser。
    //     修复方法只能是在混淆配置中显式禁止 rename_classes。
    // =================================================================
    rename_classes: false,

    // =================================================================
    // --- rename_rules: 命名规则 ---
    //   数据类型: object
    //   子字段:
    //     • style: string — 仅对 rename_variables=true 有效
    //       可用值: "hex" | "random" | "numbered" | "gibberish"
    //       推荐值: "hex"
    //     • reserved: string[] — 保留原名列表
    //       可用值: 任意字符串数组
    //       推荐值: ["main", "build_parser"]
    //       ❌ 禁止值: 不包含 main
    //       原因: 由于 rename_functions=false，reserved 中
    //         声明 main 和 build_parser 是冗余保护。
    //         但如果未来修改配置时意外开启了 rename_functions，
    //         reserved 中的名称可以防止入口函数被重命名。
    //         这是一种"防御性配置"的做法。
    // =================================================================
    rename_rules: {
      style: "hex",
      reserved: ["main", "_build_arg_tree"],
      prefix: "_0x",
      suffix: "",
      min_length: 6,
      blacklist: [],
    },

    // =================================================================
    // --- encrypt_strings: 字符串加密 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   ❌ 禁止值: 无
    //   原因: CLI 中的字符串主要是：
    //     • 命令描述（"Build protected executable"）
    //     • 参数名（"--output", "--key"）
    //     • 错误消息（"File not found"）
    //     加密后 --help 输出中这些字符串会显示为 base64 乱码，
    //     但这只是视觉问题——argparse 在内部解密后
    //     仍然能正确显示。不影响功能。
    //     对攻击者来说，乱码的 --help 输出让他们不能
    //     一眼看出命令行有哪些选项，增加初步侦查难度。
    // =================================================================
    encrypt_strings: true,

    // =================================================================
    // --- encrypt_numbers: 数字加密 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: false
    //   原因: CLI 模块中几乎没有有意义的数字常量。
    //     唯一的数字可能是 exit code（0, 1）或
    //     默认端口号。加密这些数字不会带来安全收益，
    //     反而会引入不必要的运行时开销。
    //     CLI 模块的策略是"够用就好"，不追求极致混淆。
    // =================================================================
    encrypt_numbers: false,

    // =================================================================
    // --- string_min_length: 字符串加密最小长度 ---
    //   数据类型: number
    //   可用值: 0-100
    //   推荐值: 3
    //   原因: 小于此长度的字符串不加密，避免短字符串加密后
    //     反而成为攻击者的搜索特征。
    // =================================================================
    string_min_length: 3,

    // =================================================================
    // --- string_encrypt_ratio: 字符串加密比例 ---
    //   数据类型: number
    //   可用值: 0.0 - 1.0
    //   推荐值: 1.0
    //   原因: 1.0 表示所有符合条件的字符串都加密，不留遗漏。
    // =================================================================
    string_encrypt_ratio: 1.0,

    // =================================================================
    // --- control_flow_flattening: 控制流平坦化 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: false
    //   ❌ 禁止值: true（对 CLI 模块弊大于利）
    //   原因:
    //     argparse 的 parse_args() 内部已经包含了
    //     非常复杂的错误处理和控制流（参数校验、类型转换、
    //     默认值填充、子命令路由等）。如果在此基础上
    //     再叠加控制流平坦化，会导致：
    //     1. `--help` 显示延迟 3-8 秒
    //     2. 参数解析错误（特定条件下 dispatch 到错误分支）
    //     3. 调试极其困难（堆栈信息完全不可读）
    //     而且 CLI 模块本身没有保护价值，不值得冒这个风险。
    // =================================================================
    control_flow_flattening: false,

    // =================================================================
    // --- dead_code_injection: 死代码注入 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: false
    //   原因: 死代码注入会在每个函数中插入永远不会执行的
    //     分支代码。在 argparse 的 parse_args 中注入死代码
    //     可能导致 Python 的字节码大小超过函数内联阈值，
    //     引发意外的 MemoryError 或 RecursionError。
    //     且 CLI 模块不包含需要隐藏的逻辑，死代码注入
    //     没有收益，只有风险。
    // =================================================================
    dead_code_injection: false,

    // =================================================================
    // --- dead_code_density: 死代码密度 ---
    //   数据类型: number
    //   可用值: 0.0 - 1.0
    //   推荐值: 0.3
    //   原因: 控制注入死代码的比例。因 dead_code_injection=false,
    //     此值不生效，保留默认值作为防御性配置。
    // =================================================================
    dead_code_density: 0.3,

    // =================================================================
    // --- opaque_predicate_count: 不透明谓词数量 ---
    //   数据类型: number
    //   可用值: 0-10
    //   推荐值: 2
    //   原因: 每个函数插入 N 个永远为真/假的条件分支。
    //     CLI 模块不需要此保护，保留默认值2供未来参考。
    // =================================================================
    opaque_predicate_count: 2,

    // =================================================================
    // --- remove_docstrings: 移除文档字符串 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 移除所有函数/类的 docstring，减少可阅读的信息量。
    // =================================================================
    remove_docstrings: true,

    // =================================================================
    // --- remove_comments: 移除注释 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 源码中的注释在混淆产物中不应保留。
    // =================================================================
    remove_comments: true,

    // =================================================================
    // --- strip_blank_lines: 移除空行 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 移除多余空行，压缩代码体积，减少可读性。
    // =================================================================
    strip_blank_lines: true,

    // =================================================================
    // --- max_line_length: 最大行长度 ---
    //   数据类型: number
    //   可用值: 0-9999（0=不限制）
    //   推荐值: 0
    //   原因: 0 表示不限制行长度，交由混淆代理自行决定。
    // =================================================================
    max_line_length: 0,

    // =================================================================
    // --- string_split: 字符串拆分 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 将 CLI 中的字符串（如 "build" → "_b" + "_uild"）
    //     拆分为多个片段。攻击者搜索 "build" 关键字时
    //     找不到匹配项。这项变换开销小、效果好。
    // =================================================================
    string_split: true,

    // =================================================================
    // --- string_cipher: 字符串加密算法 ---
    //   数据类型: string
    //   可用值: "aes" | "xor" | "mixed" | "base64"
    //   推荐值: "mixed"
    //   原因: "mixed" 混合多种加密算法，增加破解难度。
    //     对 CLI 模块来说，即使是最简单的 base64 也足够，
    //     但为保持一致使用 mixed。
    // =================================================================
    string_cipher: "mixed",

    // =================================================================
    // --- obfuscate_imports: 导入混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 隐藏 CLI 模块依赖于哪些子模块（crypto、obfuscate 等）。
    //     攻击者不能通过分析 imports 快速了解系统架构。
    // =================================================================
    obfuscate_imports: true,

    // =================================================================
    // --- obfuscate_calls: 函数调用混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 隐藏 CLI 分发逻辑中哪个参数调用哪个函数。
    //     攻击者不能直接看出 "--encrypt" 对应 encrypt_file()。
    // =================================================================
    obfuscate_calls: true,

    // =================================================================
    // --- obfuscate_arithmetic: 算术混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 将索引计算和边界检查转换为复杂的表达式。
    //     虽然 CLI 中算术少，但开启没有副作用。
    // =================================================================
    obfuscate_arithmetic: true,

    // =================================================================
    // --- obfuscate_booleans: 布尔表达式混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 将条件判断中的 True/False 替换为复杂表达式。
    //     对 argparse 的条件分支增加阅读难度。
    // =================================================================
    obfuscate_booleans: true,
  },

  anti_debug: {
    // =================================================================
    // --- enabled: 反调试总开关 ---
    //   可用值: true | false
    //   推荐值: false
    //   ❌ 禁止值: 无（但 true 会造成构建困难）
    //   原因: CLI 模块在构建机器上运行（用户执行保护命令时）。
    //     构建机器是受控环境，理论上不会被攻击者调试。
    //     开启反调试反而会：
    //     • 误杀合法用户在 PyCharm 中运行保护命令
    //     • 在 CI/CD 流水线中误触发导致构建失败
    //     反调试在运行时模块（解密/执行受保护文件）中才需要，
    //     在构建工具中不需要。
    // =================================================================
    enabled: false,

    // =================================================================
    // --- action: 反调试触发后的行为 ---
    //   可用值: "exit" | "warn" | "crash" | "corrupt"
    //   推荐值: "warn"（虽然 enabled=false 不会触发）
    //   原因: 作为防御性配置，即使未来 enabled 意外改为 true，
    //     warn 行为至少能给用户一个提示，而不是直接退出。
    //     但注意：由于 enabled=false，action 实际上不会被使用。
    // =================================================================
    action: "warn",

    // =================================================================
    // --- checks: 检测项目列表 ---
    //   可用值: "pdb" | "debugger" | "vm" | "sandbox" | "ida"
    //   推荐值: ["pdb", "debugger"]
    //   原因: 同样由于 enabled=false，此配置不会被激活。
    //     但保留它作为"配置模板"——如果未来某个 CLI 子命令
    //     需要在运行时执行（如解密命令），可以直接启用。
    // =================================================================
    checks: ["pdb", "debugger"],

    // =================================================================
    // --- per_check_actions: 逐项检测自定义行为 ---
    //   数据类型: string[][]
    //   可用值: [["check","action"], ...] | []
    //   推荐值: []
    //   原因: 空数组表示所有检测项统一使用 action 字段指定的行为。
    //     如需为特定检测项指定不同行为（如 pdb 只 warn 不 exit），
    //     可在此配置。CLI 模块 enabled=false，此值不生效。
    // =================================================================
    per_check_actions: [],

    // =================================================================
    // --- process_whitelist: 进程白名单 ---
    //   数据类型: string[]
    //   可用值: ["process1", "process2", ...] | []
    //   推荐值: []
    //   原因: 白名单中的进程不被反调试检测。CLI 模块不需要。
    // =================================================================
    process_whitelist: [],

    // =================================================================
    // --- block_tracing: 阻止系统追踪 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 阻止 ptrace 等系统追踪机制，防止调试器附加。
    //     CLI 模块中此值不生效（enabled=false）。
    // =================================================================
    block_tracing: true,

    // =================================================================
    // --- timing_threshold: 时序检测阈值（秒）---
    //   数据类型: number
    //   可用值: 0.1 - 60.0
    //   推荐值: 2.0
    //   原因: 检测代码执行耗时是否异常（调试器会显著减慢执行速度）。
    //     超过此阈值则判定为被调试。CLI 模块中不生效。
    // =================================================================
    timing_threshold: 2.0,

    // =================================================================
    // --- exit_code: 反调试触发时的退出码 ---
    //   数据类型: number
    //   可用值: 0-255
    //   推荐值: 1
    //   原因: 标准退出码 1 表示一般性错误。
    // =================================================================
    exit_code: 1,

    // =================================================================
    // --- wipe_memory: 退出时擦除敏感内存 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 退出前用零填充敏感内存区域，防止内存转储泄露密钥。
    //     CLI 模块中无敏感数据，开启也无副作用。
    // =================================================================
    wipe_memory: true,

    // =================================================================
    // --- corrupt_on_exit: 退出时损坏数据 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: false
    //   原因: 在检测到调试时故意损坏部分数据以迷惑攻击者。
    //     可能造成不可逆的数据损坏，强烈建议保持 false。
    // =================================================================
    corrupt_on_exit: false,
  },
}
