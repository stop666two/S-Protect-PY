{
  // ===================================================================
  // 水印模块 — 三层溯源追踪
  // ===================================================================
  // 此模块用于追踪泄露来源——当盗版者泄露了你的软件，
  // 你可以从水印中提取：
  //   • 这是哪次 build 的输出（batch_id）
  //   • 这个文件是谁的版本（客户/渠道标识）
  //   • 水印是否被篡改过（HMAC 验证失败 = 被动手脚）
  //
  // 此模块包含：
  //   • file_payload():        .pye 元数据水印
  //                            嵌入 batch_id + 时间戳 + HMAC 签名
  //   • code():                源码级水印
  //                            每段源码末尾注入哈希校验 lambda
  //   • runtime():             运行时水印校验函数生成
  //   • extract_watermark():   从 .pye 文件提取水印信息
  //   • verify_watermark():    验证水印 HMAC 真实性
  //
  // 注意：水印对安全性无直接影响（它不是反破解措施），
  //       但它是法律诉讼和溯源的重要依据。
  //       水印需要合理保护以防被清除——但过度保护没有意义。
  // ===================================================================

  // ===================================================================
  // obfuscate — 混淆设置（AST 级别）
  // ===================================================================
  obfuscate: {
    // --- level: 混淆等级 ---
    // 可用值: 1 | 2 | 3 | 4 | 5
    // 不可用: "5" / 0 / 6 / -1 / 3.5
    // 合法示例:
    //   1 — 仅重命名（最轻量，适合简单逻辑模块）
    //   2 — 重命名 + 字符串加密（适合水印模块）
    //   3 — 含控制流平坦化（此模块用此值，适合中等安全）
    //   5 — 全部开启（对此模块过度杀伤）
    // 注意事项:
    //   • 水印模块逻辑相对简单（注入代码 + 哈希 + HMAC）
    //   • 控制流平坦化可能改变 watermar.code() 的注入代码结构
    //   • 死代码注入可能破坏嵌入到源码末尾的 lambda 水印
    // 为什么用 3 不是 5（此模块）:
    //   水印模块的主要作用是嵌入和验证水印，它不是防御性模块。
    //   攻击者清除水印的动机是掩盖盗版来源，而不是破解保护。
    //   用 L5 过度混淆水印模块，风险（破坏水印逻辑）远大于收益。
    //   L3 提供合理的重命名 + 字符串加密 + 基础控制流混淆，
    //   既保护了水印字段名，又不会破坏水印注入逻辑。
    level: 3,

    // --- rename_variables: 变量重命名 ---
    // 可用值: true | false
    // 注意事项:
    //   • 水印模块的变量名（如 watermark_key、batch_id 等）
    //     泄露了水印结构，应该改名
    // 为什么用 true（此模块）:
    //   watermark_key、payload、signature 等变量名直接
    //   告诉攻击者水印的组成。改名后攻击者需要分析
    //   代码逻辑才能理解水印结构。
    rename_variables: true,

    // --- rename_functions: 函数重命名 ---
    // 可用值: true | false
    // 注意事项:
    //   • 水印函数被 encrypt 模块调用，但通过函数对象引用
    //     而非字符串名称，改名安全
    // 为什么用 true（此模块）:
    //   watermark.file_payload()、watermark.code() 等
    //   通过模块属性或函数对象传递，改名后调用不变。
    rename_functions: true,

    // --- rename_classes: 类重命名 ---
    // 可用值: true | false
    // 注意事项:
    //   • 水印模块通常采用函数式实现，没有对外暴露的类
    // 为什么用 true（此模块）:
    //   同 rename_functions，无外部类引用。
    rename_classes: true,

    // --- encrypt_strings: 字符串加密 ---
    // 可用值: true | false
    // 注意事项:
    //   • 水印字段名（"bid"、"sig"、"auth"、"ts" 等）是字符串
    //   • 加密后攻击者无法通过搜索这些字段名找到水印注入点
    //   • 但必须确保这些字符串不在配置键名匹配逻辑中使用
    // 为什么用 true（此模块）:
    //   "batch_id"、"watermark"、"hmac" 等字段名被加密后，
    //   攻击者即使 dump 了加密后的 .pye 文件，也无法直接
    //   阅读水印的 JSON 结构字段名。
    encrypt_strings: true,

    // --- encrypt_numbers: 数字加密 ---
    // 可用值: true | false
    // 注意事项:
    //   • 水印模块中数字很少（主要是时间戳和版本号）
    //   • 数字加密对水印没有实质性的安全增益
    // 为什么用 false（此模块）:
    //   水印模块几乎没有敏感数字常量。时间戳不需要加密
    //   （它就是时间，加密后还要解密，浪费性能）。
    //   数字加密的运行时开销在此模块是纯粹的浪费。
    encrypt_numbers: false,

    // --- control_flow_flattening: 控制流平坦化 ---
    // 可用值: true | false
    // ❗ 此模块必须为 false
    // 原因: Watermark.code() 需要在源码 AST 末尾精确注入
    //       水印 lambda 代码。控制流平坦化会重整代码结构、
    //       添加 while-switch 包装器，导致：
    //       • AST 末尾不再是"真正的"代码末尾
    //       • 注入位置偏移——水印被注入到平坦化控制结构中
    //       • 水印 lambda 在运行时被正确执行，但结构被破坏
    //       最终导致水印提取逻辑失败。
    // 为什么用 false（此模块）:
    //   Watermark.code() 的工作原理是：
    //     1. 解析原始模块 AST
    //     2. 找到 AST 体(body) 的末尾
    //     3. 在末尾注入一个带水印数据的 lambda 表达式
    //     4. 这个 lambda 在导入时自动执行，注册水印
    //   如果代码被平坦化，第 2 步找到的"末尾"实际上是
    //   while 循环的末尾，注入的水印 lambda 变成
    //   循环的一部分——永远不会执行（因为循环是死循环）。
    control_flow_flattening: false,

    // --- dead_code_injection: 死代码注入 ---
    // 可用值: true | false
    // ❗ 此模块必须为 false
    // 原因: 死代码注入可能在水印 lambda 中嵌入死代码，
    //       或者在水印注入目标位置前插入死代码返回语句，
    //       导致水印 lambda 成为 unreachable code。
    // 为什么用 false（此模块）:
    //   场景：假设 Watermark.code() 要注入
    //     lambda: _mark = (lambda: _hash("test"))
    //   如果死代码注入器在 lambda 内部插入了：
    //     lambda: (None or _hash("test")) or dead_code()
    //   那么 dead_code() 的返回值可能改变整个表达式的值，
    //   导致水印哈希计算错误。
    //   或者，死代码注入器在 injection_point 之前插入了
    //   一个 return 语句——watermark lambda 永远不会到达。
    //   最终结果是：水印丢失或校验失败。
    dead_code_injection: false,
  },

  // ===================================================================
  // anti_debug — 反调试/反VM/反沙箱
  // ===================================================================
  anti_debug: {
    // --- enabled: 总开关 ---
    // 可用值: true | false
    // 为什么用 false（此模块）:
    //   水印模块在 build 阶段运行（注入水印），而非用户运行时。
    //   build 机器上的反调试没有意义——开发者要调试自己的代码。
    //   另外，水印模块没有需要运行时保护的反破解逻辑。
    //   水印不存在"被绕过"的问题——水印被清除只是溯源能力
    //   丧失，不会导致程序被破解。
    //   因此反调试在此模块是不必要的开销。
    enabled: false,
  },
}
