{
  project: { name: "py-running-text", version: "1.0.0", entry: "main.py" },
  obfuscate: {
    level: 5,
    rename_variables: true, rename_functions: true, rename_classes: true,
    rename_rules: { style: "hex", reserved: [] },
    encrypt_strings: true, encrypt_numbers: true,
    control_flow_flattening: true, dead_code_injection: true,
  },
  encrypt: { algorithm: "hmac-sha256-xor", backup: true, shard_count: 5 },
  anti_debug: { enabled: true, action: "exit", checks: ["pdb_check", "debugger_detect", "vm_detect"] },
  virtualization: { enabled: true, mode: "full", functions: [], glob_patterns: [] },
  watermark: { enabled: true, levels: ["file", "code", "runtime"], batch_id: "pyruntest_001" },
  expiration: { enabled: true, expires_at: "2030-12-31T23:59:59Z", ntp_check: false, on_network_fail: "allow" },
  environment: { enabled: true, bind_directory: null, bind_username: null, bind_env_vars: [] },
  sandbox: { enabled: true },
  output: { dir: "./dist", keep_source_map: false },
}
