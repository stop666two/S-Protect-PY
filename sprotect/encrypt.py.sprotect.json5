{
  // ===================================================================
  // 加密构建引擎 — build 完整流程
  // ===================================================================
  // 此模块是 S-Protect-PY 的核心编排器。
  // 负责任务调度：项目扫描 → per-file 配置加载 → 跨文件命名收集 →
  // 逐文件 AST 混淆 → 源码压缩 → 水印注入 → 多层加密（AES+Salsa+
  // Serpent 可选嵌套） → 密钥分片存储 → 链式哈希 → 诱饵文件批量
  // 生成 → loader 生成 → 启动器 stub 组装 → 报告生成。
  //
  // ╔══════════════════════════════════════════════════════════════════╗
  // ║  关键约束                                                       ║
  // ║  • build() 被 cli.py 直接调用（通过 from encrypt import build）║
  // ║  • merge_file_config() 由 config.py 提供并被此模块调用           ║
  // ║  • 所有子模块（obfuscate/watermark/crypto/minify/decoy/loader） ║
  // ║    的函数入口由此模块直接调用                                   ║
  // ║  • 此模块的完整性 = 整个保护流水线的完整性                        ║
  // ║  • 攻击者如果能逆向此模块，就能理解保护体系的完整工作流架构       ║
  // ║  → build() 绝对不能改名                                         ║
  // ║  → 所有子模块调用保持通过模块对象引用（改名安全）                 ║
  // ╚══════════════════════════════════════════════════════════════════╝
  // ===================================================================

  // ===================================================================
  // obfuscate — 混淆设置（AST 级别）
  // ===================================================================
  obfuscate: {
    // --- level: 混淆等级 ---
    // 可用值: 1 | 2 | 3 | 4 | 5
    // 不可用: "5"（字符串）/ 0 / 6 / -1 / 3.5 / null
    // 合法示例:
    //   1 - 仅变量重命名，无结构变化
    //   3 - 中度混淆（含字符串加密 + 分割 + 调用混淆）
    //   5 - 全开（全部 11 种变换，构建最慢但保护最强）
    // 注意事项:
    //   • level 5 会开启全部变换，构建时间增加 300%-500%
    //   • 此模块含大量控制流（循环/条件/异常处理），
    //     control_flow_flattening 与 try-except 链可能冲突
    //   • encrypt_strings 在此模块安全，因为不涉及模板生成
    // 推荐值: 5
    // 不推荐: 1-2（几乎无保护效果，逆向工具可以直接分析出流程）
    // 为什么用 5: 编排器包含完整的保护流程逻辑，
    //   泄露 = 攻击者了解整个保护体系的架构和流程
    //   这是整个系统最重要的模块之一，必须最高强度保护
    level: 5,

    // --- rename_variables: 变量重命名 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0 / "yes"
    // 推荐值: true
    // 注意事项:
    //   • 所有局部变量名改为 _0x 风格随机名
    //   • 变量重命名后 traceback 更难阅读
    //   • 不影响其他模块的调用（通过对象引用）
    // 为什么不 false: 模块内有大量中间变量（如 merged_source,
    //   temp_path, shard_data 等），保留原名等于暴露内部架构
    rename_variables: true,

    // --- rename_functions: 函数重命名 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 推荐值: true
    // 注意事项:
    //   Python 通过模块对象引用函数（encrypt.build 等），
    //   改名只改变函数在模块内的 __name__ 属性，
    //   不影响从 cli.py 用 from encrypt import build 导入。
    //   但 reserved 列表必须包含 build 函数名。
    // 为什么用 true: 函数名如 _collect_names, _shard_encrypt,
    //   _inject_watermark 等暴露了保护流程的关键步骤
    rename_functions: true,

    // --- rename_classes: 类重命名 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 推荐值: true
    // 注意事项:
    //   此模块可能定义少量内部 dataclass/holder 类型，
    //   如果存在 isinstance 检查则必须谨慎。
    //   检查模块源代码确认不存在 isinstance(class, ...) 调用。
    // 为什么用 true: 类名暴露内部数据结构，改名可隐藏
    rename_classes: true,

    // --- rename_rules: 重命名规则 ---
    rename_rules: {
      // --- style: 命名风格 ---
      // 可用值:
      //   "hex"           _0xa1b2c3（十六进制，默认）
      //   "chinese"       _变量（中文字符，反混淆器难解析）
      //   "invisible"     零宽字符（肉眼不可见，但易被检测）
      //   "math-symbols"  _∑∫∂（数学符号）
      //   "custom"        自定义前缀/后缀
      // 不可用: "unicode" / "base64" / "random"
      // 推荐值: "hex"
      // 不推荐: "invisible"（某些 Python 解析器报语法错误）
      // 注意事项:
      //   • 命名风格不影响功能，只影响可读性
      //   • "chinese" 在非中文终端的显示可能乱码
      // 为什么用 "hex":
      //   十六进制命名在 IDA/Ghidra 中显示最清晰，
      //   且与常用的逆向分析工具兼容性最好
      style: "hex",

      // --- reserved: 保留名称列表 ---
      // 可用值: ["build", "_build_single", ...] | []
      // 不可用: 非字符串 / 空字符串 / 含空格
      // 推荐值: ["build"]
      // 注意事项:
      //   • rename_functions=true 时此列表必须包含所有
      //     被外部 import 引用的函数名
      //   • 遗漏任何一个 → ImportError: cannot import name
      //   • 最佳实践：先 grep 哪些函数被其他模块 import
      // 为什么仅包含 "build":
      //   只有 build() 被 cli.py 通过 from encrypt import build
      //   直接引用。其他函数即使被改名也不影响调用链。
      reserved: ["build"],
    },

    // --- encrypt_strings: 字符串加密 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 推荐值: true
    // 注意事项:
    //   • 模块内的错误消息、算法步骤名、文件名被 base64 编码
    //   • 运行时自动解码，无功能影响
    //   • 此模块不含代码生成模板，加密安全
    // 为什么用 true: 编排器中的错误消息（如 "压缩失败",
    //   "分片校验不通过"）泄露了保护流程的步骤数量
    encrypt_strings: true,

    // --- encrypt_numbers: 数字加密 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 推荐值: true
    // 注意事项:
    //   • 分片大小、加密轮数、哈希长度等数字常量被加密
    //   • 加密为 struct.unpack 表达式（略膨胀代码）
    //   • 在 build 阶段执行，对运行时性能无影响
    // 为什么用 true: 分片大小、加密轮次等数字泄露了
    //   保护方案的实现参数，加密后攻击者无法直接获取
    encrypt_numbers: true,

    // --- control_flow_flattening: 控制流平坦化 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 推荐值: true
    // 注意事项:
    //   • 将顺序代码转为 while+switch 分派器
    //   • 此模块有复杂的多步构建流程（15+ 步骤），
    //     平坦化后逆向工具很难追踪执行路径
    //   • 如果模块包含 try-except-else-finally 复杂链，
    //     平坦化可能改变异常处理的行为范围
    // 为什么用 true: 编排器是攻击者最想逆向的目标，
    //   平坦化让 IDA 的反编译结果变成一团乱麻
    control_flow_flattening: true,

    // --- dead_code_injection: 死代码注入 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 推荐值: true
    // 注意事项:
    //   • 插入与真实代码结构相同的假代码片段
    //   • 插入代码块中可能包含 return/break/continue
    //   • 需确保假代码不意外改变执行路径
    // 为什么用 true: 编排器步骤多、结构复杂，
    //   混入假步骤后攻击者无法分清哪些是真实保护步骤
    dead_code_injection: true,

    // --- string_split: 字符串分割 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   • 将字符串拆为多个碎片运行时 + 拼接
    //   • 增加 grep 搜索关键字难度
    // 为什么用 true: 错误消息被拆分后在二进制中
    //   无法直接搜索到完整句子
    string_split: true,

    // --- obfuscate_imports: import 混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // ❌ 禁止: 如果模块有动态 import（__import__ 调用）
    // 注意事项:
    //   import os → os = __import__(...)，隐藏模块依赖
    obfuscate_imports: true,

    // --- obfuscate_calls: 调用混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   func(a, b) → 通过中间 lambda 转发参数
    obfuscate_calls: true,

    // --- obfuscate_arithmetic: 算术混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   简单算术表达式被展开为等效复杂形式
    obfuscate_arithmetic: true,

    // --- obfuscate_booleans: 布尔混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   True/False 被替换为复杂布尔表达式
    obfuscate_booleans: true,
  },

  // ===================================================================
  // anti_debug — 反调试/反VM/反沙箱
  // ===================================================================
  anti_debug: {
    // --- enabled: 总开关 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 推荐值: true
    // 注意事项:
    //   • 编排器在 build 机器上运行（开发/CI 环境）
    //   • build 环境通常受控，但不可完全排除被攻击者调试的可能
    //   • 如果误触，整个 build 流程被阻断
    // 为什么用 true: 攻击者可能在 build 环境下附加调试器
    //   观察保护流程，反调试可以减少此风险
    enabled: true,

    // --- action: 检测到异常后的动作 ---
    // 可用值: "exit" | "warn" | "corrupt"
    // 不可用: "pause" / "crash" / 空字符串
    //    exit    = 立即退出进程（最安全）
    //    warn    = 打印告警后继续运行（用于调试）
    //    corrupt = 破坏内存数据后退出（最激进）
    // 推荐值: "exit"
    // 注意事项: build 机器上使用 "exit" 是安全的，
    //   因为 build 是短时任务，退出后可重试
    action: "exit",

    // --- checks: 检测项列表 ---
    // 可用值: "pdb" | "ptrace" | "debugger" | "vm" | "sandbox"
    //        | "timing" | "cuckoo" | "ida" | "procmon"
    // 不可用: 不存在的检测项名称 / 空字符串
    // 推荐值: ["pdb", "debugger", "vm"]
    // 注意事项:
    //   • build 机器不运行在沙箱/Cuckoo 中，无需检测这些
    //   • ptrace 检测在 Windows 上无意义（无 ptrace 系统调用）
    //   • timing 检测在 CI 环境（CPU 降频）可能误报
    // 为什么只选这三个: build 环境纯受控，
    //   只关心调试器附加和 VM 检测这两种常见攻击场景
    checks: ["pdb", "debugger", "vm"],

    // --- per_check_actions: 逐检测项覆盖动作 ---
    // 可用值: [{check:"vm", action:"warn"}] | []
    // 不可用: check 值不在 checks 列表中
    // 推荐值: []
    // 注意事项:
    //   优先级高于全局 action，允许对特定检测项单独配置。
    //   例: VM 检测设为 warn 而不是 exit（build 可能运行在 VM 中）
    // 为什么用 []: 此模块不区分处理各检测项，
    //   统一使用全局 action
    per_check_actions: [],

    // --- process_whitelist: 进程白名单 ---
    // 可用值: ["python.exe", "pycharm64.exe"] | []
    // 不可用: 非字符串 / 空字符串 / 含通配符
    // 推荐值: []
    // 注意事项:
    //   白名单中的进程不被当作调试器或分析工具
    // 为什么用 []: build 环境极简，不运行 IDE 等工具
    process_whitelist: [],

    // --- block_tracing: 阻断追踪 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   启动时调用 sys.settrace(None) 和 sys.setprofile(None)
    // 为什么用 true: 防止攻击者用 sys.settrace 设置跟踪
    //   来观察保护流程的函数调用链
    block_tracing: true,

    // --- timing_threshold: 时序检测阈值（秒）---
    // 可用值: 0.5 ~ 10.0
    // 推荐值: 2.0
    // 不可用: 0 / 负数 / > 60
    // 注意事项:
    //   CI 环境中因 CPU 降频可能导致时间测量偏差
    //   在 CI 场景建议设为 5.0
    timing_threshold: 2.0,

    // --- exit_code: 退出码 ---
    // 可用值: 1 ~ 255
    // 不可用: 0（正常退出）/ 负数 / > 255 / 3.5
    // 推荐值: 1
    // 注意事项: 非 0 退出码表示异常终止
    exit_code: 1,

    // --- wipe_memory: 退出时清空内存 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 调用 gc.collect() + 手动覆盖敏感变量
    wipe_memory: true,

    // --- corrupt_on_exit: 退出时破坏内存 ---
    // 可用值: true | false
    // 推荐值: false
    // 注意事项: 随机改写内存中的对象值，比 wipe 更激进
    //   与 action:"corrupt" 配合效果最好
    corrupt_on_exit: false,
  },

  // ===================================================================
  // virtualization — 代码虚拟化（预留）
  // ===================================================================
  virtualization: {
    // --- enabled: 虚拟化开关 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   • 代码虚拟化将此模块的字节码翻译为自定义 VM 指令集
    //   • 需要额外的 VM interpreter 嵌入到运行时
    //   • 目前为预留功能，需配合 _vm 模块使用
    // 为什么用 true: 编排器是最高价值目标，
    //   代码虚拟化提供比混淆更强的保护
    enabled: true,

    // --- mode: 虚拟化模式 ---
    // 可用值: "full" | "partial" | "critical"
    // 不可用: "all" / "none" / "auto"
    // 推荐值: "full"
    // 注意事项:
    //   "full"     = 虚拟化整个模块（最强，但启动开销大）
    //   "partial"  = 只虚拟化关键函数
    //   "critical" = 只虚拟化最敏感的加密相关函数
    // 为什么用 "full": 编排器模块整体都需要最高保护，
    //   部分虚拟化可能留下未保护的代码路径
    mode: "full",
  },

  // ===================================================================
  // encryption — 加密流水线设置
  // ===================================================================
  encryption: {
    // --- enabled: 加密总开关 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 推荐值: true
    // 注意事项:
    //   关闭此开关 = 不加密源码 = 纯混淆输出
    // 为什么用 true: 此模块控制整个 build 流程，
    //   加密是核心保护手段之一，必须开启
    enabled: true,

    // --- primary_algo: 主加密算法 ---
    // 可用值: "aes-256-gcm" | "chacha20-poly1305" | "xorshift"
    // 不可用: "des" / "rc4" / "aes-128" / "plain"
    // 推荐值: "aes-256-gcm"
    // 注意事项:
    //   • AES-256-GCM 提供认证加密（加密+完整性校验）
    //   • ChaCha20-Poly1305 在无 AES 硬件加速的 CPU 上更快
    //   • XOR 流仅用于混淆层，不是真正的加密
    // 为什么用 "aes-256-gcm": 256 位密钥 + GCM 模式
    //   提供认证加密，防止被篡改
    primary_algo: "aes-256-gcm",

    // --- extra_layers: 额外加密层列表 ---
    // 可用值: ["serpent", "twofish", "camellia", "salsa20"]
    //        | []
    // 不可用: 不存在的算法名 / "aes"（已做为主算法）
    // 推荐值: ["serpent", "salsa20"]
    // 注意事项:
    //   • 嵌套加密顺序: salsa20(serpent(aes(data)))
    //   • 每增加一层，构建时间 +30%，运行时解密时间 +20%
    //   • 密钥由 HKDF-SHA256 域分离派生
    // 为什么选这两个: Serpent 和 AES 结构不同，破解需两种攻击；
    //   Salsa20 流密码时序恒定，防止侧信道
    extra_layers: ["serpent", "salsa20"],

    // --- key_size: 主密钥长度（位）---
    // 可用值: 128 | 192 | 256
    // 不可用: 64 / 512 / 0 / "256"（字符串）
    // 推荐值: 256
    // 注意事项: 256 位在量子计算 Grover 算法下有 128 位安全性
    key_size: 256,

    // --- shard_count: 密钥分片数量 ---
    // 可用值: 2 ~ 16
    // 不可用: 0 / 1 / > 16 / 字符串
    // 推荐值: 5
    // 注意事项:
    //   • 使用 Shamir 秘密共享将主密钥拆分为 shard_count 分片
    //   • 需要 threshold 个分片才能恢复密钥
    //   • 分片数越多，每个分片越小，但分片管理越复杂
    // 为什么用 5: 5 分片中任意 3 片可恢复密钥，
    //   攻击者需要至少拿到 3 个分片才能解密
    shard_count: 5,

    // --- shard_threshold: 恢复密钥所需最少分片数 ---
    // 可用值: 2 ~ shard_count
    // 不可用: 0 / 1 / > shard_count
    // 推荐值: 3
    // 注意事项:
    //   • threshold = 分片数时最安全（所有分片都必须拿到）
    //   • threshold = 2 时可用性最高（任意 2 片即可恢复）
    //   • 推荐取 floor(shard_count/2) + 1
    // 为什么用 3: 5 片中取 3 片，安全性（需拿大多数）和
    //   可用性（丢失 2 片不影响）的最佳平衡
    shard_threshold: 3,

    // --- hkdf_salt: HKDF 盐值（十六进制）---
    // 可用值: 32 字符十六进制字符串 | "auto"
    // 不可用: 非十六进制 / 长度 != 32 字符（显式指定时）
    // 推荐值: "auto"
    // 注意事项:
    //   "auto" = 构建时随机生成，每次 build 不同
    // 为什么用 "auto": 每次构建生成不同盐值，
    //   即使同一份源码每次构建的输出都不同
    hkdf_salt: "auto",
  },

  // ===================================================================
  // watermark — 水印注入设置
  // ===================================================================
  watermark: {
    // --- enabled: 水印注入开关 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   水印用于追踪泄露来源（哪次 build、哪个客户）
    enabled: true,

    // --- mode: 水印模式 ---
    // 可用值: "static" | "dynamic" | "dual"
    // 不可用: "auto" / "none"
    // 推荐值: "dual"
    // 注意事项:
    //   "static"  = 变量/常量注入（静态分析可见）
    //   "dynamic" = 行为/序列化顺序注入（运行时可检测）
    //   "dual"    = 同时注入两种水印
    mode: "dual",

    // --- fingerprint_depth: 指纹深度 ---
    // 可用值: "file" | "function" | "block"
    // 不可用: "module" / "project"
    // 推荐值: "function"
    // 注意事项:
    //   "file"     = 每个文件一个水印（最浅）
    //   "function" = 每个函数一个独特水印
    //   "block"    = 每个代码块一个水印（最深，最膨胀）
    // 为什么用 "function": 函数级别的水印能精确追踪
    //   到泄露的函数位置，膨胀量适中
    fingerprint_depth: "function",
  },

  // ===================================================================
  // minify — 压缩设置
  // ===================================================================
  minify: {
    // --- enabled: 压缩开关 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 在混淆之后执行，移除注释/空格/冗余符号
    enabled: true,

    // --- remove_docstrings: 移除文档字符串 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 移除所有 """docstring""" 和 '''docstring'''，
    //   保留 __init__ 中的注释（可能有业务含义）
    remove_docstrings: true,

    // --- remove_annotations: 移除类型注解 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 移除 def f(x: int) -> str: 中的 : int 和 -> str，
    //   不影响运行时行为（Python 类型注解在运行时无强制效果）
    remove_annotations: true,

    // --- remove_pass: 移除冗余 pass ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 移除函数体和类体中无意义的 pass 语句
    remove_pass: true,
  },

  // ===================================================================
  // decoy — 诱饵文件设置
  // ===================================================================
  decoy: {
    // --- enabled: 诱饵生成开关 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   生成看起来像真实 Python 模块的假代码，
    //   让逆向分析者浪费时间分析无意义的目标
    enabled: true,

    // --- count: 诱饵文件数量 ---
    // 可用值: 1 ~ 50
    // 不可用: 0 / > 50 / 负数
    // 推荐值: 10
    // 注意事项:
    //   • 每个诱饵文件约 200-500 行看起来真实的代码
    //   • 数量过多会导致打包体积膨胀
    // 为什么用 10: 10 个假模块 + 1 个真实模块 = 1/11 猜中率，
    //   攻击者平均需要分析 5.5 个模块才能找到真的
    count: 10,

    // --- complexity: 诱饵复杂度 ---
    // 可用值: 1 ~ 5
    // 不可用: 0 / > 5
    // 推荐值: 3
    // 注意事项:
    //   1 = 简单变量定义（易被识破）
    //   3 = 含函数定义、类定义、import 语句（中等）
    //   5 = 含加密操作、文件 IO、网络请求（最高迷惑性）
    complexity: 3,
  },

  // ===================================================================
  // anti_tamper — 防篡改/链式哈希
  // ===================================================================
  anti_tamper: {
    // --- enabled: 防篡改开关 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   链式哈希：每个 shard 存储下一个 shard 的哈希值，
    //   形成哈希链。篡改任一 shard 导致整个链断裂。
    enabled: true,

    // --- hash_algo: 哈希算法 ---
    // 可用值: "sha256" | "sha3-256" | "blake2b" | "blake3"
    // 不可用: "md5" / "sha1" / "crc32"
    // 推荐值: "blake2b"
    // 注意事项:
    //   • BLAKE2b 速度比 SHA-256 快 30%
    //   • SHA-256 硬件加速在 Python 中不明显
    // 为什么用 "blake2b": 纯 Python 实现下性能最好，
    //   且安全性不低于 SHA-256
    hash_algo: "blake2b",
  },

  // ===================================================================
  // output — 输出设置
  // ===================================================================
  output: {
    // --- dir: 输出目录 ---
    // 可用值: "output" | 任意合法路径字符串
    // 不可用: 空字符串 / 含非法字符的路径
    // 推荐值: "output"
    // 注意事项:
    //   • 相对路径基于项目根目录
    //   • 目录不存在时自动创建
    output_dir: "output",

    // --- clean_before_build: 构建前清空输出目录 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   • =true 时删除 output/ 下的所有旧文件
    //   • 防止旧文件残留导致的混淆
    clean_before_build: true,

    // --- preserve_temps: 保留临时文件 ---
    // 可用值: true | false
    // 推荐值: false
    // 注意事项:
    //   • =true 时保留中间产物（混淆中间态、加密前源码等）
    //   • 仅供调试使用，生产环境禁止
    preserve_temps: false,
  },

  // ===================================================================
  // parallel — 并行处理设置
  // ===================================================================
  parallel: {
    // --- enabled: 并行处理开关 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   • 多文件混淆/加密使用 ProcessPoolExecutor 并行执行
    //   • 显著减少构建时间（特别是有 50+ 源码文件的项目）
    //   • 单文件项目开启无意义
    enabled: true,

    // --- max_workers: 最大并行数 ---
    // 可用值: 1 ~ 32
    // 不可用: 0 / > 32 / 非整数
    // 推荐值: 0（使用 os.cpu_count()）
    // 注意事项:
    //   • 0 = 自动检测 CPU 核心数
    //   • 设为 1 = 串行处理（等效于 enabled=false）
    //   • 设为核心数的 2 倍可能因 I/O 等待而更快
    max_workers: 0,
  },

  // ===================================================================
  // signing — 代码签名设置
  // ===================================================================
  signing: {
    // --- enabled: 签名开关 ---
    // 可用值: true | false
    // 推荐值: false
    // 注意事项:
    //   • 用 RSA-4096 私钥对输出的 loader 进行签名
    //   • 运行时验证签名完整性
    //   • 需要外部私钥文件，增加部署复杂度
    // 为什么用 false: 签名需要分发公钥到运行时，
    //   公钥嵌入 loader 中可被提取替换
    enabled: false,

    // --- key_file: 私钥文件路径 ---
    // 可用值: "signing_key.pem" | ""
    // 推荐值: ""
    // 注意事项: enabled=false 时不使用
    key_file: "",
  },

  // ===================================================================
  // report — 构建报告设置
  // ===================================================================
  report: {
    // --- enabled: 生成构建报告 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   生成 build_report.json，包含每个文件的混淆统计、
    //   加密算法、哈希值、水印 ID 等信息
    enabled: true,

    // --- format: 报告格式 ---
    // 可用值: "json" | "html" | "both"
    // 不可用: "xml" / "yaml"
    // 推荐值: "json"
    // 注意事项:
    //   "json" = 纯 JSON 文件（计算机可读）
    //   "html" = 可读的 HTML 报告
    //   "both" = 同时生成两种格式
    format: "json",
  },

  // ===================================================================
  // backup — 构建前自动备份
  // ===================================================================
  backup: {
    // --- enabled: 自动备份开关 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   构建前自动备份项目源码到 backup/ 目录
    enabled: true,

    // --- max_backups: 最大备份数 ---
    // 可用值: 1 ~ 100
    // 推荐值: 10
    // 注意事项: 超过此数量时删除最旧的备份
    max_backups: 10,
  },
}
