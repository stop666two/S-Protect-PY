{
  // ===================================================================
  // 极致压缩器配置 — 多算法堆叠压缩
  // ===================================================================
  // 【原理】
  //   对加密后的 .pye 载荷进行多轮堆叠压缩：
  //   标识符缩短 → Token替换 → lzma → bz2 → zlib(9) → base85编码
  //   每轮压缩都在上一轮的基础上进一步缩减体积。
  //
  // 【效果】
  //   典型 Python 项目额外缩减 15%-40%（取决于源码特征）
  //   重复字符串多的项目压缩率更高。
  //
  // 【启用】
  //   在 sprotect.json5 中设置 compressor.enabled = true
  //   或直接修改本文件。
  //
  // 【注意】
  //   压缩会增加解密时的解压时间（约 +10%~30%）
  //   对于极小项目（<50KB）效果不明显。
  // ===================================================================

  enabled: true,                     // 总开关
  pass_count: 3,                     // 堆叠轮数（1-5，越多压缩率越高但越慢）
  use_lzma: true,                    // 使用 LZMA 压缩（高压缩率）
  use_bz2: true,                     // 使用 BZ2 压缩（中等压缩率）
  use_zlib: true,                    // 使用 Zlib 压缩（兼容性好）
  use_base85: true,                  // 使用 Base85 编码（减少文本膨胀）
  token_replace: true,               // 启用 Token 替换（重复模式压缩）
  shorten_identifiers: true,         // 缩短标识符名
  remove_dead_strings: true,         // 移除无效字符串
  dictionary_size: 4096,             // Token 字典大小（字节）
  max_chunk_size: 1048576,           // 最大分块大小（1MB，超过则分块压缩）
}
