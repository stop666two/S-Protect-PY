{
  // ==========================================
  // 启动器生成模块 - 精细化配置
  // 生成 output/main.py（bootloader）和 _runtime/loader.py
  // 注意：生成的代码必须保持正确，混淆不能破坏模板字符串
  // ==========================================

  obfuscate: { level: 4, rename_variables: true, rename_functions: true,
    rename_classes: true, encrypt_strings: false, // 模板字符串不加密（含代码）
    encrypt_numbers: false, control_flow_flattening: false,
    dead_code_injection: false },
  anti_debug: { enabled: true, action: "exit", checks: ["pdb", "debugger", "vm"] },
}
