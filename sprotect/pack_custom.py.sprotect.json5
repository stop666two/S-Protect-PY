{
  // ===================================================================
  // 自定义打包器 — 自解压单文件 / .pyz zip 包
  // ===================================================================
  // 替代 PyInstaller，生成自包含的 .py 脚本或 .pyz 压缩包。
  // 输出 bundle.py 可直接用 python bundle.py 运行。
  //
  // ⚠️ 此模块包含代码生成模板（_STUB_TEMPLATE），
  //    因此 encrypt_strings 等功能已在代码中强制关闭。
  // ===================================================================

  obfuscate: {
    level: 5,
  },
}
