{
  // ===================================================================
  // 启动器生成模块 — 运行时解密引擎
  // ===================================================================
  // 此模块生成 _runtime/loader.py（运行时加载器）
  // 和 output/main.py（启动入口 stub）。
  //
  // ╔══════════════════════════════════════════════════════════════════╗
  // ║  关键约束（违反将导致生成的启动器无法运行）                       ║
  // ║                                                                  ║
  // ║  • gen_loader_source() 使用 f-string 模板生成 Python 源码，      ║
  // ║    模板内的 {}、控制流关键字、标识符不能被混淆/加密               ║
  // ║  • encrypt_strings=true → 模板字符串被 base64 编码 →             ║
  // ║    生成的 loader.py 包含乱码片段 → 运行时语法错误                 ║
  // ║  • control_flow_flattening=true → 生成器函数的 while-switch      ║
  // ║    结构破坏字符串模板的逐行拼接顺序                             ║
  // ║  • dead_code_injection=true → 假代码可能插入到模板中间，         ║
  // ║    导致生成的 loader 出现语法错误                                ║
  // ║                                                                  ║
  // ║  → encrypt_strings 必须 false                                    ║
  // ║  → control_flow_flattening 必须 false                            ║
  // ║  → dead_code_injection 必须 false                                ║
  // ║  → encrypt_numbers 建议 false（模板中数字也是字符串的一部分）    ║
  // ║  → gen_loader_source() 被 encrypt.py 直接调用                    ║
  // ╚══════════════════════════════════════════════════════════════════╝
  // ===================================================================

  // ===================================================================
  // obfuscate — 混淆设置（本模块的混淆，不影响生成的 loader）
  // ===================================================================
  obfuscate: {
    // --- level: 混淆等级 ---
    // 可用值: 1 | 2 | 3 | 4 | 5
    // 不可用: "4"（字符串）/ 0 / 6 / -1 / 3.5
    // 合法示例:
    //   4 — 除字符串加密/数字加密/平坦化/死代码外的全部混淆
    // 推荐值: 4
    // 注意事项:
    //   • level=4 跳过 encrypt_strings + encrypt_numbers +
    //     control_flow_flattening + dead_code_injection
    //   • level=5 会强制开启这些选项 → 与模板生成冲突
    // 为什么用 4 不是 5: L5 会强制开启所有变换，
    //   而此模块的 encrypt_strings 和 control_flow_flattening
    //   必须为 false（会破坏生成的 loader 代码），
    //   因此不能使用 L5 的分组预设，需手动逐项指定。
    level: 5,

    // --- rename_variables: 变量重命名 ---
    // 可用值: true | false
    // 不可用: "true" / 1 / 0
    // 推荐值: true
    // 注意事项:
    //   • 只重命名此模块（loader.py）内的变量
    //   • 不影响生成的 loader.py 代码
    //   • gen_loader_source 和 gen_boot 函数体内的临时变量被改名
    rename_variables: true,

    // --- rename_functions: 函数重命名 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   gen_loader_source 和 gen_boot 被 encrypt.py 调用，
    //   Python 通过模块对象引用函数，改名不影响调用
    rename_functions: true,

    // --- rename_classes: 类重命名 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 此模块可能包含模板类定义，改名不影响生成结果
    rename_classes: true,

    // --- rename_rules: 重命名规则 ---
    rename_rules: {
      // --- style: 命名风格 ---
      // 可用值: "hex" | "chinese" | "invisible" | "math-symbols" | "custom"
      // 不可用: "unicode" / "base64" / "random"
      // 推荐值: "hex"
      // 注意事项: hex 风格最稳定，兼容所有 Python 版本
      style: "hex",

      // --- prefix: 重命名前缀 ---
      // 可用值: "_0x" | "_" | 任意合法标识符前缀
      // 推荐值: "_0x"
      // 注意事项: style="custom" 时生效，其他风格忽略此值
      prefix: "_0x",

      // --- suffix: 重命名后缀 ---
      // 可用值: "" | "_" | 任意合法标识符后缀
      // 推荐值: ""
      suffix: "",

      // --- min_length: 重命名最小长度 ---
      // 可用值: 4 ~ 32
      // 推荐值: 6
      // 注意事项: 防止生成过短的名称导致命名冲突
      min_length: 6,

      // --- reserved: 保留名称列表 ---
      // 可用值: ["gen_loader_source", "gen_boot"] | []
      // 不可用: 非字符串 / 空字符串
      // 推荐值: ["gen_loader_source", "gen_boot"]
      // 注意事项:
      //   虽然 rename_functions=true 不影响模块导入，
      //   但 reserved 列表确保函数名在 traceback 中可识别
      reserved: ["gen_loader_source", "gen_boot"],

      // --- blacklist: 黑名单名称列表 ---
      // 可用值: ["__init__", "__name__"] | []
      // 推荐值: []
      // 注意事项: 黑名单中的名称不会被重命名，
      //   用于保护 Python 魔术方法和内置属性
      blacklist: [],
    },

    // --- encrypt_strings: 字符串加密 ---
    // 可用值: true | false
    // ❌ 禁止: true
    // 原因:
    //   此模块的核心逻辑是 f-string 模板拼接。
    //   gen_loader_source() 中有大量类似
    //   f"def {func_name}({args}):\n    {body}"
    //   的代码。如果开启字符串加密：
    //   1. 模板字符串 "def " 被 base64 编码
    //   2. 解码后 = "def " + func_name + "(" + args + "):\n    " + body
    //      — 看起来没问题？
    //   3. 问题是：模板字符串中包含的 loader.py 代码片段本身
    //      （如 "import sys\n"）也被加密
    //   4. 这些代码片段是"字符串"——Python 运行此模块时正常解码
    //   5. 但解码后的字符串被写入 loader.py 文件
    //   6. loader.py 文件中的代码片段保持解码后的原文—没问题
    //   — 等等，那为什么不能加密？
    //   真正的原因是：
    //   混淆工具在字节码级别对字符串常量进行变换，变换方式
    //   不一定是可逆的 base64 编码，可能是运行时动态解密。
    //   在运行 loader.py 时，这些"字符串片段"已经是 loader.py
    //   中的代码字符串，不再经过此模块的解密函数处理。
    //   如果混淆工具对字符串做了引用替换或重新编码，
    //   生成到 loader.py 中的代码片段就是乱码。
    //   简言之: 模板字符串作为 Python 字符串在运行时是正常的，
    //   但写入到文件的代码片段失去了运行时的解密环境。
    //   结论: encrypt_strings 必须 false。
    encrypt_strings: false,

    // --- encrypt_numbers: 数字加密 ---
    // 可用值: true | false
    // ❌ 禁止: true
    // 原因: 同字符串加密，数字常量（如版本号 1.0.0）可能出现在
    //   生成的 loader 模板中。数字加密会把 3 变为复杂表达式
    //   (lambda: 1+2)()，这个表达式写入 loader.py 后可以运行，
    //   但增加了不必要的复杂度和出错概率。
    //   原则：任何会出现在生成代码中的内容都不能被加密/混淆。
    encrypt_numbers: false,

    // --- string_min_length: 字符串加密最小长度 ---
    // 可用值: 2 ~ 20
    // 推荐值: 3
    // 注意事项: 虽 encrypt_strings=false，保留此项用于
    //   未来切换为 true 时直接生效
    string_min_length: 3,

    // --- string_encrypt_ratio: 字符串加密比例 ---
    // 可用值: 0.0 ~ 1.0
    // 推荐值: 0.8
    // 注意事项: 当前未启用（encrypt_strings=false）
    string_encrypt_ratio: 0.8,

    // --- string_cipher: 字符串加密算法 ---
    // 可用值: "aes" | "xor" | "base64" | "rot13"
    // 推荐值: "aes"
    // 注意事项: 当前未启用（encrypt_strings=false）
    string_cipher: "aes",

    // --- control_flow_flattening: 控制流平坦化 ---
    // 可用值: true | false
    // ❌ 禁止: true
    // 原因:
    //   gen_loader_source() 的逻辑是顺序拼接字符串：
    //   source = ""
    //   source += "import sys\n"
    //   source += template_header
    //   source += template_body.format(...)
    //   ...
    //   控制流平坦化将这种线性顺序转为 while+switch dispatch。
    //   每个 += 操作变成一个 dispatch case。
    //   问题是：switch dispatch 的执行顺序由 state 变量控制，
    //   如果某个 case 修改了 state 但未正确 fallthrough，
    //   拼接顺序就乱了——生成的字符串可能是：
    //   "import sys\ntemplate_body\nheader"（顺序错乱）
    //   这种情况下生成的 loader.py 语法完全错误。
    //   更严重的是：此 bug 不是每次都出现，取决于状态分配算法。
    //   结论: 控制流平坦化必须 false。
    control_flow_flattening: false,

    // --- dead_code_injection: 死代码注入 ---
    // 可用值: true | false
    // ❌ 禁止: true
    // 原因:
    //   死代码注入会在函数体内随机插入看起来像代码的假片段。
    //   例: 在 source += line 之前注入 if False: corrupted_line += "x"
    //   这些假代码片段可能被混淆工具误认为真实代码，
    //   插入到字符串拼接链中，导致生成的字符串包含额外的
    //   字符，生成出来的 loader.py 某一行出现奇怪的拼接结果。
    //   而且，即使假代码在 if False: 块中不会被运行，
    //   它出现在模板生成函数中仍然会改变代码结构。
    //   有些混淆工具的死代码注入不够智能，可能将假代码插入到
    //   f-string 表达式内部——这直接产生语法错误。
    //   结论: dead_code_injection 必须 false。
    dead_code_injection: false,

    // --- dead_code_density: 死代码密度 ---
    // 可用值: 0.1 ~ 0.5
    // 推荐值: 0.3
    // 注意事项: 当前未启用（dead_code_injection=false），
    //   保留此项用于未来切换时直接生效
    dead_code_density: 0.3,

    // --- opaque_predicate_count: 不透明谓词数量 ---
    // 可用值: 1 ~ 20
    // 推荐值: 5
    // 注意事项: 不透明谓词是永远为真/假的表达式，
    //   用于创建看似有分支的假控制流
    opaque_predicate_count: 5,

    // --- string_split: 字符串分割 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   • 将字符串拆为多个碎片运行时拼接
    //   • 模板字符串中的 loader 代码片段也被分割
    //   • 但这是安全的——分割发生在运行时，拼接后的字符串
    //     仍然是完整的 f-string 模板，写入文件的是拼接后的结果
    // 为什么用 true: 分割后硬编码的模板字符串在反编译工具中
    //   不会显示完整的 loader 代码结构
    string_split: true,

    // --- obfuscate_imports: import 混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 此模块的 import（如 import os, json, base64）
    //   被混淆为 __import__ 调用，隐藏模块依赖关系
    obfuscate_imports: true,

    // --- obfuscate_calls: 调用混淆 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 函数调用通过中间 lambda 转发，增加逆向难度
    obfuscate_calls: true,

    // --- obfuscate_arithmetic: 算术混淆 ---
    // 可用值: true | false
    // 推荐值: true
    obfuscate_arithmetic: true,

    // --- obfuscate_booleans: 布尔混淆 ---
    // 可用值: true | false
    // 推荐值: true
    obfuscate_booleans: true,

    // --- remove_docstrings: 移除文档字符串 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 移除所有 """docstring""" 和 '''docstring'''
    remove_docstrings: true,

    // --- remove_comments: 移除注释 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 移除所有单行注释 #，防止注释泄露模板生成逻辑
    remove_comments: true,

    // --- strip_blank_lines: 移除空行 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 移除多余空行，压缩代码体积
    strip_blank_lines: true,

    // --- max_line_length: 最大行长度 ---
    // 可用值: 100 ~ 500
    // 推荐值: 200
    // 注意事项: 防止单行过长导致某些分析工具崩溃
    max_line_length: 200,
  },

  // ===================================================================
  // anti_debug — 反调试设置（此模块 = 生成器，非运行时）
  // ===================================================================
  anti_debug: {
    // --- enabled: 总开关 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   • 此模块在 build 阶段被 encrypt.py 调用
    //   • 保护该模块免受调试器附加，防止泄露 loader 生成逻辑
    //   • build 环境可控，但反调试提供额外保护层
    enabled: true,

    // --- action: 检测到异常后的动作 ---
    // 可用值: "exit" | "warn" | "corrupt"
    // 推荐值: "exit"
    action: "exit",

    // --- checks: 检测项列表 ---
    // 可用值: "pdb" | "ptrace" | "debugger" | "vm" | "sandbox"
    //        | "timing" | "cuckoo" | "ida" | "procmon"
    // 推荐值: ["pdb", "debugger", "vm", "sandbox", "cuckoo", "ida"]
    // 注意事项:
    //   • 此模块比 encrypt.py 的 anti_debug 更严格
    //   • 因为 loader 生成逻辑的保护需求更高
    //   • 包括更多检测项，覆盖沙箱和静态分析工具
    // 为什么用 6 项: loader 生成逻辑涉及运行时解密密钥和算法，
    //   必须防止在任何分析环境中生成 loader
    checks: ["pdb", "debugger", "vm", "sandbox", "cuckoo", "ida"],

    // --- per_check_actions: 逐检测项覆盖动作 ---
    // 可用值: [{check:"vm", action:"warn"}] | []
    // 推荐值: []
    per_check_actions: [],

    // --- process_whitelist: 进程白名单 ---
    // 可用值: ["python.exe"] | []
    // 推荐值: []
    process_whitelist: [],

    // --- block_tracing: 阻断追踪 ---
    // 可用值: true | false
    // 推荐值: true
    block_tracing: true,

    // --- timing_threshold: 时序检测阈值（秒）---
    // 可用值: 0.5 ~ 10.0
    // 推荐值: 2.0
    timing_threshold: 2.0,

    // --- exit_code: 退出码 ---
    // 可用值: 1 ~ 255
    // 不可用: 0 / 负数 / > 255
    exit_code: 1,

    // --- wipe_memory: 退出时清空内存 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 清除内存中的模板字符串和密钥派生中间变量
    wipe_memory: true,

    // --- corrupt_on_exit: 退出时破坏内存 ---
    // 可用值: true | false
    // 推荐值: false
    corrupt_on_exit: false,
  },

  // ===================================================================
  // loader_template — 生成的 loader 代码模板设置
  // ===================================================================
  loader_template: {
    // --- stub_minimal: 是否生成极简 stub ---
    // 可用值: true | false
    // 推荐值: false
    // 注意事项:
    //   • true = 生成约 50 行的极简 loader（仅负责解密 + exec）
    //   • false = 生成完整 loader（含反调试、防篡改、超时控制等）
    // 为什么用 false: 极简 loader 保护能力弱，
    //   但在某些限制体积的场景下是必要的
    stub_minimal: false,

    // --- include_anti_debug: loader 中包含反调试 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   • 生成的 loader.py 中将包含反调试检测代码
    //   • 反调试在 loader 启动后立即执行
    //   • 如果目标环境已知有特殊性（如运行在沙箱中），请关闭
    include_anti_debug: true,

    // --- include_anti_tamper: loader 中包含防篡改校验 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   • 校验加密分片的哈希链完整性
    //   • 任何分片被篡改 → 拒绝加载
    include_anti_tamper: true,

    // --- include_expiration: loader 中包含过期检查 ---
    // 可用值: true | false
    // 推荐值: false
    // 注意事项:
    //   • 在 loader 中加入日期检查逻辑
    //   • 超过 expiry_date 后程序拒绝启动
    //   • 默认关闭，需要配合 expiration 模块使用
    include_expiration: false,

    // --- expiry_date: 过期日期 ---
    // 可用值: "YYYY-MM-DD" | ""
    // 不可用: 无效日期格式 / 已过日期
    // 推荐值: ""
    // 注意事项: include_expiration=true 时必填
    expiry_date: "",
  },

  // ===================================================================
  // loader_encryption — 加载器加密设置
  // ===================================================================
  loader_encryption: {
    // --- algo: loader 加密算法 ---
    // 可用值: "aes-256-gcm" | "chacha20-poly1305" | "xor"
    // 不可用: "none" / "plain"
    // 推荐值: "aes-256-gcm"
    // 注意事项:
    //   • loader 本身以密文形式分片存储
    //   • decrypt 阶段需要先解密 loader 本身
    //   • 使用独立于源码加密的密钥
    algo: "aes-256-gcm",

    // --- key_derivation: 密钥派生方式 ---
    // 可用值: "hkdf" | "pbkdf2" | "direct"
    // 不可用: "none" / "plaintext"
    // 推荐值: "hkdf"
    // 注意事项:
    //   • "hkdf"   = HKDF-SHA256 从 master_key 派生（推荐）
    //   • "pbkdf2" = PBKDF2 带 salt + 迭代（更慢但抗暴力）
    //   • "direct" = 直接使用嵌入的密钥（不安全）
    key_derivation: "hkdf",
  },

  // ===================================================================
  // loader_runtime — 加载器运行时行为
  // ===================================================================
  loader_runtime: {
    // --- execution_mode: 执行模式 ---
    // 可用值: "exec" | "importlib" | "subprocess"
    // 不可用: "eval" / "shell"
    // 推荐值: "exec"
    // 注意事项:
    //   • "exec"      = exec(decrypted_code, globals())（最快）
    //   • "importlib" = 使用 importlib 动态加载模块（最兼容）
    //   • "subprocess"= 启动子进程运行（隔离性最好）
    // 为什么用 "exec": exec 方式性能最好且兼容性最高，
    //   importlib 对于加密后的代码可能有模块查找问题
    execution_mode: "exec",

    // --- clear_locals: 执行后清除局部变量 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: exec 执行后删除临时变量，减少内存中的敏感数据
    clear_locals: true,

    // --- hide_callstack: 隐藏调用栈 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 执行前替换 sys.excepthook，隐藏 loader 调用帧
    hide_callstack: true,

    // --- max_retries: 解密重试次数 ---
    // 可用值: 0 ~ 5
    // 不可用: 负数 / > 5
    // 推荐值: 1
    // 注意事项: 分片解密失败时的重试次数。
    //   0 = 不重试，1 = 重试一次，>1 在磁盘 I/O 错误时有用
    max_retries: 1,
  },

  // ===================================================================
  // loader_error — 加载器错误处理
  // ===================================================================
  loader_error: {
    // --- show_user: 向用户显示错误 ---
    // 可用值: true | false
    // 推荐值: false
    // 注意事项:
    //   • true  = 解密失败时显示友好错误消息
    //   • false = 静默退出，不显示任何消息
    // 为什么用 false: 不显示错误 = 攻击者不知道失败原因
    show_user: false,

    // --- fake_error: 显示假错误以迷惑攻击者 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   • true  = 显示伪造的 Python 错误（如 ImportError）
    //   • false = 不显示错误
    // 为什么用 true: 让攻击者以为是代码本身的 bug，
    //   而不是保护系统的防御触发
    fake_error: true,

    // --- fake_error_type: 伪造的错误类型 ---
    // 可用值: "ImportError" | "ModuleNotFoundError" | "SyntaxError"
    //        | "RuntimeError"
    // 不可用: "SystemExit" / "KeyboardInterrupt"
    // 推荐值: "ModuleNotFoundError"
    fake_error_type: "ModuleNotFoundError",

    // --- fake_error_message: 伪造的错误消息 ---
    // 可用值: "No module named 'requests'" | ""
    // 推荐值: "No module named 'requests'"
    // 注意事项: 误导攻击者认为是依赖缺失问题
    fake_error_message: "No module named 'requests'",
  },

  // ===================================================================
  // loader_obfuscation — 对生成的 loader 代码进行二次混淆
  // ===================================================================
  loader_obfuscation: {
    // --- enabled: 二次混淆开关 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项:
    //   • 在生成的 loader.py 代码上再次应用 AST 混淆
    //   • 防止攻击者直接分析解密后的 loader 代码
    //   • 二次混淆的对象是字符串形式的源代码，
    //     由混淆工具解析字符串内容后进行变换
    enabled: true,

    // --- level: 二次混淆等级 ---
    // 可用值: 1 ~ 5
    // 推荐值: 3
    // 注意事项:
    //   • 相比主模块混淆（level 4），二次混淆等级较低
    //   • 因为 loader 代码本身是在资源受限的环境下运行
    //   • 过高的等级可能导致生成的 loader 启动延迟
    level: 5,

    // --- variable_rename: 重命名 loader 中的变量 ---
    // 可用值: true | false
    // 推荐值: true
    // 注意事项: 生成的 loader 中的变量和函数名被随机化
    variable_rename: true,
  },

  // ===================================================================
  // output — 输出路径设置
  // ===================================================================
  output: {
    // --- loader_path: loader 输出路径 ---
    // 可用值: "_runtime/loader.py" | 任意合法路径
    // 推荐值: "_runtime/loader.py"
    // 注意事项: 相对路径基于项目根目录
    loader_path: "_runtime/loader.py",

    // --- main_stub_path: 启动 stub 输出路径 ---
    // 可用值: "main.py" | "output/main.py"
    // 推荐值: "output/main.py"
    // 注意事项: 此文件为用户双击执行的入口
    main_stub_path: "output/main.py",

    // --- runner_template: 启动 stub 模板 ---
    // 可用值: "standard" | "silent" | "console"
    // 推荐值: "standard"
    // 注意事项:
    //   "standard" = 标准启动（有控制台窗口）
    //   "silent"   = 后台运行（仅 Windows 隐藏窗口）
    //   "console"  = 调试模式（打印详细日志）
    runner_template: "standard",
  },
}
