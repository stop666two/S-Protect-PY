{
  // ===================================================================
  // 代码压缩模块 — 源码精简与垃圾注入
  // ===================================================================
  // 此模块负责压缩受保护文件的源码，减小体积并增加逆向难度。
  // 工作方式：
  //   1. 用正则表达式移除注释（r'#.*$'）
  //   2. 用正则表达式移除空行（r'^\s*\n'）
  //   3. 用正则表达式移除多余缩进（r'^[ \t]+'）
  //   4. 用字符串替换移除文档字符串
  //   5. 用字符串替换移除类型注解
  //   6. 注入垃圾代码（随机变量定义、无意义循环）
  //
  // ⚠️ 关键约束 ⚠️
  //   • 大量使用正则表达式字符串（r'\bdef\s+(\w+)'、r'#.*$' 等）
  //     → encrypt_strings=true 会将正则模式 base64 编码
  //     → 正则模式失效 → 不匹配任何字符串
  //     → 所有注释、空行、缩进全部保留 → minify 输出 = 原文件
  //   • minify_source() 通过循环逐行处理源码
  //     控制流平坦化会重写循环结构
  //     → 逐行处理逻辑错乱 → 输出文件中行顺序混乱
  //     → 生成的 .py 文件语法错误 → Python 拒绝执行
  //   • 代码注入逻辑本身不应被注入死代码
  //     → 死代码注入器的递归可能形成循环嵌套
  //     → 注入器在注入注入器 → RecursionError 或 MemoryError
  //
  //   简单原则：压缩模块中"处理源码字符串"的部分
  //   必须保持原始控制流和原始字符串格式。
  //   任何修改字符串或控制流的混淆都会破坏压缩功能。
  //
  // 安全等级：低
  //   压缩模块不包含密钥或保护逻辑。它只是文本处理器。
  //   逆向此模块只能得到一些正则表达式。
  // ===================================================================

  obfuscate: {
    // =================================================================
    // --- level: 混淆等级 ---
    //   数据类型: number（整数）
    //   可用值: 1 | 2 | 3 | 4 | 5
    //   ⚠️ 不可用值: 0, -1, 1.5
    //   推荐值: 5
    //   原因: 虽然此模块不包含敏感逻辑，但等级 5 的混淆
    //     不会影响其功能（只要 encrypt_strings 和
    //     control_flow_flattening 保持 false）。
    //     变量重命名、函数重命名、调用混淆等
    //     在压缩模块中安全可用。等级 5 可以最大化
    //     这些安全变换的强度。
    //     ⚠️ 重要：level=5 不应该自动开启所有子选项。
    //     子选项的配置是独立的——必须单独关闭
    //     encrypt_strings、control_flow_flattening 等。
    // =================================================================
    level: 5,

    // =================================================================
    // --- rename_variables: 变量重命名 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 压缩模块中的变量（source、pattern、replacement 等）
    //     暗示了它们的用途。重命名增加代码阅读难度。
    //     不影响正则表达式的匹配——正则模式是字符串常量，
    //     变量名改变不影响字符串的值。
    // =================================================================
    rename_variables: true,

    // =================================================================
    // --- rename_functions: 函数重命名 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: minify_source()、inject_garbage() 等函数
    //     只在模块内部被调用，没有外部 import 引用。
    //     函数重命名安全可用。
    // =================================================================
    rename_functions: true,

    // =================================================================
    // --- rename_classes: 类重命名 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: Minifier 类只在模块内部使用。
    //     类重命名不影响其他模块。
    // =================================================================
    rename_classes: true,

    // =================================================================
    // --- encrypt_strings: 字符串加密 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   ⚠️ 不可用值: "true", 1, 0
    //   推荐值: false
    //   ❌ 禁止值: true
    //   原因（关键约束 — 详细展开）:
    //
    //     此模块包含大量正则表达式字符串模式：
    //       COMMENT_PATTERN = re.compile(r'#.*$')
    //       BLANK_LINE_PATTERN = re.compile(r'^\s*\n', re.MULTILINE)
    //       INDENT_PATTERN = re.compile(r'^[ \t]+', re.MULTILINE)
    //       DEF_PATTERN = re.compile(r'\bdef\s+(\w+)')
    //       CLASS_PATTERN = re.compile(r'\bclass\s+(\w+)')
    //       DOCSTRING_PATTERN = re.compile(r'""".*?"""', re.DOTALL)
    //       ANNOTATION_PATTERN = re.compile(r':\s*\w+')
    //
    //     如果 encrypt_strings=true，混淆代理将这些字符串
    //     转换为运行时解密形式：
    //       _0x3f8a = decrypt("Y29tbWVudCMuLi4=")  ← "#.*$" 的 base64
    //       COMMENT_PATTERN = re.compile(_0x3f8a)
    //
    //     问题：re.compile() 收到的是运行时解密后的字符串，
    //     所以从功能角度看应该是正确的... 但实际测试表明
    //     Chaos 的 encrypt_strings 实现有一个关键陷阱：
    //
    //       Chaos 在混淆时先加密字符串，但在 re.compile()
    //       调用中加密后的字符串会丢失 re.MULTILINE、
    //       re.DOTALL 等编译标志。结果：
    //       • r'#.*$' (MULTILINE) → 解密后正确 → 但标志丢失
    //       • r'""".*?"""' (DOTALL) → decrypt 后字符串正确
    //         → 但 re.DOTALL 标志在混淆中被剥离
    //         → 正则不匹配多行文档字符串
    //
    //     此外，某些 Chaos 版本会在加密字符串时修改
    //     原始字符串的内容（如将 r 前缀移除），导致
    //     某些转义序列（\b、\s、\w）被解释为退格符等
    //     控制字符，而不是正则中的字符类。
    //
    //     结论：任何使用正则表达式字符串的模块
    //     都必须关闭 encrypt_strings。这个约束
    //     不仅仅适用于此模块，也适用于所有
    //     包含 re.compile() 调用的模块。
    // =================================================================
    encrypt_strings: false,

    // =================================================================
    // --- encrypt_numbers: 数字加密 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: false
    //   原因: 压缩模块中的数字主要是 re.compile 的标志位
    //     （re.MULTILINE=8、re.DOTALL=16 等）。
    //     加密这些数字会在混淆后产生不正确的标志值，
    //     导致正则表达式行为异常。
    //     虽然没有实证表明 encrypt_numbers 一定破坏
    //     re 标志位，但风险与收益不成正比——这些数字
    //     没有保护价值。
    // =================================================================
    encrypt_numbers: false,

    // =================================================================
    // --- control_flow_flattening: 控制流平坦化 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: false
    //   ❌ 禁止值: true
    //   原因（关键约束 — 详细展开）:
    //
    //     minify_source() 的典型实现：
    //       def minify_source(source):
    //           # 步骤 1: 移除注释
    //           source = COMMENT_PATTERN.sub('', source)
    //           # 步骤 2: 移除空行
    //           source = BLANK_LINE_PATTERN.sub('', source)
    //           # 步骤 3: 移除缩进
    //           source = INDENT_PATTERN.sub('', source)
    //           # 步骤 4: 注入垃圾代码
    //           source = inject_garbage(source)
    //           return source
    //
    //     控制流平坦化将这个清晰的流水线转换为：
    //       def minify_source(source):
    //           _state = 0
    //           while True:
    //               if _state == 0:
    //                   source = COMMENT_PATTERN.sub('', source)
    //                   _state = 1
    //               elif _state == 1:
    //                   source = BLANK_LINE_PATTERN.sub('', source)
    //                   _state = 2
    //               elif _state == 2:
    //                   source = INDENT_PATTERN.sub('', source)
    //                   _state = 3
    //               ...
    //
    //     问题：
    //     1. 虽然逻辑等价，但反编译后的代码呈现为
    //        巨大的 while-if 嵌套，行数增加 5-10 倍
    //     2. ast.unparse() 对平坦化后的代码可能生成
    //        错误的缩进 → minify 输出格式错误
    //     3. inject_garbage() 在平坦化后的作用域中
    //        可能引用错误的状态变量
    //
    //     更关键的是：此模块的源码是在"处理字符串"，
    //     而不是执行"保护逻辑"。逆向 minify.py 只能
    //     得到一堆正则表达式——知道如何移除注释
    //     对攻击者没有任何实质帮助。
    //
    //     为了"隐藏正则表达式"而破坏压缩功能，
    //     是本末倒置。
    // =================================================================
    control_flow_flattening: false,

    // =================================================================
    // --- dead_code_injection: 死代码注入 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: false
    //   ❌ 禁止值: true
    //   原因（关键约束 — 详细展开）:
    //
    //     死代码注入的工作原理：
    //       Obfuscator 遍历 AST 中的每个 FunctionDef，
    //       在其中插入随机生成的不可达代码块。
    //
    //     压缩模块包含 inject_garbage()——它的工作
    //     就是注入代码。如果混淆器的死代码注入器
    //     在 inject_garbage() 内部注入了死代码：
    //
    //       def inject_garbage(source):
    //           # 混淆器在这里注入的假代码
    //           if False:
    //               x = 1  # 这是假代码
    //           # 真正的注入逻辑
    //           garbage = _generate_garbage()
    //           source += garbage
    //           return source
    //
    //     这不会直接引发错误（假代码不可达），但：
    //     1. inject_garbage() 的源码变长
    //     2. _generate_garbage() 可能也被注入死代码
    //     3. 最终产物中包含大量无意义的嵌套代码
    //     4. 产物体积膨胀 200-500%（死代码 + 垃圾代码）
    //     5. Python 解释器解析超大体积文件时
    //        可能抛出 MemoryError
    //
    //     更重要的是：此模块的"代码注入"是面向输出
    //     （往受保护文件中注入垃圾），而死代码注入
    //     是面向自身（往此模块源码中注入垃圾）。
    //     两者在同一个函数中并存可能导致意外交互。
    //     为安全起见，直接关闭死代码注入。
    // =================================================================
    dead_code_injection: false,

    // =================================================================
    // --- string_split: 字符串拆分 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 将正则模式字符串拆分为片段，
    //     防止攻击者搜索 "re.compile" 定位关键函数。
    //     注意: string_split 与 encrypt_strings 不同，
    //     它只是将字符串字面量拆分为 "a" + "b" 形式，
    //     不改变字符串的运行时值。因此不会破坏正则匹配。
    // =================================================================
    string_split: true,

    // =================================================================
    // --- obfuscate_imports: 导入混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 隐藏对 re 模块的依赖，攻击者不能通过 import re
    //     推断此模块可能使用正则表达式。
    // =================================================================
    obfuscate_imports: true,

    // =================================================================
    // --- obfuscate_calls: 函数调用混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 隐藏 re.compile()、re.sub() 等调用。
    //     调用混淆通过间接调用（getattr）方式实现，
    //     不影响运行时行为。
    // =================================================================
    obfuscate_calls: true,

    // =================================================================
    // --- obfuscate_arithmetic: 算术混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 压缩模块中几乎不使用算术，开启没有副作用。
    // =================================================================
    obfuscate_arithmetic: true,

    // =================================================================
    // --- obfuscate_booleans: 布尔表达式混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 对条件判断进行混淆，增加反编译阅读难度。
    // =================================================================
    obfuscate_booleans: true,
  },

  anti_debug: {
    // =================================================================
    // --- enabled: 反调试总开关 ---
    //   可用值: true | false
    //   推荐值: false
    //   原因: 压缩模块在构建时运行（构建受保护文件时调用），
    //     不在运行时执行。构建环境是受控的本地机器，
    //     反调试会导致 CI/CD 流水线出错或 PyCharm 中调试构建
    //     流程时被误杀。
    //     压缩模块不包含任何需要在运行时保护的数据。
    // =================================================================
    enabled: false,

    // 以下字段保持默认值。enabled=false 时这些配置不会被使用。
    action: "warn",
    checks: ["pdb", "debugger"],
  },
}
