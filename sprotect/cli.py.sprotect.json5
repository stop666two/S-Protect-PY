  obfuscate: {
    // ------------------------------------------------------------------
    // 娣锋穯绛夌骇: 3
    // ------------------------------------------------------------------
    // 閫夊瀷鐞嗙敱:
    //   CLI 妯″潡涓嶅寘鍚牳蹇冧繚鎶ら€昏緫锛堟牳蹇冨湪 crypto.py / loader.py锛?    //   閫嗗悜浠峰€间綆锛屾敾鍑昏€呭嵆浣跨湅鎳?CLI 涔熸棤娉曠粫杩囪繍琛屾椂淇濇姢
    //   level 3 鎻愪緵: 鍙橀噺閲嶅懡鍚?+ 鍙€夌殑瀛楃涓插姞瀵?    //
    // 涓嶅紑鍒?4/5 鐨勫師鍥?
    //   鈶?argparse 鐨?add_argument 閾惧紡璋冪敤琚帶鍒舵祦骞冲潶鍖栧悗蹇呭畾鏂
    //   鈶?姝讳唬鐮佹敞鍏ュ彲鑳界牬鍧忓瓙鍛戒护鍒ゆ柇鐨?if-elif 閾?    //   鈶?鍑芥暟鍚嶉噸鍛藉悕浼氬鑷?entry_points 鎵句笉鍒?main()
    // ------------------------------------------------------------------
    level: 3,

    // --- 鍙橀噺閲嶅懡鍚?---
    // true: 灏?parser, subparsers, args 绛夊眬閮ㄥ彉閲忔敼涓烘棤鎰忎箟鍚?    //       涓嶅奖鍝?argparse 鍐呴儴杩愯锛屽洜涓?argparse 閫氳繃鍙傛暟鍚嶇粦瀹氱殑
    //       鏄瓧绗︿覆锛?build' / 'encrypt' 绛夛級锛屼笉鏄彉閲忓悕
    rename_variables: true,

    // --- 鍑芥暟閲嶅懡鍚?---
    // 鉂?蹇呴』涓?false
    // 鏍瑰洜:
    //   setup.py 涓厤缃?
    //     entry_points={
    //       'console_scripts': [
    //         'sprotect=sprotect.cli:main',
    //       ],
    //     }
    //   setuptools 閫氳繃瀛楃涓?'sprotect.cli:main' 鏌ユ壘鍑芥暟
    //   閲嶅懡鍚嶅悗瀛楃涓叉寚鍚戠殑鍑芥暟鍚嶄笉瀛樺湪锛屽叆鍙ｇ偣鎶涘嚭 ModuleNotFoundError
    // 琛ュ厖:
    //   build_parser() 铏界劧褰撳墠鏈澶栭儴鐩存帴寮曠敤锛屼絾淇濈暀鍘熷悕鏂逛究
    //   灏嗘潵鍋?CLI 鍗曞厓娴嬭瘯鏃堕€氳繃 cli.build_parser() 璋冪敤
    rename_functions: false,

    // --- 绫婚噸鍛藉悕 ---
    // 鉂?蹇呴』涓?false
    // 鏍瑰洜:
    //   argparse 鍐呴儴浣跨敤 class.__name__ 鍋氱被鍨嬪垽鏂拰甯姪鏍煎紡鍖?    //   铏界劧褰撳墠浠ｇ爜娌℃湁瀹氫箟鑷畾涔?argparse 绫伙紝浣嗕繚鎸?false 閬垮厤
    //   鏈潵鎵╁睍鏃跺紩鍏ヨ嚜瀹氫箟 Action/Hierarchy 绫诲鑷村紓甯?    rename_classes: false,

    rename_rules: {
      // 鍛藉悕椋庢牸: 鍗佸叚杩涘埗鍓嶇紑锛坃0x + 闅忔満鏁板瓧锛?      style: "hex",

      // --- 淇濈暀鍚嶇О鍒楄〃 ---
      // main:         CLI 鍏ュ彛鍑芥暟锛岃 setup.py entry_points 纭紩鐢?      // build_parser: 瀛愬懡浠よВ鏋愬櫒鏋勫缓鍑芥暟锛屼繚鐣欎互渚垮仛鍗曞厓娴嬭瘯
      //               娴嬭瘯浠ｇ爜涓父閫氳繃 cli.build_parser() 鑾峰彇瑙ｆ瀽鍣?      reserved: ["main", "build_parser"],
    },

    // --- 瀛楃涓插姞瀵?---
    // true: 鍔犲瘑 argparse 鐨勬弿杩版枃鏈拰閿欒淇℃伅
    // 褰卞搷:
    //   鈥?--help 杈撳嚭鐨勫府鍔╂枃鏈細琚贩娣嗭紙鐪嬭捣鏉ヤ贡鐮侊級
    //   鈥?argparse 鍐呴儴閫昏緫涓嶅彈褰卞搷锛堣В瀵嗗悗姝ｅ父鍖归厤锛?    //   鈥?閿欒淇℃伅锛堝 usage:锛変篃浼氳鍔犲瘑
    // 鏉冭　:
    //   濡傛灉椤圭洰闇€瑕?CLI 閮ㄧ讲缁欑粓绔敤鎴凤紝寤鸿 false 淇濈暀 --help 鍙鎬?    //   鐩墠璁句负 true 鏄负浜嗗鍔犻潤鎬佸垎鏋愮殑闅惧害
    encrypt_strings: true,

    // --- 鏁板瓧鍔犲瘑 ---
    // false: cli.py 涓病鏈夋晱鎰熸暟瀛楀父閲忥紙绔彛鍙?瀵嗛挜闀垮害绛夛級
    //       浠呮湁 argparse 鐨勯粯璁ゅ弬鏁板€硷紝鍔犲瘑娌℃湁鎰忎箟
    encrypt_numbers: false,

    // --- 鎺у埗娴佸钩鍧﹀寲 ---
    // 鉂?蹇呴』涓?false
    // 鏍瑰洜:
    //   argparse 浣跨敤 builder 妯″紡閾惧紡璋冪敤:
    //     parser = subparsers.add_parser('build', ...)
    //     parser.add_argument('--output')
    //     parser.set_defaults(func=build_cmd)
    //   鎺у埗娴佸钩鍧﹀寲浼氶噸鏋?if-else 涓?switch-dispatch 妯″紡
    //   閾惧紡璋冪敤鍦ㄨ繖绉嶆ā寮忎笅浼氳繑鍥為敊璇殑瀵硅薄寮曠敤
    //   瀹炴祴缁撴灉: ArgumentParser 瀵硅薄鐨勬柟娉曢摼鏂瀵艰嚧 TypeError
    control_flow_flattening: false,

    // --- 姝讳唬鐮佹敞鍏?---
    // 鉂?蹇呴』涓?false
    // 鏍瑰洜:
    //   姝讳唬鐮佹敞鍏ヤ細鎻掑叆 if False: 鍧楋紝鍏朵腑鍙兘鍖呭惈瀵?argparse 瀵硅薄鐨勮皟鐢?    //   铏界劧涓嶄細鎵ц锛屼絾 Python 鍦ㄧ紪璇戞椂浼氳В鏋愯娉?    //   娉ㄥ叆鐨勪唬鐮佸彲鑳戒笉灏忓績淇敼 parser 鐨勭姸鎬侊紙濡傛剰澶栬皟鐢?add_argument锛?    //   鎴栧紩鐢ㄤ笉瀛樺湪鐨勫彉閲忓鑷?NameError
    dead_code_injection: false,
    // --- 字符串分割 ---
    string_split: true,
    // --- import 混淆 ---
    obfuscate_imports: true,
    // --- 函数调用混淆 ---
    obfuscate_calls: true,
  },

  anti_debug: {
    // --- 鎬诲紑鍏? false ---
    // 閫夊瀷鐞嗙敱:
    //   CLI 闃舵鍦ㄦ瀯寤烘満鍣ㄤ笂杩愯锛屾槸寮€鍙戣€呰嚜宸辩殑鐜
    //   寮€鍚弽璋冭瘯浼氬鑷?
    //     鈥?寮€鍙戞椂浣跨敤 pdb 璋冭瘯瀛愬懡浠ら€昏緫琚樆姝?    //     鈥?闆嗘垚娴嬭瘯涓?pytest --pdb 琚娴嬪埌瀵艰嚧绋嬪簭閫€鍑?    //   CLI 妯″潡鏈韩涓婅堪鏀诲嚮闈㈠垎鏋愪篃璇存槑浜嗏€斺€斿畠涓嶅寘鍚晱鎰熼€昏緫
    enabled: false,

    // --- 妫€娴嬪埌璋冭瘯鏃剁殑琛屼负 ---
    // warn: 鎵撳嵃璀﹀憡浣嗕笉闃绘杩愯
    //       鍥?enabled 涓?false锛屾璁剧疆褰撳墠涓嶄細鐢熸晥
    action: "warn",

    // --- 鍚敤鐨勮皟璇曟娴嬮」 ---
    // pdb:      妫€娴?pdb.set_trace() 鏄惁琚皟鐢?    // debugger: 妫€娴?sys.gettrace() 鏄惁杩斿洖闈?None
    checks: ["pdb", "debugger"],
  },
}

