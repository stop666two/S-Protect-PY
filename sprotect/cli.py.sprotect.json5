{
  // ========================================================================
  // CLI 入口模块 - 命令行解析与分发
  // ========================================================================
  // 所属层级: 应用层 (Application Layer)
  // 文件位置: sprotect/cli.py
  //
  // ┌─ 功能概述 ──────────────────────────────────────────────────────────┐
  // │ 此模块是整个工具的 CLI 入口，负责:                                   │
  // │   ① argparse 参数解析框架搭建                                       │
  // │   ② 子命令注册: build | encrypt | config | init | watermark |       │
  // │     version                                                        │
  // │   ③ watermark 嵌套子命令: extract | verify | list                  │
  // │   ④ config 嵌套子命令: init | show                                  │
  // │   ⑤ 退出码统一管理 (sys.exit)                                       │
  // │   ⑥ 参数校验与用户交互提示                                           │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 架构约束 ──────────────────────────────────────────────────────────┐
  // │ ⚠ main() 函数被 setup.py 的 entry_points 控制台脚本直接引用         │
  // │   → 必须保留原名，不可重命名                                        │
  // │ ⚠ argparse 帮助字符串（description/epilog）在加密后会导致            │
  // │   --help 输出内容被混淆（生成乱码），但这不影响参数解析工作           │
  // │   因为 argparse 内部会先解码再展示                                   │
  // │ ⚠ 此模块在 build 过程中最先被执行，不参与运行时代码保护              │
  // │   它的作用仅仅是: 收集参数 → 校验 → 分发给具体模块                   │
  // └───────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 攻击面分析 ────────────────────────────────────────────────────────┐
  // │ 攻击者可能:                                                         │
  // │   • 修改子命令入口以绕过加密流程                                     │
  // │   • 替换 main() 直接调用底层函数                                     │
  // │   • 注入恶意参数使 build 过程执行非预期操作                          │
  // │ 防护策略:                                                           │
  // │   • 子命令通过字符串匹配分发，混淆后依然安全                         │
  // │   • 参数校验在主流程进行，CLI 仅负责传递                             │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 变更历史 ──────────────────────────────────────────────────────────┐
  // │ v1.0 初始版本，支持 6 个子命令                                      │
  // │ v1.1 添加 watermark 嵌套子命令                                      │
  // │ v1.2 添加 config 嵌套子命令                                         │
  // └─────────────────────────────────────────────────────────────────────┘
  // ========================================================================

  obfuscate: {
    // ------------------------------------------------------------------
    // 混淆等级: 3
    // ------------------------------------------------------------------
    // 选型理由:
    //   CLI 模块不包含核心保护逻辑（核心在 crypto.py / loader.py）
    //   逆向价值低，攻击者即使看懂 CLI 也无法绕过运行时保护
    //   level 3 提供: 变量重命名 + 可选的字符串加密
    //
    // 不开到 4/5 的原因:
    //   ① argparse 的 add_argument 链式调用被控制流平坦化后必定断裂
    //   ② 死代码注入可能破坏子命令判断的 if-elif 链
    //   ③ 函数名重命名会导致 entry_points 找不到 main()
    // ------------------------------------------------------------------
    level: 3,

    // --- 变量重命名 ---
    // true: 将 parser, subparsers, args 等局部变量改为无意义名
    //       不影响 argparse 内部运行，因为 argparse 通过参数名绑定的
    //       是字符串（'build' / 'encrypt' 等），不是变量名
    rename_variables: true,

    // --- 函数重命名 ---
    // ❗ 必须为 false
    // 根因:
    //   setup.py 中配置:
    //     entry_points={
    //       'console_scripts': [
    //         'sprotect=sprotect.cli:main',
    //       ],
    //     }
    //   setuptools 通过字符串 'sprotect.cli:main' 查找函数
    //   重命名后字符串指向的函数名不存在，入口点抛出 ModuleNotFoundError
    // 补充:
    //   build_parser() 虽然当前未被外部直接引用，但保留原名方便
    //   将来做 CLI 单元测试时通过 cli.build_parser() 调用
    rename_functions: false,

    // --- 类重命名 ---
    // ❗ 必须为 false
    // 根因:
    //   argparse 内部使用 class.__name__ 做类型判断和帮助格式化
    //   虽然当前代码没有定义自定义 argparse 类，但保持 false 避免
    //   未来扩展时引入自定义 Action/Hierarchy 类导致异常
    rename_classes: false,

    rename_rules: {
      // 命名风格: 十六进制前缀（_0x + 随机数字）
      style: "hex",

      // --- 保留名称列表 ---
      // main:         CLI 入口函数，被 setup.py entry_points 硬引用
      // build_parser: 子命令解析器构建函数，保留以便做单元测试
      //               测试代码中常通过 cli.build_parser() 获取解析器
      reserved: ["main", "build_parser"],
    },

    // --- 字符串加密 ---
    // true: 加密 argparse 的描述文本和错误信息
    // 影响:
    //   • --help 输出的帮助文本会被混淆（看起来乱码）
    //   • argparse 内部逻辑不受影响（解密后正常匹配）
    //   • 错误信息（如 usage:）也会被加密
    // 权衡:
    //   如果项目需要 CLI 部署给终端用户，建议 false 保留 --help 可读性
    //   目前设为 true 是为了增加静态分析的难度
    encrypt_strings: true,

    // --- 数字加密 ---
    // false: cli.py 中没有敏感数字常量（端口号/密钥长度等）
    //       仅有 argparse 的默认参数值，加密没有意义
    encrypt_numbers: false,

    // --- 控制流平坦化 ---
    // ❗ 必须为 false
    // 根因:
    //   argparse 使用 builder 模式链式调用:
    //     parser = subparsers.add_parser('build', ...)
    //     parser.add_argument('--output')
    //     parser.set_defaults(func=build_cmd)
    //   控制流平坦化会重构 if-else 为 switch-dispatch 模式
    //   链式调用在这种模式下会返回错误的对象引用
    //   实测结果: ArgumentParser 对象的方法链断裂导致 TypeError
    control_flow_flattening: false,

    // --- 死代码注入 ---
    // ❗ 必须为 false
    // 根因:
    //   死代码注入会插入 if False: 块，其中可能包含对 argparse 对象的调用
    //   虽然不会执行，但 Python 在编译时会解析语法
    //   注入的代码可能不小心修改 parser 的状态（如意外调用 add_argument）
    //   或引用不存在的变量导致 NameError
    dead_code_injection: false,
  },

  anti_debug: {
    // --- 总开关: false ---
    // 选型理由:
    //   CLI 阶段在构建机器上运行，是开发者自己的环境
    //   开启反调试会导致:
    //     • 开发时使用 pdb 调试子命令逻辑被阻止
    //     • 集成测试中 pytest --pdb 被检测到导致程序退出
    //   CLI 模块本身上述攻击面分析也说明了——它不包含敏感逻辑
    enabled: false,

    // --- 检测到调试时的行为 ---
    // warn: 打印警告但不阻止运行
    //       因 enabled 为 false，此设置当前不会生效
    action: "warn",

    // --- 启用的调试检测项 ---
    // pdb:      检测 pdb.set_trace() 是否被调用
    // debugger: 检测 sys.gettrace() 是否返回非 None
    checks: ["pdb", "debugger"],
  },
}
