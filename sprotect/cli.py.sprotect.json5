{
  // ==========================================
  // CLI 命令行入口模块 - 精细化配置
  // 解析命令行参数、分发子命令（build/encrypt/config/init/version）
  // ==========================================

  obfuscate: {
    level: 3,                    // CLI 需要保持一定可读性以显示帮助信息
    rename_variables: true,       // 安全，推荐开启
    rename_functions: false,      // CLI 函数可能被外部调试，保持稳定
    rename_classes: false,
    rename_rules: {
      style: "hex",
      reserved: ["main", "build_parser", "build_project"],
    },
    encrypt_strings: true,        // 加密提示文字和错误信息
    encrypt_numbers: false,
    remove_docstrings: false,     // CLI 帮助信息依赖 docstring
    remove_comments: true,
    strip_blank_lines: true,
    control_flow_flattening: false, // CLI 逻辑简单，不需平坦化
    dead_code_injection: false,
  },

  anti_debug: {
    enabled: false,               // CLI 阶段不启用反调试
    action: "warn",
    checks: ["pdb"],
  },
}
