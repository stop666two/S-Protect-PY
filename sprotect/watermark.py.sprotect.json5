{
  // ===================================================================
  // 水印模块 — 三层溯源追踪
  // ===================================================================
  // 此模块负责在受保护文件的源码中注入数字水印，
  // 用于追踪数据泄露的来源。
  //
  // 水印层级：
  //   第一层 — build_id + batch_id（哪次构建、哪个批次）
  //   第二层 — 授权用户 ID（哪个用户被授权）
  //   第三层 — 时间戳 + 随机 Nonce（防重放攻击）
  //
  // 水印格式：
  //   (lambda _sP=__import__('builtins'): ...)(...)
  //   该 lambda 在源码末尾精确注入，不修改其他代码。
  //
  // ⚠️ 关键约束 ⚠️
  //   • Watermark.code() 使用 ast 模块在源码末尾
  //     精确注入 lambda 表达式。它通过计算 AST 的
  //     总行数来确定注入位置。
  //   • control_flow_flattening=true 会打乱函数体内的
  //     代码块顺序和标签结构 → 导致 AST 行数计算偏移
  //     → 水印 lambda 被注入到错误位置
  //     → 注入位置错误 → 生成的源码语法错误
  //   • dead_code_injection=true 会在源码中插入
  //     大量无用代码块 → 部分代码可能"污染"水印 lambda
  //     → 水印被拆分为多个片段
  //     → 验证时 compute_hash() 计算错误哈希值
  //     → 水印验证失败，合法用户被判定为"未授权"
  //
  // 安全等级：中
  //   水印本身的作用是"溯源"而非"防护"。
  //   攻击者移除水印不会影响解密功能。
  //   混淆以"不破坏水印注入逻辑"为最高优先级。
  // ===================================================================

  obfuscate: {
    // =================================================================
    // --- level: 混淆等级 ---
    //   数据类型: number（整数）
    //   可用值: 1 | 2 | 3 | 4 | 5
    //   ⚠️ 不可用值: 0, -1, 1.5
    //   推荐值: 3
    //   ❌ 禁止值: 4 | 5（可能引入不可预见的 AST 变换冲突）
    //   原因:
    //     水印模块的核心逻辑是：
    //     1. 解析源码为 AST
    //     2. 在 AST 末尾注入 lambda 节点
    //     3. 将 AST 反编译为源码字符串
    //     4. 验证注入后的哈希值
    //
    //     等级 4-5 的混淆可能对 ast.parse() / ast.unparse()
    //     的调用方式进行过度变换，导致：
    //     • ast.unparse() 输出格式异常（缩进错误）
    //     • lambda 表达式中的变量作用域分析失败
    //     • 水印验证的哈希计算引用错误变量
    //
    //     等级 3 在"可读性降低"和"功能安全"之间取得平衡。
    //     变量名被重命名、字符串被加密、调用被混淆，
    //     但控制流和 AST 操作保持原样。
    // =================================================================
    level: 5,

    // =================================================================
    // --- rename_variables: 变量重命名 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 隐藏 code()、compute_hash() 中的局部变量用途。
    //     Watermark 类中的 `build_id`、`user_id`、`nonce`
    //     等变量暗示了水印的结构，重命名后攻击者不能
    //     一眼看出哪些数据被嵌入水印。
    // =================================================================
    rename_variables: true,

    // =================================================================
    // --- rename_functions: 函数重命名 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 水印模块的函数（code、compute_hash、verify）
    //     不被其他模块 import（水印生成在构建过程中内联调用）。
    //     因此函数重命名没有外部依赖风险。
    // =================================================================
    rename_functions: true,

    // =================================================================
    // --- rename_classes: 类重命名 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: Watermark 类只在此模块内部使用，没有外部引用。
    //     重命名后攻击者不能通过搜索 "class Watermark"
    //     定位水印注入代码。
    // =================================================================
    rename_classes: true,

    // --- rename_rules: 重命名规则 ---
    // 可用值: { style: string, reserved: string[], prefix: string, suffix: string, min_length: number, blacklist: string[] }
    //   - style: 命名风格 — "hex" | "random" | "chinese" | "invisible"
    //   - reserved: 保留名称列表（不会被重命名的标识符）
    //   - prefix: 重命名后标识符的前缀，如 "_"
    //   - suffix: 重命名后标识符的后缀，如 "_"
    //   - min_length: 重命名后标识符的最小长度
    //   - blacklist: 禁止使用的标识符列表
    // 推荐值: { style: "hex", reserved: [], prefix: "", suffix: "", min_length: 6, blacklist: [] }
    // ⚠️ 模块特殊原因: 水印模块的 code()、compute_hash()、verify()
    //   等函数虽不被外部直接 import，但它们是模块的公开 API，
    //   保留原名便于构建过程中的内联调用和测试。
    //   使用空数组时所有函数都会被重命名（rename_functions=true），
    //   此处显式声明以确保配置清晰。
    rename_rules: {
      style: "hex",
      reserved: [],
      prefix: "",
      suffix: "",
      min_length: 6,
      blacklist: [],
    },

    // =================================================================
    // --- encrypt_strings: 字符串加密 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 隐藏水印模板字符串（如 lambda 的源码模板、
    //     builtins 模块名等）。攻击者不能通过搜索
    //     "lambda _sP=__import__" 来定位水印注入点。
    //     ⚠️ 注意: 水印模板字符串必须精确匹配格式，
    //       encrypt_strings 使用运行时解密，不影响最终字符串值。
    //       只要解密后的字符串和预期一致，水印注入逻辑正常。
    // =================================================================
    encrypt_strings: true,

    // =================================================================
    // --- encrypt_numbers: 数字加密 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: false
    //   原因: 水印模块中唯一的数字是 build_id 和 batch_id。
    //     这些数字不敏感（它们的含义在数据库映射中）。
    //     加密这些数字不会带来额外安全收益。
    // =================================================================
    encrypt_numbers: false,

    // --- string_min_length: 字符串最小加密长度 ---
    // 可用值: number（>= 0，小于此长度的字符串不加密）
    // 推荐值: 3
    // ⚠️ 模块特殊原因: encrypt_strings=true，设置最小长度 3
    //   可以避免加密过短的无关字符串（如 "a"、"=="），
    //   减少运行时解密开销。
    string_min_length: 3,

    // --- string_encrypt_ratio: 字符串加密比例 ---
    // 可用值: 0.0 ~ 1.0（0.0=不加密任何字符串，1.0=加密所有字符串）
    // 推荐值: 1.0
    // ⚠️ 模块特殊原因: encrypt_strings=true，比值设为 1.0
    //   确保所有长度 >= string_min_length 的字符串都被加密，
    //   最大化对水印模板字符串的保护。
    string_encrypt_ratio: 1.0,

    // --- string_cipher: 字符串加密算法 ---
    // 可用值: "base64" | "xor" | "aes"
    // 推荐值: "aes"
    // ⚠️ 模块特殊原因: 水印模板字符串是攻击者的关键搜索目标，
    //   使用 AES 加密提供最高强度的静态保护。
    string_cipher: "aes",

    // =================================================================
    // --- control_flow_flattening: 控制流平坦化 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   ⚠️ 不可用值: 非布尔值
    //   推荐值: false
    //   ❌ 禁止值: true
    //   原因（关键约束 — 详细展开）:
    //
    //     Watermark.code() 的工作原理：
    //       1. tree = ast.parse(source)  ← 解析为 AST
    //       2. 计算 tree.body[-1].lineno  ← 获取最后一行行号
    //       3. 构造 lambda AST 节点         ← 构建水印
    //       4. tree.body.append(watermark)  ← 追加到 AST 末尾
    //       5. result = ast.unparse(tree)  ← 反编译为源码
    //
    //     控制流平坦化会遍历 Obfuscator.visit_FunctionDef()，
    //     将函数体转换为此格式：
    //       while True:
    //           if state == 0: ... state = 5
    //           elif state == 5: ... state = 2
    //           elif state == 2: ... state = 3
    //           ...
    //     这种变换会：
    //     1. 修改 ast.parse() 返回的 AST 的 lineno 属性
    //        → Watermark.code() 计算的最后一行行号错误
    //     2. 在源码中插入大量状态变量和标签
    //        → 水印 lambda 被注入到 while 循环中间
    //        → ast.unparse() 输出的源码在注入位置语法错误
    //     3. lambda 中的 _sP 变量捕获作用域被破坏
    //        → 水印在运行时抛出 NameError
    //
    //     简而言之：控制流平坦化和 AST 注入水印是不兼容的。
    //     这是硬性约束，不能为了增加混淆而牺牲水印功能。
    // =================================================================
    control_flow_flattening: false,

    // =================================================================
    // --- dead_code_injection: 死代码注入 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: false
    //   ❌ 禁止值: true
    //   原因（关键约束 — 详细展开）:
    //
    //     死代码注入通过 Obfuscator 在每个函数作用域中
    //     插入大量永远不会被执行的条件分支。注入器使用
    //     随机种子生成不可达的 if/while 块。
    //
    //     与水印的冲突点：
    //     1. 死代码可能被注入到 lambda 表达式内部
    //        → 水印 lambda 被"污染"了额外的代码行
    //        → 水印的 compute_hash() 计算的哈希值错误
    //     2. 死代码中的变量定义可能和 lambda 中的 _sP 重名
    //        → 变量捕获歧义 → lambda 在运行时抛出 UnboundLocalError
    //     3. 死代码注入器可能修改 ast.unparse() 的缩进设置
    //        → 水印 lambda 的缩进级别错误
    //        → 生成的源码因 IndentationError 无法执行
    //
    //     死代码注入的收益（增加反编译难度）远小于风险
    //     （水印功能失效）。此模块必须关闭死代码注入。
    // =================================================================
    dead_code_injection: false,

    // --- dead_code_density: 死代码密度 ---
    // 可用值: 0.0 ~ 1.0（0.0=不注入，1.0=最大密度）
    // 推荐值: 0.0
    // ⚠️ 模块特殊原因: dead_code_injection=false，此字段无效。
    dead_code_density: 0.0,

    // --- opaque_predicate_count: 不透明谓词数量 ---
    // 可用值: number（>= 0）
    // 推荐值: 0
    // ⚠️ 模块特殊原因: 不透明谓词可能触发死代码生成器，
    //   为了安全全部关闭。
    opaque_predicate_count: 0,

    // --- remove_docstrings: 移除文档字符串 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 保留 docstring 有助于模块维护。
    remove_docstrings: false,

    // --- remove_comments: 移除注释 ---
    // 可用值: true | false
    // 推荐值: true
    // ⚠️ 模块特殊原因: 注释在构建产物中无意义，移除可减小体积。
    remove_comments: true,

    // --- strip_blank_lines: 移除空行 ---
    // 可用值: true | false
    // 推荐值: true
    // ⚠️ 模块特殊原因: 移除空行可减小构建产物体积。
    strip_blank_lines: true,

    // --- max_line_length: 最大行长度 ---
    // 可用值: number（0 = 不限制）
    // 推荐值: 0
    // ⚠️ 模块特殊原因: 水印 lambda 表达式可能较长，
    //   不做行长度限制以避免被截断。
    max_line_length: 0,

    // =================================================================
    // --- string_split: 字符串拆分 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 将 "builtins" 拆分为 "bui" + "ltins" 等片段，
    //     防止攻击者搜索 "builtins" 定位水印中的 import 逻辑。
    //     字符串拆分在 AST 级别工作，不会影响最终字符串值。
    // =================================================================
    string_split: true,

    // =================================================================
    // --- obfuscate_imports: 导入混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 隐藏 Watermark 模块依赖了哪些标准库（ast、hashlib 等）。
    //     攻击者不能通过 import 列表快速推断水印可能使用的算法。
    // =================================================================
    obfuscate_imports: true,

    // =================================================================
    // --- obfuscate_calls: 函数调用混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 隐藏 water_mark.code()、compute_hash() 等调用关系。
    //     攻击者不能一眼看出 code() 调用了 compute_hash()。
    // =================================================================
    obfuscate_calls: true,

    // =================================================================
    // --- obfuscate_arithmetic: 算术混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 将行号计算（len(tree.body)）和索引操作
    //     转换为复杂表达式，增加静态分析难度。
    //     但与 control_flow_flattening 不同，算术混淆
    //     不会改变 AST 的结构，不影响水印注入功能。
    // =================================================================
    obfuscate_arithmetic: true,

    // =================================================================
    // --- obfuscate_booleans: 布尔表达式混淆 ---
    //   数据类型: boolean
    //   可用值: true | false
    //   推荐值: true
    //   原因: 对水印验证逻辑中的条件判断（hash == expected）
    //     进行布尔混淆，使攻击者不能快速定位验证点。
    // =================================================================
    obfuscate_booleans: true,
  },

  anti_debug: {
    // =================================================================
    // --- enabled: 反调试总开关 ---
    //   可用值: true | false
    //   推荐值: false
    //   原因: 水印模块在构建时运行（注入水印到源码中），
    //     不在运行时执行。构建过程是受控的本地环境，
    //     不需要反调试保护。
    //     注意：水印的验证过程在运行时执行（受保护文件启动时），
    //     但验证逻辑被注入到受保护文件的 main.py 中，
    //     而不是在 watermark.py 中。因此 watermark.py
    //     本身不需要反调试。
    // =================================================================
    enabled: false,

    // --- action: 反调试触发时的全局行为 ---
    // 可用值: "warn" | "exit" | "crash" | "corrupt"
    // 推荐值: "warn"
    // ⚠️ 模块特殊原因: enabled=false，此字段不生效。
    action: "warn",

    // --- checks: 启用的反调试检查列表 ---
    // 可用值: string[]，支持: "pdb", "debugger", "ptrace",
    //   "process_name", "remote_debug", "container", "vm"
    // 推荐值: []
    // ⚠️ 模块特殊原因: 构建模块不需要任何反调试检查。
    checks: [],

    // --- per_check_actions: 每个检查的独立触发动作 ---
    // 可用值: string[]，与 checks 数组一一对应
    //   每个元素可为: "warn" | "exit" | "crash" | "corrupt"
    // 推荐值: []
    // ⚠️ 模块特殊原因: checks 为空，此字段无效。
    per_check_actions: [],

    // --- process_whitelist: 允许调试的进程白名单 ---
    // 可用值: string[]（进程名列表）
    // 推荐值: []
    // ⚠️ 模块特殊原因: enabled=false，无需白名单。
    process_whitelist: [],

    // --- block_tracing: 阻止系统级跟踪 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: enabled=false，无需阻止跟踪。
    block_tracing: false,

    // --- timing_threshold: 反调试超时阈值（秒） ---
    // 可用值: number（0 = 禁用定时检查）
    // 推荐值: 0
    // ⚠️ 模块特殊原因: enabled=false，无需定时检查。
    timing_threshold: 0,

    // --- exit_code: 反调试触发时的进程退出码 ---
    // 可用值: number（通常为 1 或负数）
    // 推荐值: 1
    // ⚠️ 模块特殊原因: enabled=false，此字段不生效。
    exit_code: 1,

    // --- wipe_memory: 退出时擦除敏感内存 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 此模块无敏感内存数据。
    wipe_memory: false,

    // --- corrupt_on_exit: 退出时损坏关键数据 ---
    // 可用值: true | false
    // 推荐值: false
    // ⚠️ 模块特殊原因: 此模块无关键数据可损坏。
    corrupt_on_exit: false,
  },
}
