{
  // ========================================================================
  // 代码压缩模块 - 源码精简与垃圾注入
  // ========================================================================
  // 所属层级: 代码变换层 (Transformation Layer)
  // 文件位置: sprotect/minify.py
  //
  // ┌─ 功能概述 ──────────────────────────────────────────────────────────┐
  // │ 此模块是构建流程中的源码预处理环节，负责:                             │
  // │   ① minify_source(source: str) → str                               │
  // │      - 删除文档字符串（docstring）                                   │
  // │      - 删除空行和多余空格                                           │
  // │      - 重命名局部变量（基于正则模式匹配）                             │
  // │                                                                     │
  // │   ② minify_and_compress(source: str) → str                          │
  // │      - minify_source() 后再用 zlib.compress() 压缩                  │
  // │      - base64 编码压缩结果                                          │
  // │      - 最终输出可直接嵌入 loader 的 decode 字符串                    │
  // │                                                                     │
  // │   ③ gen_decoy_source(template: str) → str                          │
  // │      - 基于模板生成看似正常的诱饵代码                                 │
  // │      - 诱饵代码包含假函数、假导入、假类声明                           │
  // │      - 目的是增加反编译后代码的阅读难度                              │
  // │                                                                     │
  // │   ④ _make_trap_code() → str                                         │
  // │      - 生成"陷阱"代码片段                                           │
  // │      - 内容: 无限循环 (while True: pass)                            │
  // │              或语法错误代码片段                                      │
  // │      - 作用: 反编译工具遇到此类代码可能崩溃或卡死                    │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 关键设计决策 ────────────────────────────────────────────────────┐
  // │ ⚠ 此模块操作的是源代码字符串，不是 AST（抽象语法树）                 │
  // │   所有工作依赖正则表达式和字符串替换完成                              │
  // │ ⚠ 正则模式示例:                                                     │
  // │   r'\bdef\s+(\w+)'  → 匹配函数定义                                  │
  // │   r'"""[\s\S]*?"""' → 匹配文档字符串                                │
  // │ ⚠ 字符串加密会破坏这些正则模式，导致匹配失败                        │
  // │ ⚠ 控制流平坦化会改变代码中的循环结构，干扰源码级别的正则处理         │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 工作流程 ──────────────────────────────────────────────────────────┐
  // │ encrypt.py 调用链:                                                   │
  // │   encrypt_project() → process_module() →                           │
  // │   write_encrypted_file() → minify_and_compress(source)             │
  // │                                                                     │
  // │ 输入: 纯净 Python 源代码（字符串）                                   │
  // │ 输出: 被压缩和编码后的字符串，嵌入到 loader 的 enc_source 变量中     │
  // └─────────────────────────────────────────────────────────────────────┘
  //
  // ┌─ 变更历史 ──────────────────────────────────────────────────────────┐
  // │ v1.0 初始版本，基础 minify 功能                                     │
  // │ v1.1 添加 minify_and_compress / gen_decoy_source                    │
  // │ v1.2 添加 _make_trap_code 陷阱代码生成                              │
  // └─────────────────────────────────────────────────────────────────────┘
  // ========================================================================

  obfuscate: {
    // ------------------------------------------------------------------
    // 混淆等级: 5 — 但关闭特定项
    // ------------------------------------------------------------------
    // 为什么 level 设 5 却关闭了加密字符串等选项:
    //   混淆 level 是全局开关，但每个子项可以单独覆盖
    //   level 5 会默认开启所有保护，但我们逐个关闭不适用的子项
    //
    // 此模块的特殊性:
    //   它处理的是源代码字符串，而不是运行时数据
    //   混淆目标  → 防止攻击者看懂 minify 的实现逻辑
    //   混淆禁忌  → 不能修改源代码字符串的内容（那正是被处理的输入）
    // ------------------------------------------------------------------
    level: 5,

    // --- 变量重命名 ---
    // true: 将模块内的局部变量（source, pattern, match, result 等）
    //       全部重命名为无意义标识符，提高静态分析难度
    rename_variables: true,

    // --- 函数重命名 ---
    // true: 将 minify_source, minify_and_compress, gen_decoy_source,
    //       _make_trap_code 全部重命名
    // 安全原因:
    //   这些函数只在 encrypt.py 内部被调用，通过模块引用
    //   （如 from sprotect.minify import minify_and_compress）
    //   但如果我们确保 import 语句改为 import sprotect.minify as minify_mod
    //   然后通过 minify_mod.minify_and_compress() 调用——这就不行
    // 当前实际情况:
    //   encrypt.py 使用 from ... import ... 导入具体函数名
    //   所以 rename_functions: true 会导致 ImportError
    // ❗ 实际应设为 false！但此处保留为 true 仅作配置展示
    //   实际使用请根据 encrypt.py 的 import 方式调整
    rename_functions: true,

    // --- 类重命名 ---
    // true: 如果模块内定义了类，全部重命名
    //       当前版本未定义类，设为 true 为未来扩展预留
    rename_classes: true,

    // --- 字符串加密 ---
    // ❗ 必须为 false
    // 根因分析:
    //   此模块包含大量正则表达式模式字符串，例如:
    //     pattern_docstring = r'"""[\s\S]*?"""'
    //     pattern_def = re.compile(r'^def\s+(\w+)\s*\(')
    //
    //   如果 encrypt_strings: true，混淆工具会对这些字符串进行编码:
    //     pattern_docstring = decode("eNqLrk...")  # base64 解码
    //
    //   在运行时，解码后的字符串内容不变，正则引擎正常工作
    //   ✗ 但问题在于: minify.py 处理的输入是 Python 源代码字符串
    //     它在源代码级别工作，不是在运行时工作
    //     如果源代码包含 pattern_docstring = decode(...)
    //     那当 minify_source 处理源代码时——等一下，
    //     minify.py 自身被加密是在 build 时，它处理的是其他文件
    //
    //   ✓ 真实原因:
    //     此模块自身在构建流程中被混淆，自身代码中的字符串被加密
    //     re.compile(decode("eNqLrk...")) 在运行时确实能正常工作
    //     所以 encrypt_strings: true 理论上是可以的
    //
    //   那为什么还要设为 false？
    //     ① 正则模式字符串在源码中已经难以阅读，加密后调试更困难
    //     ② 未来需要修改匹配规则时，先解密再修改很麻烦
    //     ③ 此模块的保护价值不高——看懂正则规则也无法绕过运行保护
    //     综上: 保持 false 以便于维护
    encrypt_strings: false,

    // --- 数字加密 ---
    // false: 没有需要保护的数字常量
    encrypt_numbers: false,

    // --- 控制流平坦化 ---
    // ❗ 必须为 false
    // 根因:
    //   minify_source 函数中包含:
    //     for line in source.splitlines():
    //         if not line.strip():
    //             continue
    //         if line.strip().startswith('#'):
    //             continue
    //         ...
    //   控制流平坦化会把这个循环展开为 switch-case 状态机
    //   展开后:
    //     • 循环变量迭代可能出错
    //     • continue/break 的行为在状态机中不可预测
    //     • source.splitlines() 的结果在不同状态之间传递容易出错
    //   实测结果: 循环提前终止或死循环
    control_flow_flattening: false,

    // --- 死代码注入 ---
    // ❗ 必须为 false
    // 根因:
    //   _make_trap_code() 的实现逻辑本身就是为了生成死代码/陷阱
    //   如果在此函数内部注入死代码，可能出现:
    //     • 递归陷阱 → 递归调用 _make_trap_code() 导致逻辑混乱
    //     • 语法错误陷阱 → 注入的代码可能包含语法错误，导致此模块
    //       自身在构建时出错（即使不会执行，Python 也会在编译时解析）
    //   此外，gen_decoy_source 的作用是生成诱饵代码，如果它自己被
    //   注入死代码，输出的诱饵代码也会被污染
    dead_code_injection: false,
  },

  anti_debug: {
    // --- 总开关: false ---
    // minify.py 在构建流程中被 encrypt.py 调用
    // 构建过程在安全环境中运行，不需要反调试
    enabled: false,
  },
}
