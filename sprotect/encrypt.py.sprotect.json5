{
  // ==========================================
  // 加密构建引擎 — build 完整流程
  // ==========================================
  // 此模块是 S-Protect-PY 的核心编排器。
  // 负责完整 build 流程：项目扫描 → 混淆 → 加密 → 启动器生成。
  //
  // 集成了 extra_layers 支持、混合加密、多线程并行处理、
  // 水印报告生成等。
  //
  // 安全等级：最高。此模块掌控整个保护流水线的调度。
  // ==========================================

  obfuscate: {
    level: 5,
    rename_variables: true,
    rename_functions: true,
    rename_classes: true,
    rename_rules: { style: "hex", reserved: [] },
    encrypt_strings: true,
    encrypt_numbers: true,
    control_flow_flattening: true,
    dead_code_injection: true,
    string_split: true,
    obfuscate_imports: true,
    obfuscate_calls: true,
    obfuscate_arithmetic: true,
    obfuscate_booleans: true,
  },

  anti_debug: {
    enabled: true,
    action: "exit",
    checks: ["pdb", "debugger", "vm"],
  },

  virtualization: {
    enabled: true,
    mode: "full",
  },
}
